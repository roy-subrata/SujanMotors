{
  "name": "auto-parts-shop-web",
  "version": "1.0.0",
  "description": "Auto Parts Shop Inventory Management System",
  "scripts": {
    "tailwind:build": "tailwindcss -i ./Styles/input.css -o ./wwwroot/tailwind.css",
    "tailwind:watch": "tailwindcss -i ./Styles/input.css -o ./wwwroot/tailwind.css --watch",
    "dev": "npm run tailwind:watch"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.32",
    "autoprefixer": "^10.4.17",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13"
  },
  "keywords": [
    "auto-parts",
    "inventory",
    "blazor",
    "tailwindcss"
  ]
}
