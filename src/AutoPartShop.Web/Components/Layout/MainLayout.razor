@inherits LayoutComponentBase

<MudThemeProvider />
<MudDialogProvider FullWidth="true" MaxWidth="MaxWidth.Small" BackdropClick="false" CloseOnEscapeKey="true" />
<MudSnackbarProvider />
<MudPopoverProvider />

<div class="flex h-screen bg-dark-50">
    <!-- Sidebar -->
    <aside id="sidebar" class="flex flex-col bg-dark-900 text-white transition-all duration-300 overflow-y-auto border-r border-dark-700 h-screen z-40" style="width: 320px; min-width: 320px;">
        <NavMenu />

        <!-- Sidebar Collapse Toggle (visible on sidebar) -->
        <button id="sidebar-collapse-toggle" class="absolute top-6 right-4 z-50 inline-flex items-center justify-center w-9 h-9 rounded-lg bg-dark-800 text-white hover:bg-dark-700 transition-colors" title="Collapse Sidebar">
            <svg class="w-5 h-5 sidebar-collapse-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
        </button>
    </aside>

    <!-- Main Content Wrapper -->
    <div class="flex flex-col flex-1 transition-all duration-300">
        <!-- Header -->
        <header class="sticky top-0 z-30 bg-white border-b border-dark-200 shadow-sm">
            <div class="flex items-center justify-between h-16 px-6">
                <!-- Logo and Title -->
                <div class="flex items-center space-x-3">
                    <!-- Sidebar Toggle -->
                    <button id="sidebar-toggle" class="inline-flex items-center justify-center w-10 h-10 rounded-lg text-dark-600 hover:bg-dark-100 transition-colors" title="Toggle Sidebar">
                        <svg id="sidebar-toggle-icon" class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                    </button>

                    <!-- Logo -->
                    <div class="flex items-center space-x-2">
                        <div class="w-10 h-10 bg-gradient-to-br from-primary-600 to-primary-800 rounded-lg flex items-center justify-center">
                            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                            </svg>
                        </div>
                        <span class="text-lg font-bold text-dark-900 hidden sm:inline">AutoParts Shop</span>
                    </div>
                </div>

                <!-- Header Actions -->
                <div class="flex items-center space-x-4">
                    <!-- Search Bar -->
                    <div class="hidden sm:block">
                        <div class="relative">
                            <input type="text" placeholder="Search parts, orders..." class="input-field pl-10 w-48 lg:w-64 text-sm" />
                            <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-dark-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                            </svg>
                        </div>
                    </div>

                    <!-- Notifications -->
                    <button class="relative w-10 h-10 rounded-lg text-dark-600 hover:bg-dark-100 transition-colors inline-flex items-center justify-center">
                        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9"></path>
                        </svg>
                        <span class="absolute top-2 right-2 w-2 h-2 bg-red-500 rounded-full"></span>
                    </button>

                    <!-- User Profile Dropdown -->
                    <div class="flex items-center space-x-3 pl-4 border-l border-dark-200">
                        <div class="hidden sm:text-right">
                            <p class="text-sm font-medium text-dark-900">John Doe</p>
                            <p class="text-xs text-dark-500">Admin</p>
                        </div>
                        <button class="w-10 h-10 rounded-full bg-gradient-to-br from-primary-400 to-primary-600 flex items-center justify-center text-white font-semibold hover:shadow-lg transition-shadow">
                            JD
                        </button>
                    </div>
                </div>
            </div>
        </header>

        <!-- Main Content Area -->
        <main class="flex-1 overflow-y-auto">
            <div class="p-6 lg:p-8">
                @Body
            </div>
        </main>
    </div>
</div>


<!-- Error UI -->
<div id="blazor-error-ui" data-nosnippet class="fixed bottom-0 left-0 right-0 bg-red-600 text-white p-4 shadow-lg hidden">
    <div class="flex items-center justify-between max-w-4xl mx-auto">
        <div class="flex items-center space-x-3">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"></path>
            </svg>
            <p class="font-medium">An unhandled error has occurred.</p>
        </div>
        <a href="." class="inline-flex items-center space-x-2 px-4 py-2 bg-white/20 rounded-lg hover:bg-white/30 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
            </svg>
            <span>Reload</span>
        </a>
    </div>
</div>

<script>
    let sidebarVisible = true;

    // Toggle sidebar visibility
    function toggleSidebar() {
        const sidebar = document.getElementById('sidebar');
        const toggleIcon = document.getElementById('sidebar-toggle-icon');
        const collapseToggle = document.getElementById('sidebar-collapse-toggle');

        if (sidebar) {
            sidebarVisible = !sidebarVisible;

            if (sidebarVisible) {
                // Show sidebar
                sidebar.style.width = '320px';
                sidebar.style.minWidth = '320px';
                sidebar.style.opacity = '1';
                sidebar.style.visibility = 'visible';
                toggleIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>';
                if (collapseToggle) collapseToggle.style.display = 'flex';
            } else {
                // Hide sidebar
                sidebar.style.width = '0px';
                sidebar.style.minWidth = '0px';
                sidebar.style.opacity = '0';
                sidebar.style.visibility = 'hidden';
                toggleIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>';
                if (collapseToggle) collapseToggle.style.display = 'none';
            }
        }
    }

    // Collapse button on sidebar itself
    function collapseSidebar() {
        toggleSidebar();
    }

    // Event listeners
    document.addEventListener('DOMContentLoaded', function() {
        // Main toggle button in header
        const toggleButton = document.getElementById('sidebar-toggle');
        if (toggleButton) {
            toggleButton.addEventListener('click', function(e) {
                e.preventDefault();
                toggleSidebar();
            });
        }

        // Collapse button on sidebar
        const collapseButton = document.getElementById('sidebar-collapse-toggle');
        if (collapseButton) {
            collapseButton.addEventListener('click', function(e) {
                e.preventDefault();
                collapseSidebar();
            });
        }

        // Close sidebar when clicking on nav links on small screens (< 768px)
        const navLinks = document.querySelectorAll('nav a');
        navLinks.forEach(link => {
            link.addEventListener('click', function() {
                if (window.innerWidth < 768) {
                    toggleSidebar();
                }
            });
        });
    });

    // Error handling
    document.addEventListener('blazor:unhandledError', function() {
        document.getElementById('blazor-error-ui').classList.remove('hidden');
    });

    // Close error UI
    function dismissError() {
        document.getElementById('blazor-error-ui').classList.add('hidden');
    }

    // Close error on reload link
    document.querySelector('#blazor-error-ui a')?.addEventListener('click', dismissError);
</script>
