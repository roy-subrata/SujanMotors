@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Initialize submenu functionality if needed
            await Task.CompletedTask;
        }
    }
}

<script>
    function toggleSubmenuHandler(button) {
        // Get the menu ID from the button's data attribute
        const menuId = button.getAttribute('data-toggle');
        const menu = document.getElementById(menuId);
        const arrow = button.querySelector('.submenu-arrow');

        if (!menu) {
            console.error('Menu not found for ID:', menuId);
            return false;
        }

        // Check current display state
        const isHidden = menu.style.display === 'none';

        if (isHidden) {
            // Show menu
            menu.style.display = 'block';
            if (arrow) {
                arrow.style.transform = 'rotate(180deg)';
            }
        } else {
            // Hide menu
            menu.style.display = 'none';
            if (arrow) {
                arrow.style.transform = 'rotate(0deg)';
            }
        }

        return false;
    }

    // Ensure the script is ready
    document.addEventListener('DOMContentLoaded', function() {
        console.log('NavMenu script loaded');
    });
</script>
