@page "/sales"
@rendermode InteractiveServer

<PageTitle>Sales Dashboard - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Sales Dashboard</h1>
            <p class="text-dark-500 mt-1">Monitor sales performance and key metrics</p>
        </div>
        <a href="/orders/create" class="btn-primary flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Create Order
        </a>
    </div>

    <!-- Key Metrics -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Total Sales -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Total Sales</p>
                    <p class="text-2xl font-bold text-dark-900">₹84.5L</p>
                    <p class="text-xs text-green-600 mt-1">↑ 12.5% vs last month</p>
                </div>
                <div class="p-3 bg-primary-100 rounded-lg">
                    <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Orders This Month -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Orders This Month</p>
                    <p class="text-2xl font-bold text-dark-900">42</p>
                    <p class="text-xs text-green-600 mt-1">↑ 8.3% vs last month</p>
                </div>
                <div class="p-3 bg-blue-100 rounded-lg">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Average Order Value -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Avg Order Value</p>
                    <p class="text-2xl font-bold text-dark-900">₹2,011</p>
                    <p class="text-xs text-orange-600 mt-1">↓ 2.1% vs last month</p>
                </div>
                <div class="p-3 bg-orange-100 rounded-lg">
                    <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7H6v10a1 1 0 001 1h10a1 1 0 001-1V9a1 1 0 00-1-1m-6 0V4a1 1 0 011-1h4a1 1 0 011 1v3M9 17v-4"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Conversion Rate -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Conversion Rate</p>
                    <p class="text-2xl font-bold text-dark-900">18.5%</p>
                    <p class="text-xs text-green-600 mt-1">↑ 3.2% vs last month</p>
                </div>
                <div class="p-3 bg-green-100 rounded-lg">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Sales Trend -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Sales Trend (Last 30 Days)</h3>
            <div class="h-64 bg-dark-50 rounded-lg flex items-center justify-center">
                <p class="text-dark-500">Sales chart placeholder - Integration with charting library needed</p>
            </div>
        </div>

        <!-- Top Products -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Top Performing Products</h3>
            <div class="space-y-3">
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <p class="text-sm font-medium text-dark-900">Engine Oil Filter</p>
                        <p class="text-sm font-semibold text-dark-900">₹18,500</p>
                    </div>
                    <div class="w-full bg-dark-200 rounded-full h-2">
                        <div class="bg-primary-600 h-2 rounded-full" style="width: 85%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <p class="text-sm font-medium text-dark-900">Brake Pad Set</p>
                        <p class="text-sm font-semibold text-dark-900">₹16,200</p>
                    </div>
                    <div class="w-full bg-dark-200 rounded-full h-2">
                        <div class="bg-primary-600 h-2 rounded-full" style="width: 74%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <p class="text-sm font-medium text-dark-900">Air Filter</p>
                        <p class="text-sm font-semibold text-dark-900">₹12,800</p>
                    </div>
                    <div class="w-full bg-dark-200 rounded-full h-2">
                        <div class="bg-primary-600 h-2 rounded-full" style="width: 58%"></div>
                    </div>
                </div>
                <div>
                    <div class="flex items-center justify-between mb-2">
                        <p class="text-sm font-medium text-dark-900">Spark Plugs</p>
                        <p class="text-sm font-semibold text-dark-900">₹10,500</p>
                    </div>
                    <div class="w-full bg-dark-200 rounded-full h-2">
                        <div class="bg-primary-600 h-2 rounded-full" style="width: 48%"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Sales by Customer -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-6">Sales by Customer (Top 10)</h3>
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-dark-200 bg-dark-50">
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Customer</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Orders</th>
                        <th class="text-right py-3 px-4 font-semibold text-dark-900">Total Sales</th>
                        <th class="text-right py-3 px-4 font-semibold text-dark-900">% of Total</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-dark-200">
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Sharma Auto Parts</td>
                        <td class="text-center py-4 px-4 text-dark-700">12</td>
                        <td class="text-right py-4 px-4 text-dark-900 font-semibold">₹15,800</td>
                        <td class="text-right py-4 px-4"><span class="badge-success">18.7%</span></td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Tech Engine Solutions</td>
                        <td class="text-center py-4 px-4 text-dark-700">10</td>
                        <td class="text-right py-4 px-4 text-dark-900 font-semibold">₹14,200</td>
                        <td class="text-right py-4 px-4"><span class="badge-success">16.8%</span></td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Drive Forward Ltd</td>
                        <td class="text-center py-4 px-4 text-dark-700">8</td>
                        <td class="text-right py-4 px-4 text-dark-900 font-semibold">₹11,500</td>
                        <td class="text-right py-4 px-4"><span class="badge-info">13.6%</span></td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Mechanic's Hub</td>
                        <td class="text-center py-4 px-4 text-dark-700">7</td>
                        <td class="text-right py-4 px-4 text-dark-900 font-semibold">₹9,800</td>
                        <td class="text-right py-4 px-4"><span class="badge-info">11.6%</span></td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Auto Fix Station</td>
                        <td class="text-center py-4 px-4 text-dark-700">5</td>
                        <td class="text-right py-4 px-4 text-dark-900 font-semibold">₹7,600</td>
                        <td class="text-right py-4 px-4"><span class="badge-warning">9.0%</span></td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Vehicle Care Pro</td>
                        <td class="text-center py-4 px-4 text-dark-700">4</td>
                        <td class="text-right py-4 px-4 text-dark-900 font-semibold">₹5,200</td>
                        <td class="text-right py-4 px-4"><span class="badge-warning">6.2%</span></td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Speed Garage</td>
                        <td class="text-center py-4 px-4 text-dark-700">3</td>
                        <td class="text-right py-4 px-4 text-dark-900 font-semibold">₹4,800</td>
                        <td class="text-right py-4 px-4"><span class="badge-warning">5.7%</span></td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Parts & Service</td>
                        <td class="text-center py-4 px-4 text-dark-700">2</td>
                        <td class="text-right py-4 px-4 text-dark-900 font-semibold">₹3,400</td>
                        <td class="text-right py-4 px-4"><span class="badge-warning">4.0%</span></td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Elite Motors</td>
                        <td class="text-center py-4 px-4 text-dark-700">2</td>
                        <td class="text-right py-4 px-4 text-dark-900 font-semibold">₹3,100</td>
                        <td class="text-right py-4 px-4"><span class="badge-warning">3.7%</span></td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Supreme Auto</td>
                        <td class="text-center py-4 px-4 text-dark-700">1</td>
                        <td class="text-right py-4 px-4 text-dark-900 font-semibold">₹2,300</td>
                        <td class="text-right py-4 px-4"><span class="badge-warning">2.7%</span></td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Load sales dashboard data
    }
}
