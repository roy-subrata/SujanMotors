@page "/invoices/create"

<PageTitle>Generate Invoice - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Generate Invoice</h1>
            <p class="text-dark-500 mt-1">Create a new invoice from order</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/invoices" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </a>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Generate Invoice
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Invoice Summary -->
            <div class="card bg-blue-50 border-l-4 border-blue-500">
                <h3 class="text-lg font-bold text-blue-900 mb-4">Invoice Summary</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <p class="text-blue-800">Subtotal</p>
                        <p class="font-semibold text-blue-900">₹10,500</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Tax (18%)</p>
                        <p class="font-semibold text-blue-900">₹1,890</p>
                    </div>
                    <div className="border-t border-blue-200 pt-2 mt-2 flex justify-between">
                        <p className="font-semibold text-blue-900">Total Invoice</p>
                        <p className="text-lg font-bold text-blue-600">₹12,390</p>
                    </div>
                </div>
            </div>

            <!-- Quick Info -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Quick Info</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Auto-generated Invoice ID</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Select from existing order</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Customize terms and dates</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Order Selection Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Select Order</h3>

                <div class="grid grid-cols-1 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Order *</label>
                        <select class="input-field">
                            <option selected>Select Order</option>
                            <option>ORD-2024-152 - Sharma Auto Parts - ₹45,000</option>
                            <option>ORD-2024-151 - Tech Engine Solutions - ₹89,500</option>
                            <option>ORD-2024-150 - Drive Forward Ltd - ₹52,300</option>
                            <option>ORD-2024-149 - Mechanic's Hub - ₹34,700</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Invoice Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Invoice Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Invoice Date *</label>
                        <input type="date" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Due Date *</label>
                        <input type="date" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Terms (Days)</label>
                        <input type="number" placeholder="30" value="30" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Invoice Status</label>
                        <select class="input-field">
                            <option selected>Draft</option>
                            <option>Ready to Send</option>
                            <option>Sent</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Invoice Items Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Invoice Items</h3>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Part Name</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">SKU</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Unit Price</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Qty</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Amount</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">Engine Oil Filter</td>
                                <td class="py-4 px-4 text-dark-700">EOF-001</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹450</td>
                                <td class="text-center py-4 px-4"><input type="number" min="1" value="10" class="w-16 px-2 py-1 border border-dark-200 rounded text-center" /></td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹4,500</td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 font-medium text-xs">Remove</button>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">Brake Pad Set</td>
                                <td class="py-4 px-4 text-dark-700">BPS-002</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹1,200</td>
                                <td class="text-center py-4 px-4"><input type="number" min="1" value="5" class="w-16 px-2 py-1 border border-dark-200 rounded text-center" /></td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹6,000</td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 font-medium text-xs">Remove</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Terms & Notes Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Terms & Notes</h3>

                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Terms & Conditions</label>
                        <textarea rows="3" class="input-field" placeholder="Add payment terms...">Payment due within 30 days of invoice date. 2% discount if paid within 10 days.</textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Special Notes (Optional)</label>
                        <textarea rows="2" class="input-field" placeholder="Add any special notes or instructions..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <a href="/invoices" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </a>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Generate Invoice
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Initialize create invoice form
    }
}
