@page "/invoices/{id}/edit"

<PageTitle>Edit Invoice - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Edit Invoice</h1>
            <p class="text-dark-500 mt-1">INV-2024-127 • Sharma Auto Parts</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/invoices" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </a>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Invoice Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Invoice Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-success">Paid</span>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Change Status</label>
                        <select class="input-field">
                            <option selected>Paid</option>
                            <option>Draft</option>
                            <option>Sent</option>
                            <option>Viewed</option>
                            <option>Partially Paid</option>
                            <option>Overdue</option>
                            <option>Cancelled</option>
                        </select>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Invoice ID</p>
                        <p class="text-dark-900 font-semibold">INV-2024-127</p>
                    </div>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="card bg-red-50 border-l-4 border-red-500">
                <h3 class="text-lg font-bold text-red-900 mb-4">Danger Zone</h3>
                <button class="w-full btn-danger flex items-center justify-center text-sm border border-red-300 bg-red-100 text-red-700 hover:bg-red-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Delete This Invoice
                </button>
                <p class="text-xs text-red-700 mt-2">This action cannot be undone. This will permanently delete the invoice.</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Invoice Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Invoice Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Invoice Date *</label>
                        <input type="date" value="2024-12-20" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Due Date *</label>
                        <input type="date" value="2024-12-27" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Customer</label>
                        <input type="text" value="Sharma Auto Parts" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Order Reference</label>
                        <input type="text" value="ORD-2024-152" class="input-field" />
                    </div>
                </div>
            </div>

            <!-- Invoice Items Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Invoice Items</h3>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Part Name</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">SKU</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Unit Price</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Qty</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Amount</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">Engine Oil Filter</td>
                                <td class="py-4 px-4 text-dark-700">EOF-001</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹450</td>
                                <td class="text-center py-4 px-4"><input type="number" min="1" value="10" class="w-16 px-2 py-1 border border-dark-200 rounded text-center" /></td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹4,500</td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 font-medium text-xs">Remove</button>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">Brake Pad Set</td>
                                <td class="py-4 px-4 text-dark-700">BPS-002</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹1,200</td>
                                <td class="text-center py-4 px-4"><input type="number" min="1" value="5" class="w-16 px-2 py-1 border border-dark-200 rounded text-center" /></td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹6,000</td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 font-medium text-xs">Remove</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <button class="btn-secondary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Add Item
                </button>
            </div>

            <!-- Tax & Totals Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Tax & Totals</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Subtotal</label>
                        <input type="number" value="10500" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Tax Rate (%)</label>
                        <input type="number" value="18" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Tax Amount</label>
                        <input type="number" value="1890" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Total Amount</label>
                        <input type="number" value="12390" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Discount</label>
                        <input type="number" placeholder="0" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Final Amount Due</label>
                        <input type="number" value="12390" class="input-field" />
                    </div>
                </div>
            </div>

            <!-- Payment Terms Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Terms & Notes</h3>

                <div class="space-y-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Terms & Conditions</label>
                        <textarea rows="3" class="input-field">Payment due within 30 days of invoice date. 2% discount if paid within 10 days.</textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Special Notes (Optional)</label>
                        <textarea rows="2" class="input-field" placeholder="Add any special notes or instructions..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <a href="/invoices" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </a>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load invoice data for editing
    }
}
