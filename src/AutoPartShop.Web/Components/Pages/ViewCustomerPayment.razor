@page "/customer-payments/{id}/view"
@rendermode InteractiveServer

<PageTitle>View Customer Payment - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Payment Receipt</h1>
            <p class="text-dark-500 mt-1">CPAY-2024-044 • Tech Engine Solutions • Dec 16, 2024</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/customer-payments" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Back
            </a>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                </svg>
                Download Receipt
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Payment Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Payment Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Status</p>
                        <span class="badge-success">Received</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Payment ID</p>
                        <p class="text-dark-900 font-semibold">CPAY-2024-044</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Payment Date</p>
                        <p class="text-dark-900 font-semibold">Dec 16, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Payment Method</p>
                        <span class="badge-warning">Check</span>
                    </div>
                </div>
            </div>

            <!-- Payment Summary -->
            <div class="card bg-green-50 border-l-4 border-green-500">
                <h3 class="text-lg font-bold text-green-900 mb-3">Payment Summary</h3>
                <div class="space-y-2 text-sm">
                    <div class="flex items-center justify-between">
                        <p class="text-green-800">Invoices Paid</p>
                        <p class="font-semibold text-green-900">1</p>
                    </div>
                    <div class="flex items-center justify-between">
                        <p class="text-green-800">Amount Received</p>
                        <p class="font-semibold text-green-900">₹75,500</p>
                    </div>
                    <div className="border-t border-green-200 pt-2 mt-2 flex items-center justify-between">
                        <p className="font-semibold text-green-900">Total Received</p>
                        <p className="text-lg font-bold text-green-600">₹75,500</p>
                    </div>
                </div>
            </div>

            <!-- Customer Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Customer Details</h3>
                <div class="space-y-3 text-sm">
                    <div>
                        <p class="text-dark-500 font-medium mb-1">Customer Name</p>
                        <p class="text-dark-900 font-semibold">Tech Engine Solutions</p>
                    </div>
                    <div>
                        <p class="text-dark-500 font-medium mb-1">Contact Person</p>
                        <p class="text-dark-900 font-semibold">Vikram Patel</p>
                    </div>
                    <div>
                        <p class="text-dark-500 font-medium mb-1">Email</p>
                        <p class="text-dark-900 font-semibold">vikram@techengine.com</p>
                    </div>
                    <div>
                        <p class="text-dark-500 font-medium mb-1">Phone</p>
                        <p class="text-dark-900 font-semibold">+91 98765 54321</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Payment Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Information</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Payment ID</p>
                        <p class="text-dark-900 font-semibold">CPAY-2024-044</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Customer</p>
                        <p class="text-dark-900 font-semibold">Tech Engine Solutions</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Payment Amount</p>
                        <p class="text-dark-900 font-semibold">₹75,500</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Payment Date</p>
                        <p class="text-dark-900 font-semibold">Dec 16, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Payment Method</p>
                        <p class="text-dark-900 font-semibold">Check</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Check Number</p>
                        <p class="text-dark-900 font-semibold">CHK-001234</p>
                    </div>

                    <div class="md:col-span-2">
                        <p class="text-sm text-dark-500 font-medium mb-1">Reference ID</p>
                        <p class="text-dark-900 font-semibold">REF-2024-044-001</p>
                    </div>
                </div>
            </div>

            <!-- Paid Invoices -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Paid Invoices</h3>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Invoice #</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Order #</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Invoice Amount</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Amount Paid</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Due Date</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 text-dark-900 font-semibold">INV-2024-087</td>
                                <td class="py-4 px-4 text-dark-700">ORD-2024-043</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹75,500</td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹75,500</td>
                                <td class="py-4 px-4 text-dark-700">Dec 16, 2024</td>
                                <td class="text-center py-4 px-4"><span class="badge-success">Paid</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Payment Method Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Method Details</h3>

                <div className="bg-dark-50 rounded-lg p-4 space-y-4">
                    <div>
                        <p className="text-xs text-dark-500 font-medium">Payment Method</p>
                        <p className="text-sm font-semibold text-dark-900">Check</p>
                    </div>
                    <div>
                        <p className="text-xs text-dark-500 font-medium">Check Number</p>
                        <p className="text-sm font-semibold text-dark-900">CHK-001234</p>
                    </div>
                    <div>
                        <p className="text-xs text-dark-500 font-medium">Bank Name</p>
                        <p className="text-sm font-semibold text-dark-900">State Bank of India</p>
                    </div>
                    <div>
                        <p className="text-xs text-dark-500 font-medium">Reference ID</p>
                        <p className="text-sm font-semibold text-dark-900">REF-2024-044-001</p>
                    </div>
                </div>
            </div>

            <!-- Payment Timeline -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Timeline</h3>

                <div className="space-y-4">
                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                            <div className="w-0.5 h-12 bg-dark-200 mt-2"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Payment Initiated</p>
                            <p className="text-sm text-dark-500">Dec 16, 2024 09:15 AM</p>
                        </div>
                    </div>

                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                            <div className="w-0.5 h-12 bg-dark-200 mt-2"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Received & Verified</p>
                            <p className="text-sm text-dark-500">Dec 16, 2024 11:30 AM</p>
                        </div>
                    </div>

                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Payment Confirmed</p>
                            <p className="text-sm text-dark-500">Dec 16, 2024 02:45 PM</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Notes -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Payment Notes</h3>
                <p class="text-dark-700">Check received for invoice INV-2024-087. Check cleared successfully on Dec 17, 2024. Reference maintained for reconciliation.</p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load payment details
    }
}
