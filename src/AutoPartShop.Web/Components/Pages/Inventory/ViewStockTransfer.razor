@page "/inventory/warehouse-transfers/{id}/view"
@rendermode InteractiveServer

<PageTitle>Stock Transfer Details - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Stock Transfer Details</h1>
            <p class="text-dark-500 mt-1">TRF-2024-001 | Main Warehouse → South Regional Hub</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/inventory/warehouse-transfers" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Back to Transfers
            </a>
            <a href="/inventory/warehouse-transfers/TRF-2024-001/edit" class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Edit Transfer
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Transfer Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Transfer Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-info">In Transit</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Transfer ID</p>
                        <p class="text-dark-900 font-semibold">TRF-2024-001</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Priority</p>
                        <span class="badge-warning">Normal</span>
                    </div>
                </div>
            </div>

            <!-- Key Dates -->
            <div class="card bg-blue-50 border-l-4 border-blue-500">
                <h3 class="text-lg font-bold text-blue-900 mb-4">Key Dates</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <p class="text-blue-800">Transfer Date</p>
                        <p class="font-semibold text-blue-900">Nov 15, 2024</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Expected Delivery</p>
                        <p class="font-semibold text-blue-900">Nov 18, 2024</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Days in Transit</p>
                        <p class="font-semibold text-blue-900">3 days</p>
                    </div>
                </div>
            </div>

            <!-- Shipping Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Shipping Details</h3>
                <div class="space-y-3 text-sm">
                    <div>
                        <p class="text-dark-500 font-medium">Method</p>
                        <p class="text-dark-900">Road Transport</p>
                    </div>
                    <div>
                        <p class="text-dark-500 font-medium">Driver</p>
                        <p class="text-dark-900">Rajesh Sharma</p>
                    </div>
                    <div>
                        <p class="text-dark-500 font-medium">Contact</p>
                        <p class="text-dark-900">+91 9876543210</p>
                    </div>
                    <div>
                        <p class="text-dark-500 font-medium">Tracking #</p>
                        <p class="text-dark-900 font-mono">TRACK-2024-001</p>
                    </div>
                    <div>
                        <p class="text-dark-500 font-medium">Vehicle</p>
                        <p class="text-dark-900">DL-01-AB-1234</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Warehouse Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Warehouse Information</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <!-- From Warehouse -->
                    <div class="p-4 bg-dark-50 rounded-lg">
                        <h4 class="font-semibold text-dark-900 mb-3">From Warehouse</h4>
                        <div class="space-y-2 text-sm">
                            <div>
                                <p class="text-dark-500">Name</p>
                                <p class="text-dark-900 font-semibold">Main Warehouse</p>
                            </div>
                            <div>
                                <p class="text-dark-500">Code</p>
                                <p class="text-dark-900">WH-001</p>
                            </div>
                            <div>
                                <p class="text-dark-500">Region</p>
                                <p class="text-dark-900">North</p>
                            </div>
                            <div>
                                <p class="text-dark-500">Location</p>
                                <p class="text-dark-900">New Delhi</p>
                            </div>
                        </div>
                    </div>

                    <!-- To Warehouse -->
                    <div class="p-4 bg-dark-50 rounded-lg">
                        <h4 class="font-semibold text-dark-900 mb-3">To Warehouse</h4>
                        <div class="space-y-2 text-sm">
                            <div>
                                <p class="text-dark-500">Name</p>
                                <p class="text-dark-900 font-semibold">South Regional Hub</p>
                            </div>
                            <div>
                                <p class="text-dark-500">Code</p>
                                <p class="text-dark-900">WH-002</p>
                            </div>
                            <div>
                                <p class="text-dark-500">Region</p>
                                <p class="text-dark-900">South</p>
                            </div>
                            <div>
                                <p class="text-dark-500">Location</p>
                                <p class="text-dark-900">Chennai</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Transferred Items -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Transferred Items</h3>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">SKU</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Product Name</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Quantity</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Unit</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Unit Value</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Total Value</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">ENG-2401</td>
                                <td class="py-4 px-4 text-dark-700">Engine Oil Filter (Premium)</td>
                                <td class="text-right py-4 px-4 text-dark-700">200 units</td>
                                <td class="text-center py-4 px-4 text-dark-700">pcs</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹450</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹90,000</td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">BRK-0850</td>
                                <td class="py-4 px-4 text-dark-700">Brake Pad Set (Ceramic)</td>
                                <td class="text-right py-4 px-4 text-dark-700">150 units</td>
                                <td class="text-center py-4 px-4 text-dark-700">pcs</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹1,200</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹1,80,000</td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">SUS-1205</td>
                                <td class="py-4 px-4 text-dark-700">Shock Absorber Assembly</td>
                                <td class="text-right py-4 px-4 text-dark-700">120 units</td>
                                <td class="text-center py-4 px-4 text-dark-700">pcs</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹3,500</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹4,20,000</td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 p-4 bg-primary-50 rounded-lg border border-primary-200">
                    <div class="flex justify-between items-center">
                        <p class="font-semibold text-dark-900">Total Transfer Value:</p>
                        <p class="text-2xl font-bold text-primary-600">₹6,90,000</p>
                    </div>
                </div>
            </div>

            <!-- Transfer Timeline -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Transfer Timeline</h3>

                <div class="space-y-4">
                    <!-- Created -->
                    <div class="flex gap-4">
                        <div class="flex flex-col items-center">
                            <div class="w-4 h-4 bg-primary-600 rounded-full"></div>
                            <div class="w-0.5 h-12 bg-dark-200 mt-2"></div>
                        </div>
                        <div class="pb-4">
                            <p class="font-semibold text-dark-900">Transfer Created</p>
                            <p class="text-sm text-dark-500">Nov 15, 2024 at 10:30 AM</p>
                            <p class="text-sm text-dark-600 mt-1">Created by: Rajesh Kumar (Warehouse Manager)</p>
                        </div>
                    </div>

                    <!-- In Transit -->
                    <div class="flex gap-4">
                        <div class="flex flex-col items-center">
                            <div class="w-4 h-4 bg-primary-600 rounded-full"></div>
                            <div class="w-0.5 h-12 bg-dark-200 mt-2"></div>
                        </div>
                        <div class="pb-4">
                            <p class="font-semibold text-dark-900">Shipment In Transit</p>
                            <p class="text-sm text-dark-500">Nov 16, 2024 at 02:15 PM</p>
                            <p class="text-sm text-dark-600 mt-1">Driver: Rajesh Sharma | Vehicle: DL-01-AB-1234</p>
                        </div>
                    </div>

                    <!-- Expected Delivery -->
                    <div class="flex gap-4">
                        <div class="flex flex-col items-center">
                            <div class="w-4 h-4 bg-dark-300 rounded-full"></div>
                        </div>
                        <div>
                            <p class="font-semibold text-dark-900">Expected Delivery</p>
                            <p class="text-sm text-dark-500">Nov 18, 2024 (Expected)</p>
                            <p class="text-sm text-dark-600 mt-1">Awaiting delivery confirmation</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Additional Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Additional Information</h3>

                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Special Instructions</p>
                        <p class="text-dark-900">Handle with care - Premium parts. Ensure temperature controlled storage. Confirm receipt within 24 hours.</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Internal Notes</p>
                        <p class="text-dark-900">Urgent restock for South region due to high demand. Prioritize delivery to WH-002.</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Estimated Cost</p>
                        <p class="text-dark-900">₹8,500 (Shipping & Handling)</p>
                    </div>
                </div>
            </div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <a href="/inventory/warehouse-transfers" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                    </svg>
                    Back to Transfers
                </a>
                <a href="/inventory/warehouse-transfers/TRF-2024-001/edit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                    </svg>
                    Edit Transfer
                </a>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load transfer details
    }
}
