@page "/inventory/stock-movement"
@rendermode InteractiveServer

<PageTitle>Stock Movement History - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Stock Movement History</h1>
            <p class="text-dark-500 mt-1">Track all inventory movements and changes</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                </svg>
                Print
            </button>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export
            </button>
        </div>
    </div>

    <!-- Filters Card -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Search Parts</label>
                <input type="text" placeholder="Filter by name or SKU..." class="input-field" />
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Movement Type</label>
                <select class="input-field">
                    <option>All Types</option>
                    <option>Add Stock</option>
                    <option>Remove Stock</option>
                    <option>Adjustment</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Date Range</label>
                <select class="input-field">
                    <option>Last 7 Days</option>
                    <option>Last 30 Days</option>
                    <option>Last 3 Months</option>
                    <option>Last Year</option>
                    <option>Custom Range</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">User</label>
                <select class="input-field">
                    <option>All Users</option>
                    <option>Admin User</option>
                    <option>Warehouse Staff</option>
                    <option>System</option>
                </select>
            </div>
            <div class="flex items-end">
                <button class="btn-primary w-full">Apply Filters</button>
            </div>
        </div>
    </div>

    <!-- Stock Movement Timeline -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-6">Movement Timeline</h3>

        <div class="space-y-4">
            <!-- Movement 1 -->
            <div class="flex gap-4">
                <div class="flex flex-col items-center">
                    <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                    </div>
                    <div class="w-0.5 h-20 bg-dark-200 mt-2"></div>
                </div>
                <div class="flex-1 pt-1">
                    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                        <div class="flex items-center justify-between mb-2">
                            <p class="font-semibold text-dark-900">Engine Oil Filter - +50 units</p>
                            <span class="badge-success">Add</span>
                        </div>
                        <p class="text-sm text-dark-600">Purchase Order Received - PO-2024-123</p>
                        <div className="grid grid-cols-2 gap-4 mt-3">
                            <div>
                                <p class="text-xs text-dark-500">Previous Stock</p>
                                <p class="font-semibold text-dark-900">195 units</p>
                            </div>
                            <div>
                                <p class="text-xs text-dark-500">New Stock</p>
                                <p class="font-semibold text-dark-900">245 units</p>
                            </div>
                        </div>
                        <p class="text-xs text-dark-400 mt-3">Nov 15, 2024 10:30 AM • By Admin User</p>
                    </div>
                </div>
            </div>

            <!-- Movement 2 -->
            <div class="flex gap-4">
                <div class="flex flex-col items-center">
                    <div class="w-10 h-10 bg-red-100 rounded-full flex items-center justify-center">
                        <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 12H4"></path>
                        </svg>
                    </div>
                    <div class="w-0.5 h-20 bg-dark-200 mt-2"></div>
                </div>
                <div class="flex-1 pt-1">
                    <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                        <div class="flex items-center justify-between mb-2">
                            <p class="font-semibold text-dark-900">Brake Pads Set - -25 units</p>
                            <span class="badge-danger">Remove</span>
                        </div>
                        <p class="text-sm text-dark-600">Damaged/Defective - Quality issue detected during inspection</p>
                        <div className="grid grid-cols-2 gap-4 mt-3">
                            <div>
                                <p class="text-xs text-dark-500">Previous Stock</p>
                                <p class="font-semibold text-dark-900">37 units</p>
                            </div>
                            <div>
                                <p class="text-xs text-dark-500">New Stock</p>
                                <p class="font-semibold text-dark-900">12 units</p>
                            </div>
                        </div>
                        <p class="text-xs text-dark-400 mt-3">Nov 12, 2024 2:15 PM • By Warehouse Staff</p>
                    </div>
                </div>
            </div>

            <!-- Movement 3 -->
            <div class="flex gap-4">
                <div class="flex flex-col items-center">
                    <div class="w-10 h-10 bg-orange-100 rounded-full flex items-center justify-center">
                        <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12M8 11h12m-12 4h12M3 7a2 2 0 100-4 2 2 0 000 4z"></path>
                        </svg>
                    </div>
                    <div class="w-0.5 h-20 bg-dark-200 mt-2"></div>
                </div>
                <div class="flex-1 pt-1">
                    <div class="bg-orange-50 border border-orange-200 rounded-lg p-4">
                        <div class="flex items-center justify-between mb-2">
                            <p class="font-semibold text-dark-900">Air Filter - -10 units</p>
                            <span class="badge-warning">Adjustment</span>
                        </div>
                        <p class="text-sm text-dark-600">Inventory Correction - Physical count mismatch</p>
                        <div className="grid grid-cols-2 gap-4 mt-3">
                            <div>
                                <p class="text-xs text-dark-500">Previous Stock</p>
                                <p class="font-semibold text-dark-900">166 units</p>
                            </div>
                            <div>
                                <p class="text-xs text-dark-500">New Stock</p>
                                <p class="font-semibold text-dark-900">156 units</p>
                            </div>
                        </div>
                        <p class="text-xs text-dark-400 mt-3">Nov 10, 2024 9:45 AM • By Admin User</p>
                    </div>
                </div>
            </div>

            <!-- Movement 4 -->
            <div class="flex gap-4">
                <div class="flex flex-col items-center">
                    <div class="w-10 h-10 bg-green-100 rounded-full flex items-center justify-center">
                        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                    </div>
                    <div class="w-0.5 h-20 bg-dark-200 mt-2"></div>
                </div>
                <div class="flex-1 pt-1">
                    <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                        <div class="flex items-center justify-between mb-2">
                            <p class="font-semibold text-dark-900">Engine Oil Filter - +100 units</p>
                            <span class="badge-success">Add</span>
                        </div>
                        <p class="text-sm text-dark-600">Purchase Order Received - PO-2024-098</p>
                        <div className="grid grid-cols-2 gap-4 mt-3">
                            <div>
                                <p class="text-xs text-dark-500">Previous Stock</p>
                                <p class="font-semibold text-dark-900">95 units</p>
                            </div>
                            <div>
                                <p class="text-xs text-dark-500">New Stock</p>
                                <p class="font-semibold text-dark-900">195 units</p>
                            </div>
                        </div>
                        <p class="text-xs text-dark-400 mt-3">Nov 5, 2024 11:20 AM • By Admin User</p>
                    </div>
                </div>
            </div>

            <!-- Movement 5 -->
            <div class="flex gap-4">
                <div class="flex flex-col items-center">
                    <div class="w-10 h-10 bg-blue-100 rounded-full flex items-center justify-center">
                        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 10l-2 1m0 0l-2-1m2 1v2.5M20 7l-2 1m2-1l-2-1m2 1v2.5M14 4l-2-1-2 1m2-1v2.5M4 7l2 1M4 7l2-1m-2 1v2.5"></path>
                        </svg>
                    </div>
                </div>
                <div class="flex-1 pt-1">
                    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
                        <div class="flex items-center justify-between mb-2">
                            <p class="font-semibold text-dark-900">Transmission Fluid - +50 units</p>
                            <span class="badge-primary">Transfer</span>
                        </div>
                        <p class="text-sm text-dark-600">Transfer In - From Main Warehouse</p>
                        <div className="grid grid-cols-2 gap-4 mt-3">
                            <div>
                                <p class="text-xs text-dark-500">Previous Stock</p>
                                <p class="font-semibold text-dark-900">75 units</p>
                            </div>
                            <div>
                                <p class="text-xs text-dark-500">New Stock</p>
                                <p class="font-semibold text-dark-900">125 units</p>
                            </div>
                        </div>
                        <p class="text-xs text-dark-400 mt-3">Oct 28, 2024 3:30 PM • By System</p>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Movement Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="card-sm border-l-4 border-green-500">
            <h4 class="font-semibold text-dark-900 mb-3">Total Added</h4>
            <p class="text-3xl font-bold text-green-600">+200</p>
            <p class="text-dark-500 text-xs mt-2">Units added (Last 30 days)</p>
        </div>

        <div class="card-sm border-l-4 border-red-500">
            <h4 class="font-semibold text-dark-900 mb-3">Total Removed</h4>
            <p class="text-3xl font-bold text-red-600">-85</p>
            <p class="text-dark-500 text-xs mt-2">Units removed (Last 30 days)</p>
        </div>

        <div class="card-sm border-l-4 border-blue-500">
            <h4 class="font-semibold text-dark-900 mb-3">Net Change</h4>
            <p class="text-3xl font-bold text-blue-600">+115</p>
            <p class="text-dark-500 text-xs mt-2">Net inventory change</p>
        </div>

        <div class="card-sm border-l-4 border-orange-500">
            <h4 class="font-semibold text-dark-900 mb-3">Transactions</h4>
            <p class="text-3xl font-bold text-orange-600">847</p>
            <p class="text-dark-500 text-xs mt-2">Total movements recorded</p>
        </div>
    </div>
</div>
