@page "/inventory/warehouses/{id}/edit"

<PageTitle>Edit Warehouse - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Edit Warehouse</h1>
            <p class="text-dark-500 mt-1">Main Warehouse (WH-001)</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/inventory/warehouses" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </a>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Warehouse Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Warehouse Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-success">Active</span>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Change Status</label>
                        <select class="input-field">
                            <option selected>Active</option>
                            <option>Inactive</option>
                            <option>Maintenance</option>
                        </select>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Region</p>
                        <p class="text-dark-900 font-semibold">North</p>
                    </div>
                </div>
            </div>

            <!-- Storage Statistics -->
            <div class="card bg-blue-50 border-l-4 border-blue-500">
                <h3 class="text-lg font-bold text-blue-900 mb-4">Storage Statistics</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <p class="text-blue-800">Total Capacity</p>
                        <p class="font-semibold text-blue-900">15,000 units</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Current Stock</p>
                        <p class="font-semibold text-blue-900">11,250 units</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Available Space</p>
                        <p class="font-semibold text-blue-900">3,750 units</p>
                    </div>
                    <div class="mt-3 pt-3 border-t border-blue-200">
                        <div class="flex justify-between mb-2">
                            <p class="text-blue-800 font-medium">Capacity Used</p>
                            <p class="font-semibold text-blue-900">75%</p>
                        </div>
                        <div class="w-full bg-blue-200 rounded-full h-2">
                            <div class="bg-blue-600 h-2 rounded-full" style="width: 75%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Inventory Value -->
            <div class="card bg-green-50 border-l-4 border-green-500">
                <h3 class="text-lg font-bold text-green-900 mb-4">Inventory Value</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <p class="text-green-800">Total SKUs</p>
                        <p class="font-semibold text-green-900">2,847</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-green-800">Stock Value</p>
                        <p class="font-semibold text-green-900">₹52.3L</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-green-800">Avg. Item Value</p>
                        <p class="font-semibold text-green-900">₹1,835</p>
                    </div>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="card bg-red-50 border-l-4 border-red-500">
                <h3 class="text-lg font-bold text-red-900 mb-4">Danger Zone</h3>
                <button class="w-full btn-danger flex items-center justify-center text-sm border border-red-300 bg-red-100 text-red-700 hover:bg-red-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Delete This Warehouse
                </button>
                <p class="text-xs text-red-700 mt-2">Cannot delete if warehouse has active stock</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Basic Information Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Basic Information</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Warehouse Name *</label>
                        <input type="text" value="Main Warehouse" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Warehouse Code *</label>
                        <input type="text" value="WH-001" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Region *</label>
                        <select class="input-field">
                            <option selected>North</option>
                            <option>South</option>
                            <option>East</option>
                            <option>West</option>
                            <option>Central</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                        <select class="input-field">
                            <option selected>Active</option>
                            <option>Inactive</option>
                            <option>Maintenance</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Location Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Location Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">City *</label>
                        <input type="text" value="New Delhi" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">State/Province *</label>
                        <input type="text" value="Delhi" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Postal Code</label>
                        <input type="text" value="110001" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Country *</label>
                        <input type="text" value="India" class="input-field" />
                    </div>
                </div>

                <div class="mt-6">
                    <label class="block text-sm font-medium text-dark-900 mb-2">Full Address *</label>
                    <textarea rows="3" class="input-field">Plot 45, Industrial Area, DSIDC, Delhi 110001</textarea>
                </div>
            </div>

            <!-- Warehouse Manager Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Warehouse Manager</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Manager Name *</label>
                        <input type="text" value="Rajesh Kumar" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Contact Email</label>
                        <input type="email" value="rajesh.kumar@company.com" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Phone Number *</label>
                        <input type="tel" value="+91 9876543210" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Mobile Number</label>
                        <input type="tel" value="+91 9876543210" class="input-field" />
                    </div>
                </div>
            </div>

            <!-- Capacity & Operations Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Capacity & Operations</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Total Capacity (Units) *</label>
                        <input type="number" value="15000" class="input-field" />
                        <p class="text-sm text-dark-500 mt-2">Maximum storage units this warehouse can hold</p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Reorder Level *</label>
                        <input type="number" value="2000" class="input-field" />
                        <p class="text-sm text-dark-500 mt-2">Alert threshold for stock replenishment</p>
                    </div>
                </div>

                <div class="mt-6">
                    <label class="block text-sm font-medium text-dark-900 mb-2">Operating Hours</label>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div>
                            <label class="block text-sm font-medium text-dark-600 mb-2">Opening Time</label>
                            <input type="time" value="06:00" class="input-field" />
                        </div>
                        <div>
                            <label class="block text-sm font-medium text-dark-600 mb-2">Closing Time</label>
                            <input type="time" value="22:00" class="input-field" />
                        </div>
                    </div>
                </div>
            </div>

            <!-- Special Features Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Special Features</h3>

                <div class="space-y-3">
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-dark-300 text-primary-600" checked />
                        <span class="ml-3 text-dark-900">Temperature Controlled Storage</span>
                    </label>
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-dark-300 text-primary-600" checked />
                        <span class="ml-3 text-dark-900">Security Cameras</span>
                    </label>
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-dark-300 text-primary-600" checked />
                        <span class="ml-3 text-dark-900">Fire Suppression System</span>
                    </label>
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-dark-300 text-primary-600" checked />
                        <span class="ml-3 text-dark-900">RFID Tracking System</span>
                    </label>
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-dark-300 text-primary-600" checked />
                        <span class="ml-3 text-dark-900">Enable Stock Alerts</span>
                    </label>
                </div>
            </div>

            <!-- Stock Distribution Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Stock Distribution by Category</h3>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Category</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Item Count</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Stock Value</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Percentage</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 text-dark-900">Engine & Engine Parts</td>
                                <td class="text-right py-4 px-4 text-dark-700">1,242</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹18.5L</td>
                                <td class="text-center py-4 px-4">
                                    <div class="w-full bg-dark-200 rounded-full h-2">
                                        <div class="bg-primary-600 h-2 rounded-full" style="width: 35%"></div>
                                    </div>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 text-dark-900">Suspension & Brakes</td>
                                <td class="text-right py-4 px-4 text-dark-700">856</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹14.2L</td>
                                <td class="text-center py-4 px-4">
                                    <div class="w-full bg-dark-200 rounded-full h-2">
                                        <div class="bg-primary-600 h-2 rounded-full" style="width: 27%"></div>
                                    </div>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 text-dark-900">Electrical Components</td>
                                <td class="text-right py-4 px-4 text-dark-700">523</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹9.8L</td>
                                <td class="text-center py-4 px-4">
                                    <div class="w-full bg-dark-200 rounded-full h-2">
                                        <div class="bg-primary-600 h-2 rounded-full" style="width: 19%"></div>
                                    </div>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 text-dark-900">Body & Exterior</td>
                                <td class="text-right py-4 px-4 text-dark-700">226</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹9.8L</td>
                                <td class="text-center py-4 px-4">
                                    <div class="w-full bg-dark-200 rounded-full h-2">
                                        <div class="bg-primary-600 h-2 rounded-full" style="width: 19%"></div>
                                    </div>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <a href="/inventory/warehouses" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </a>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load warehouse data for editing
    }
}
