@page "/inventory/categories/add"
@rendermode InteractiveServer
@using AutoPartShop.Web.Services
@inject ICategoryService CategoryService
@inject NavigationManager Navigation

<PageTitle>Add New Category - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Add New Category</h1>
            <p class="text-dark-500 mt-1">Create a new product category or subcategory</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/inventory/categories" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </a>
            <button @onclick="CreateCategory" disabled="@IsSubmitting" class="btn-primary flex items-center justify-center">
                @if (IsSubmitting)
                {
                    <svg class="w-5 h-5 mr-2 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                    </svg>
                    <span>Creating...</span>
                }
                else
                {
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    <span>Create Category</span>
                }
            </button>
        </div>
    </div>

    <!-- Error Message -->
    @if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="card border-l-4 border-red-500 bg-red-50">
            <div class="flex items-center gap-4">
                <svg class="w-6 h-6 text-red-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div class="flex-1">
                    <h4 class="font-semibold text-red-900">Error</h4>
                    <p class="text-red-700 text-sm">@ErrorMessage</p>
                </div>
                <button @onclick="() => ErrorMessage = string.Empty" class="text-red-600 hover:text-red-700 font-medium">Dismiss</button>
            </div>
        </div>
    }

    <!-- Success Message -->
    @if (!string.IsNullOrEmpty(SuccessMessage))
    {
        <div class="card border-l-4 border-green-500 bg-green-50">
            <div class="flex items-center gap-4">
                <svg class="w-6 h-6 text-green-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div class="flex-1">
                    <h4 class="font-semibold text-green-900">Success</h4>
                    <p class="text-green-700 text-sm">@SuccessMessage</p>
                </div>
            </div>
        </div>
    }

    <!-- Add Category Form -->
    <div class="space-y-6">
        <!-- Basic Information Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Basic Information</h3>
            <div class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Category Name *</label>
                        <input type="text" @bind="NewCategory.Name" placeholder="e.g., Engine Components" class="input-field" required />
                        <p class="text-xs text-dark-500 mt-1">Display name for the category</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Category Code *</label>
                        <input type="text" @bind="NewCategory.Code" placeholder="e.g., ENG-001" class="input-field" required />
                        <p class="text-xs text-dark-500 mt-1">Unique identifier (will be uppercase)</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Parent Category</label>
                        <select @onchange="OnParentCategoryChanged" value="@SelectedParentId" class="input-field">
                            <option value="">-- No Parent (Root Category) --</option>
                            @foreach (var cat in ParentCategories)
                            {
                                var depth = cat.DepthLevel;
                                var indent = new string(' ', depth * 2); // 2 spaces per level
                                var depthIndicator = depth > 0 ? "└─ " : ""; // Visual indicator for nested items
                                <option value="@cat.Id.ToString()">@($"{depthIndicator}{indent}{cat.Name} ({cat.Code}) - Level {depth + 1}")</option>
                            }
                        </select>
                        <p class="text-xs text-dark-500 mt-1">Leave empty to create a root category. Select any category to create a subcategory.</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Display Order</label>
                        <input type="number" @bind="NewCategory.DisplayOrder" placeholder="0" class="input-field" />
                        <p class="text-xs text-dark-500 mt-1">Order in lists (0 = first)</p>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Description</label>
                    <textarea rows="4" @bind="NewCategory.Description" class="input-field" placeholder="Detailed description of this category..."></textarea>
                    <p class="text-xs text-dark-500 mt-1">What products are included in this category?</p>
                </div>
            </div>
        </div>

        <!-- Parent Category Info Section -->
        @if (!string.IsNullOrEmpty(SelectedParentId))
        {
            var selectedParent = ParentCategories.FirstOrDefault(c => c.Id.ToString() == SelectedParentId);
            @if (selectedParent != null)
            {
                <div class="card bg-blue-50 border border-blue-200">
                    <h3 class="text-lg font-bold text-blue-900 mb-4">Parent Category Information</h3>
                    <div class="space-y-3">
                        <div>
                            <p class="text-sm text-blue-700 font-medium">Parent Category</p>
                            <p class="text-dark-900 font-semibold">@selectedParent.Name</p>
                        </div>
                        <div>
                            <p class="text-sm text-blue-700 font-medium">Breadcrumb Path</p>
                            <p class="text-dark-900 font-semibold font-mono text-sm">@selectedParent.BreadcrumbPath</p>
                        </div>
                        <div class="grid grid-cols-2 gap-4">
                            <div>
                                <p class="text-sm text-blue-700 font-medium">Current Level</p>
                                <p class="text-dark-900 font-semibold">@(selectedParent.DepthLevel + 1) / 7</p>
                            </div>
                            <div>
                                <p class="text-sm text-blue-700 font-medium">Child Categories</p>
                                <p class="text-dark-900 font-semibold">@selectedParent.ChildCount</p>
                            </div>
                        </div>
                        @if (selectedParent.DepthLevel >= 6)
                        {
                            <div class="p-3 bg-red-100 border border-red-300 rounded-lg">
                                <p class="text-sm text-red-700 font-medium">⚠️ Cannot Create Subcategory</p>
                                <p class="text-xs text-red-600">This parent category has reached the maximum depth level (7)</p>
                            </div>
                        }
                        else if (selectedParent.DepthLevel >= 5)
                        {
                            <div class="p-3 bg-yellow-100 border border-yellow-300 rounded-lg">
                                <p class="text-sm text-yellow-700 font-medium">⚠️ Approaching Maximum Depth</p>
                                <p class="text-xs text-yellow-600">New category will be at level @(selectedParent.DepthLevel + 2) / 7</p>
                            </div>
                        }
                    </div>
                </div>
            }
        }

        <!-- Display & Visibility Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Display & Visibility</h3>
            <div class="space-y-6">
                <div class="flex items-center space-x-3">
                    <input type="checkbox" @bind="NewCategory.IsActive" id="isActive" class="w-4 h-4 rounded border-dark-300" />
                    <label for="isActive" class="text-sm font-medium text-dark-900">Active Category</label>
                </div>
                <p class="text-xs text-dark-500">Inactive categories won't appear in frontend</p>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-4 justify-between">
            <a href="/inventory/categories" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </a>
            <div class="flex gap-2">
                <button type="button" @onclick="ResetForm" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                    </svg>
                    Reset
                </button>
                <button type="button" @onclick="CreateCategory" disabled="@IsSubmitting" class="btn-primary flex items-center justify-center">
                    @if (IsSubmitting)
                    {
                        <svg class="w-5 h-5 mr-2 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                        <span>Creating...</span>
                    }
                    else
                    {
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        <span>Create Category</span>
                    }
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    private CreateCategoryRequest NewCategory = new() { IsActive = true };
    private List<CategoryDto> ParentCategories = new();
    private string SelectedParentId = string.Empty;
    private bool IsSubmitting = false;
    private string ErrorMessage = string.Empty;
    private string SuccessMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadParentCategories();
    }

    private void OnParentCategoryChanged(ChangeEventArgs e)
    {
        SelectedParentId = e.Value?.ToString() ?? string.Empty;
    }

    private async Task LoadParentCategories()
    {
        try
        {
            // Load ALL categories (not just top-level) to enable recursive subcategory creation
            var response = await CategoryService.GetAllCategoriesAsync();
            if (response != null)
            {
                // Sort by hierarchy to show them indented in dropdown
                ParentCategories = SortCategoriesByHierarchy(response.ToList());
            }
        }
        catch (ServiceException ex)
        {
            ErrorMessage = $"Failed to load parent categories: {ex.Message}";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
        }
    }

    /// <summary>
    /// Sorts categories by hierarchy for proper dropdown display
    /// </summary>
    private List<CategoryDto> SortCategoriesByHierarchy(List<CategoryDto> categories)
    {
        var sorted = new List<CategoryDto>();
        var processed = new HashSet<Guid>();

        // First add all root categories
        var roots = categories.Where(c => c.ParentCategoryId == null).OrderBy(c => c.DisplayOrder).ThenBy(c => c.Name).ToList();

        foreach (var root in roots)
        {
            AddCategoryAndChildren(root, categories, sorted, processed);
        }

        // Add any orphaned categories (shouldn't happen)
        foreach (var cat in categories.Where(c => !processed.Contains(c.Id)))
        {
            sorted.Add(cat);
            processed.Add(cat.Id);
        }

        return sorted;
    }

    /// <summary>
    /// Recursively adds a category and its children to the sorted list
    /// </summary>
    private void AddCategoryAndChildren(CategoryDto category, List<CategoryDto> allCategories, List<CategoryDto> sorted, HashSet<Guid> processed)
    {
        if (processed.Contains(category.Id))
            return;

        sorted.Add(category);
        processed.Add(category.Id);

        // Add children in order
        var children = allCategories
            .Where(c => c.ParentCategoryId == category.Id)
            .OrderBy(c => c.DisplayOrder)
            .ThenBy(c => c.Name)
            .ToList();

        foreach (var child in children)
        {
            AddCategoryAndChildren(child, allCategories, sorted, processed);
        }
    }

    private async Task CreateCategory()
    {
        // Validation
        if (string.IsNullOrWhiteSpace(NewCategory.Name))
        {
            ErrorMessage = "Category name is required";
            return;
        }

        if (string.IsNullOrWhiteSpace(NewCategory.Code))
        {
            ErrorMessage = "Category code is required";
            return;
        }

        try
        {
            IsSubmitting = true;
            ErrorMessage = string.Empty;
            SuccessMessage = string.Empty;

            // Set ParentCategoryId from SelectedParentId
            Guid? parentId = null;
            if (!string.IsNullOrEmpty(SelectedParentId) && Guid.TryParse(SelectedParentId, out var parsedParentId))
            {
                parentId = parsedParentId;

                // Validate depth - check if parent would exceed max depth
                var parentCategory = ParentCategories.FirstOrDefault(c => c.Id == parsedParentId);
                if (parentCategory != null)
                {
                    const int MaxCategoryDepth = 7;
                    if (parentCategory.DepthLevel >= MaxCategoryDepth - 1)
                    {
                        ErrorMessage = $"Cannot create subcategory! Parent category is at level {parentCategory.DepthLevel + 1}. Maximum allowed level is 7.";
                        return;
                    }
                }
            }

            NewCategory.ParentCategoryId = parentId;

            await CategoryService.CreateCategoryAsync(NewCategory);
            SuccessMessage = "Category created successfully!";
            await Task.Delay(1500);
            Navigation.NavigateTo("/inventory/categories");
        }
        catch (ServiceException ex)
        {
            ErrorMessage = $"Error creating category: {ex.Message}";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An unexpected error occurred: {ex.Message}";
        }
        finally
        {
            IsSubmitting = false;
        }
    }

    private void ResetForm()
    {
        NewCategory = new() { IsActive = true };
        SelectedParentId = string.Empty;
        ErrorMessage = string.Empty;
        SuccessMessage = string.Empty;
    }
}
