@page "/inventory/unit-conversions"
@rendermode InteractiveServer

<PageTitle>Unit Conversions - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Unit Conversions</h1>
            <p class="text-dark-500 mt-1">Manage conversion rates between units - Buy in one unit, Sell in another</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/inventory/units" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Back to Units
            </a>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Add Conversion
            </button>
        </div>
    </div>

    <!-- Info Banner -->
    <div class="card bg-blue-50 border-l-4 border-blue-500">
        <p class="text-blue-900 text-sm">
            <strong>Unit Conversions Example:</strong> Buy Engine Oil in Liters (L) but sell in Milliliters (ml) or pieces.
            Define conversion rates here so the system automatically adjusts quantities and prices.
        </p>
    </div>

    <!-- Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Total Conversions -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Total Conversions</p>
                    <p class="text-2xl font-bold text-dark-900">18</p>
                </div>
                <div class="p-3 bg-primary-100 rounded-lg">
                    <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Active Conversions -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Active Conversions</p>
                    <p class="text-2xl font-bold text-dark-900">18</p>
                </div>
                <div class="p-3 bg-green-100 rounded-lg">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-4">Filters</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Base Unit</label>
                <select class="input-field">
                    <option selected>All Base Units</option>
                    <option>Kilogram (kg)</option>
                    <option>Liter (L)</option>
                    <option>Meter (m)</option>
                    <option>Piece (pcs)</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                <select class="input-field">
                    <option selected>All Status</option>
                    <option>Active</option>
                    <option>Inactive</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Conversions by Type -->
    <div class="space-y-6">
        <!-- Weight Conversions -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Weight Conversions (Base: Kilogram)</h3>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-dark-200 bg-dark-50">
                            <th class="text-left py-3 px-4 font-semibold text-dark-900">From Unit</th>
                            <th class="text-left py-3 px-4 font-semibold text-dark-900">To Unit</th>
                            <th class="text-right py-3 px-4 font-semibold text-dark-900">Conversion Factor</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Formula</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-dark-200">
                        <tr class="hover:bg-dark-50">
                            <td class="py-4 px-4 font-semibold text-dark-900">Kilogram (kg)</td>
                            <td class="py-4 px-4 text-dark-700">Gram (g)</td>
                            <td class="text-right py-4 px-4 text-dark-700">1,000</td>
                            <td class="text-center py-4 px-4 text-dark-700">1 kg = 1,000 g</td>
                            <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                            <td class="text-center py-4 px-4">
                                <button class="text-primary-600 hover:text-primary-700 text-xs font-medium">Edit</button>
                            </td>
                        </tr>
                        <tr class="hover:bg-dark-50">
                            <td class="py-4 px-4 font-semibold text-dark-900">Kilogram (kg)</td>
                            <td class="py-4 px-4 text-dark-700">Milligram (mg)</td>
                            <td class="text-right py-4 px-4 text-dark-700">1,000,000</td>
                            <td class="text-center py-4 px-4 text-dark-700">1 kg = 1,000,000 mg</td>
                            <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                            <td class="text-center py-4 px-4">
                                <button class="text-primary-600 hover:text-primary-700 text-xs font-medium">Edit</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Volume Conversions -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Volume Conversions (Base: Liter)</h3>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-dark-200 bg-dark-50">
                            <th class="text-left py-3 px-4 font-semibold text-dark-900">From Unit</th>
                            <th class="text-left py-3 px-4 font-semibold text-dark-900">To Unit</th>
                            <th class="text-right py-3 px-4 font-semibold text-dark-900">Conversion Factor</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Formula</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-dark-200">
                        <tr class="hover:bg-dark-50">
                            <td class="py-4 px-4 font-semibold text-dark-900">Liter (L)</td>
                            <td class="py-4 px-4 text-dark-700">Milliliter (ml)</td>
                            <td class="text-right py-4 px-4 text-dark-700">1,000</td>
                            <td class="text-center py-4 px-4 text-dark-700">1 L = 1,000 ml</td>
                            <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                            <td class="text-center py-4 px-4">
                                <button class="text-primary-600 hover:text-primary-700 text-xs font-medium">Edit</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Length Conversions -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Length Conversions (Base: Meter)</h3>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-dark-200 bg-dark-50">
                            <th class="text-left py-3 px-4 font-semibold text-dark-900">From Unit</th>
                            <th class="text-left py-3 px-4 font-semibold text-dark-900">To Unit</th>
                            <th class="text-right py-3 px-4 font-semibold text-dark-900">Conversion Factor</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Formula</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-dark-200">
                        <tr class="hover:bg-dark-50">
                            <td class="py-4 px-4 font-semibold text-dark-900">Meter (m)</td>
                            <td class="py-4 px-4 text-dark-700">Centimeter (cm)</td>
                            <td class="text-right py-4 px-4 text-dark-700">100</td>
                            <td class="text-center py-4 px-4 text-dark-700">1 m = 100 cm</td>
                            <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                            <td class="text-center py-4 px-4">
                                <button class="text-primary-600 hover:text-primary-700 text-xs font-medium">Edit</button>
                            </td>
                        </tr>
                        <tr class="hover:bg-dark-50">
                            <td class="py-4 px-4 font-semibold text-dark-900">Meter (m)</td>
                            <td class="py-4 px-4 text-dark-700">Millimeter (mm)</td>
                            <td class="text-right py-4 px-4 text-dark-700">1,000</td>
                            <td class="text-center py-4 px-4 text-dark-700">1 m = 1,000 mm</td>
                            <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                            <td class="text-center py-4 px-4">
                                <button class="text-primary-600 hover:text-primary-700 text-xs font-medium">Edit</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        <!-- Count Conversions -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Count Conversions (Base: Piece)</h3>

            <div class="overflow-x-auto">
                <table class="w-full text-sm">
                    <thead>
                        <tr class="border-b border-dark-200 bg-dark-50">
                            <th class="text-left py-3 px-4 font-semibold text-dark-900">From Unit</th>
                            <th class="text-left py-3 px-4 font-semibold text-dark-900">To Unit</th>
                            <th class="text-right py-3 px-4 font-semibold text-dark-900">Conversion Factor</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Formula</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                            <th class="text-center py-3 px-4 font-semibold text-dark-900">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-dark-200">
                        <tr class="hover:bg-dark-50">
                            <td class="py-4 px-4 font-semibold text-dark-900">Piece (pcs)</td>
                            <td class="py-4 px-4 text-dark-700">Box</td>
                            <td class="text-right py-4 px-4 text-dark-700">12</td>
                            <td class="text-center py-4 px-4 text-dark-700">1 box = 12 pcs</td>
                            <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                            <td class="text-center py-4 px-4">
                                <button class="text-primary-600 hover:text-primary-700 text-xs font-medium">Edit</button>
                            </td>
                        </tr>
                        <tr class="hover:bg-dark-50">
                            <td class="py-4 px-4 font-semibold text-dark-900">Piece (pcs)</td>
                            <td class="py-4 px-4 text-dark-700">Carton</td>
                            <td class="text-right py-4 px-4 text-dark-700">120</td>
                            <td class="text-center py-4 px-4 text-dark-700">1 carton = 120 pcs</td>
                            <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                            <td class="text-center py-4 px-4">
                                <button class="text-primary-600 hover:text-primary-700 text-xs font-medium">Edit</button>
                            </td>
                        </tr>
                        <tr class="hover:bg-dark-50">
                            <td class="py-4 px-4 font-semibold text-dark-900">Box</td>
                            <td class="py-4 px-4 text-dark-700">Carton</td>
                            <td class="text-right py-4 px-4 text-dark-700">10</td>
                            <td class="text-center py-4 px-4 text-dark-700">1 carton = 10 boxes</td>
                            <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                            <td class="text-center py-4 px-4">
                                <button class="text-primary-600 hover:text-primary-700 text-xs font-medium">Edit</button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Load conversions
    }
}
