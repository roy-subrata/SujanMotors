@page "/inventory/categories/{id}/edit"
@rendermode InteractiveServer
@using AutoPartShop.Web.Services
@using MudBlazor
@inject ICategoryService CategoryService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject Microsoft.Extensions.Logging.ILogger<EditCategory> Logger

<PageTitle>Edit Category - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Loading State -->
    @if (IsLoading)
    {
        <div class="card">
            <div class="flex items-center justify-center py-12">
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-12 h-12 bg-primary-100 rounded-full mb-4">
                        <svg class="w-6 h-6 text-primary-600 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                    </div>
                    <p class="text-dark-600 font-medium">Loading category...</p>
                </div>
            </div>
        </div>
    }
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <!-- Error State -->
        <div class="card border-l-4 border-red-500 bg-red-50">
            <div class="flex items-center gap-4">
                <svg class="w-6 h-6 text-red-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div class="flex-1">
                    <h4 class="font-semibold text-red-900">Error Loading Category</h4>
                    <p class="text-red-700 text-sm">@ErrorMessage</p>
                </div>
                <button @onclick="RetryLoadCategory" class="btn-secondary text-sm">Retry</button>
            </div>
        </div>
    }
    else if (Category != null)
    {
        <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Edit Category</h1>
            <p class="text-dark-500 mt-1">Update category information and settings</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button @onclick="HandleCancel" class="btn-secondary flex items-center justify-center" disabled="@IsSaving">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <button @onclick="HandleSave" class="btn-primary flex items-center justify-center" disabled="@IsSaving">
                @if (IsSaving)
                {
                    <svg class="w-5 h-5 mr-2 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                    </svg>
                    <span>Saving...</span>
                }
                else
                {
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    <span>Save Changes</span>
                }
            </button>
        </div>
    </div>

    <!-- Edit Category Form -->
    <form class="space-y-6" @onsubmit="HandleSave">
        <!-- Basic Information Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Basic Information</h3>
            <div class="space-y-6">
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Category Name *</label>
                        <input type="text" @bind="Category.Name" class="input-field" required />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Category Code</label>
                        <input type="text" value="@Category.Code" class="input-field bg-dark-100" disabled />
                        <p class="text-xs text-dark-500 mt-1">Cannot be changed</p>
                    </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Parent Category</label>
                        <select class="input-field bg-dark-100" disabled>
                            <option value="">-- No Parent (Root Category) --</option>
                        </select>
                        <p class="text-xs text-dark-500 mt-1">Cannot change parent for root categories</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Category Level</label>
                        <input type="text" value="@GetCategoryLevel()" class="input-field bg-dark-100" disabled />
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Description</label>
                </div>

                <div className="pt-4 border-t border-dark-200">
                    <p class="text-sm text-dark-500 font-medium mb-2">Category Statistics</p>
                    <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                        <div class="bg-dark-50 p-3 rounded">
                            <p class="text-xs text-dark-500">Subcategories</p>
                            <p class="text-2xl font-bold text-dark-900 mt-1">@(Category.SubCategories?.Count ?? 0)</p>
                        </div>
                        <div class="bg-dark-50 p-3 rounded">
                            <p class="text-xs text-dark-500">Created By</p>
                            <p class="text-sm font-semibold text-dark-900 mt-1">@Category.CreatedBy</p>
                        </div>
                        <div class="bg-dark-50 p-3 rounded">
                            <p class="text-xs text-dark-500">Modified By</p>
                            <p class="text-sm font-semibold text-dark-900 mt-1">@(string.IsNullOrEmpty(Category.ModifiedBy) ? Category.CreatedBy : Category.ModifiedBy)</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Display & Visibility Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Display & Visibility</h3>
            <div className="space-y-6">
                <div>
                    <label class="flex items-center space-x-3 cursor-pointer">
                        <input type="checkbox" @bind="Category.IsActive" class="w-4 h-4 rounded border-dark-300" />
                        <span class="text-sm font-medium text-dark-900">Active Category</span>
                    </label>
                    <p class="text-xs text-dark-500 mt-2">When inactive, this category will not appear in the frontend</p>
                </div>
            </div>
        </div>

        <!-- Additional Settings Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Additional Settings</h3>
            <div className="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Display Order</label>
                    <input type="number" @bind="Category.DisplayOrder" class="input-field" />
                    <p class="text-xs text-dark-500 mt-1">Controls the order in which this category appears</p>
                </div>
            </div>
        </div>

        <!-- Danger Zone Section -->
        @if (Category.SubCategories?.Count == 0)
        {
            <div class="card border-l-4 border-red-500">
                <h3 class="text-lg font-bold text-red-600 mb-6">Danger Zone</h3>
                <div className="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Delete This Category</label>
                        <p class="text-sm text-dark-600 mb-4">Be careful! This action cannot be undone. Make sure you have backed up any important information.</p>
                        <button type="button" @onclick="HandleDelete" class="px-4 py-2 bg-red-600 text-white rounded-lg hover:bg-red-700 transition-colors text-sm font-medium disabled:opacity-50 disabled:cursor-not-allowed" disabled="@IsSaving" title="Delete this category permanently">
                            @if (IsSaving)
                            {
                                <span>Deleting...</span>
                            }
                            else
                            {
                                <span>Delete Category</span>
                            }
                        </button>
                    </div>
                </div>
            </div>
        }
        else
        {
            <div class="card border-l-4 border-yellow-500 bg-yellow-50">
                <h3 class="text-lg font-bold text-yellow-600 mb-6">Cannot Delete</h3>
                <div className="space-y-4">
                    <p class="text-sm text-yellow-700">This category has @Category?.SubCategories?.Count subcategories and cannot be deleted. Please delete or reassign all subcategories first.</p>
                </div>
            </div>
        }

        <!-- Form Actions -->
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-4 justify-between">
            <button type="button" @onclick="HandleCancel" class="btn-secondary flex items-center justify-center" disabled="@IsSaving">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <div class="flex gap-2">
                <button type="button" @onclick="RetryLoadCategory" class="btn-secondary flex items-center justify-center" disabled="@IsSaving">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                    </svg>
                    Reset
                </button>
                <button type="submit" class="btn-primary flex items-center justify-center" disabled="@IsSaving">
                    @if (IsSaving)
                    {
                        <svg class="w-5 h-5 mr-2 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                        <span>Saving...</span>
                    }
                    else
                    {
                        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                        </svg>
                  
                        <span>Save Changes</span>
                    }
                </button>
            </div>
        </div>
    </form>
    }
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    private CategoryDto? Category;
    private CategoryDto? OriginalCategory;
    private bool IsLoading = true;
    private bool IsSaving = false;
    private string ErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategory();
    }

    private async Task LoadCategory()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = string.Empty;
            StateHasChanged();

            if (!Guid.TryParse(Id, out var categoryId))
            {
                ErrorMessage = "Invalid category ID format";
                return;
            }

            var response = await CategoryService.GetCategoryByIdAsync(categoryId);
            if (response != null)
            {
                Category = response;
                OriginalCategory = new CategoryDto
                {
                    Id = response.Id,
                    Name = response.Name,
                    Description = response.Description,
                    Code = response.Code,
                    ParentCategoryId = response.ParentCategoryId,
                    DisplayOrder = response.DisplayOrder,
                    IsActive = response.IsActive,
                    CreatedBy = response.CreatedBy,
                    ModifiedBy = response.ModifiedBy,
                    SubCategories = response.SubCategories
                };
            }
            else
            {
                ErrorMessage = "Category not found";
            }
        }
        catch (ServiceException ex)
        {
            ErrorMessage = $"Failed to load category: {ex.Message}";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private async Task RetryLoadCategory()
    {
        await LoadCategory();
    }

    private async Task HandleSave()
    {
        if (Category == null)
            return;

        if (string.IsNullOrWhiteSpace(Category.Name))
        {
            Snackbar.Add("Category name is required", Severity.Warning);
            return;
        }

        try
        {
            IsSaving = true;
            StateHasChanged();

            var request = new UpdateCategoryRequest
            {
                Id = Category.Id,
                Name = Category.Name,
                Description = Category.Description,
                DisplayOrder = Category.DisplayOrder,
                IsActive = Category.IsActive
            };

            var result = await CategoryService.UpdateCategoryAsync(Category.Id, request);

            if (result != null)
            {
                Category = result;
                OriginalCategory = new CategoryDto
                {
                    Id = result.Id,
                    Name = result.Name,
                    Description = result.Description,
                    Code = result.Code,
                    ParentCategoryId = result.ParentCategoryId,
                    DisplayOrder = result.DisplayOrder,
                    IsActive = result.IsActive,
                    CreatedBy = result.CreatedBy,
                    ModifiedBy = result.ModifiedBy,
                    SubCategories = result.SubCategories
                };

                Snackbar.Add("Category updated successfully", Severity.Success);
                Logger.LogInformation($"[EditCategory] Category '{Category.Name}' (ID: {Category.Id}) updated successfully");
            }
        }
        catch (ServiceException ex)
        {
            ErrorMessage = $"Failed to update category: {ex.Message}";
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            Logger.LogError($"[EditCategory] ServiceException: {ex.Message}");
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            Logger.LogError($"[EditCategory] Exception: {ex.Message}");
        }
        finally
        {
            IsSaving = false;
            StateHasChanged();
        }
    }

    private void HandleCancel()
    {
        Logger.LogInformation($"[EditCategory] Navigation back to categories list");
        Navigation.NavigateTo("/inventory/categories");
    }

    private async Task HandleDelete()
    {
        if (Category == null)
            return;

        try
        {
            var parameters = new DialogParameters<ConfirmDialog>
            {
                { nameof(ConfirmDialog.ContentText), $"Are you sure you want to delete the category '{Category.Name}'? This action cannot be undone." }
            };

            var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm Delete", parameters);
            var result = await dialog.Result;

            if (result?.Canceled == true)
            {
                Logger.LogInformation($"[EditCategory] Delete cancelled for category '{Category.Name}'");
                return;  // ✅ User cancelled - exit early
            }

            // ✅ Only proceed with deletion if user confirmed
            IsSaving = true;
            StateHasChanged();

            await CategoryService.DeleteCategoryAsync(Category.Id);
            Snackbar.Add("Category deleted successfully", Severity.Success);
            Logger.LogInformation($"[EditCategory] Category '{Category.Name}' (ID: {Category.Id}) deleted successfully");

            // ✅ Navigate back to categories list after successful deletion
            await Task.Delay(500);  // Brief delay to show success message
            Navigation.NavigateTo("/inventory/categories");
        }
        catch (ServiceException ex)
        {
            ErrorMessage = $"Failed to delete category: {ex.Message}";
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            Logger.LogError($"[EditCategory] Delete ServiceException: {ex.Message}");
            IsSaving = false;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
            Logger.LogError($"[EditCategory] Delete Exception: {ex.Message}");
            IsSaving = false;
            StateHasChanged();
        }
    }

    private string GetCategoryLevel()
    {
        if (Category?.ParentCategoryId == null)
        {
            return "Root (Level 1)";
        }

        // In a real implementation, you would calculate the actual depth
        return "Level 2+";
    }
}
