@page "/inventory/categories/{id}"

<PageTitle>Category Details - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Category Details</h1>
            <p class="text-dark-500 mt-1">Complete information about this category</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                </svg>
                Print
            </button>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H14v2.828a2 2 0 11-2.828-2.828l8.586-8.586z"></path>
                </svg>
                Edit Category
            </button>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Column - Quick Info -->
        <div class="lg:col-span-1 space-y-6">
            <!-- Category Icon Card -->
            <div class="card">
                <div class="w-full bg-gradient-to-br from-purple-50 to-purple-100 rounded-lg h-40 flex items-center justify-center mb-4">
                    <span class="text-6xl">⚙️</span>
                </div>
                <p class="text-center font-semibold text-dark-900">Engine Components</p>
                <p class="text-center text-sm text-dark-500 mt-1">CAT-001</p>
                <div class="mt-4 pt-4 border-t border-dark-200">
                    <span class="badge-success">Active</span>
                </div>
            </div>

            <!-- Quick Info Card -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Quick Info</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Status</p>
                        <p class="text-dark-900 font-semibold mt-1">Active</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Category Level</p>
                        <p class="text-dark-900 font-semibold mt-1">Root (Level 1)</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Created On</p>
                        <p class="text-dark-900 font-semibold mt-1">Jan 15, 2024</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Last Updated</p>
                        <p class="text-dark-900 font-semibold mt-1">Nov 15, 2024</p>
                    </div>
                </div>
            </div>

            <!-- Actions Card -->
            <div class="card space-y-2">
                <button class="w-full btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Add Subcategory
                </button>
                <button class="w-full btn-secondary">
                    <svg class="w-5 h-5 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                    </svg>
                    View All Parts
                </button>
            </div>
        </div>

        <!-- Right Column - Detailed Information -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Basic Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Basic Information</h3>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Category Name</p>
                        <p class="text-dark-900 font-semibold mt-2">Engine Components</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Category Code</p>
                        <p class="text-dark-900 font-semibold mt-2">CAT-001</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Display Name</p>
                        <p class="text-dark-900 font-semibold mt-2">Engine Components</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">URL Slug</p>
                        <p class="text-dark-900 font-semibold mt-2">engine-components</p>
                    </div>
                    <div className="md:col-span-2">
                        <p class="text-sm text-dark-500 font-medium">Description</p>
                        <p class="text-dark-700 mt-2">Premium automotive engine components including spark plugs, air filters, oil filters, and ignition systems for gasoline and diesel engines.</p>
                    </div>
                </div>
            </div>

            <!-- Category Hierarchy -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Category Hierarchy</h3>
                <div className="space-y-4">
                    <div className="flex items-center">
                        <span class="inline-flex items-center justify-center w-8 h-8 bg-purple-100 rounded-full text-purple-600 font-semibold text-sm">1</span>
                        <div class="ml-4 flex-1">
                            <p class="font-semibold text-dark-900">Engine Components</p>
                            <p class="text-xs text-dark-500">Root Category (Level 1)</p>
                        </div>
                    </div>

                    <div className="pl-8 border-l-2 border-dark-200 space-y-3">
                        <div className="flex items-center">
                            <span class="inline-flex items-center justify-center w-8 h-8 bg-blue-100 rounded-full text-blue-600 font-semibold text-sm">1.1</span>
                            <div class="ml-4 flex-1">
                                <p class="font-medium text-dark-900">Spark Plugs</p>
                                <p class="text-xs text-dark-500">CAT-001-001 • 8 parts</p>
                            </div>
                        </div>

                        <div className="flex items-center">
                            <span class="inline-flex items-center justify-center w-8 h-8 bg-blue-100 rounded-full text-blue-600 font-semibold text-sm">1.2</span>
                            <div class="ml-4 flex-1">
                                <p class="font-medium text-dark-900">Air Filters</p>
                                <p class="text-xs text-dark-500">CAT-001-002 • 12 parts</p>
                            </div>
                        </div>

                        <div className="flex items-center">
                            <span class="inline-flex items-center justify-center w-8 h-8 bg-blue-100 rounded-full text-blue-600 font-semibold text-sm">1.3</span>
                            <div class="ml-4 flex-1">
                                <p class="font-medium text-dark-900">Engine Oil Filters</p>
                                <p class="text-xs text-dark-500">CAT-001-003 • 8 parts</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Statistics -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Statistics</h3>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="border-b md:border-b-0 md:border-r border-dark-200 pb-6 md:pb-0 md:pr-6">
                        <p class="text-sm text-dark-500 font-medium">Total Subcategories</p>
                        <p class="text-3xl font-bold text-dark-900 mt-2">3</p>
                        <p class="text-xs text-dark-500 mt-1">Direct children only</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Total Products</p>
                        <p class="text-3xl font-bold text-dark-900 mt-2">28</p>
                        <p class="text-xs text-dark-500 mt-1">Including all levels</p>
                    </div>
                </div>
            </div>

            <!-- Display & Visibility -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Display & Visibility</h3>
                <div className="space-y-4">
                    <div className="flex items-center justify-between py-2">
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Visible in Menu</p>
                            <p class="text-xs text-dark-500 mt-1">Shows in navigation</p>
                        </div>
                        <span class="badge-success">Yes</span>
                    </div>
                    <div className="flex items-center justify-between py-2 border-t border-dark-200">
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Searchable</p>
                            <p class="text-xs text-dark-500 mt-1">Included in search</p>
                        </div>
                        <span class="badge-success">Yes</span>
                    </div>
                    <div className="flex items-center justify-between py-2 border-t border-dark-200">
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Category Icon</p>
                            <p class="text-xs text-dark-500 mt-1">Visual representation</p>
                        </div>
                        <span class="text-2xl">⚙️</span>
                    </div>
                    <div className="flex items-center justify-between py-2 border-t border-dark-200">
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Color</p>
                            <p class="text-xs text-dark-500 mt-1">Background color</p>
                        </div>
                        <div className="flex items-center gap-2">
                            <div class="w-6 h-6 bg-purple-500 rounded"></div>
                            <span class="text-dark-900 font-semibold">#8b5cf6</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- SEO Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">SEO Information</h3>
                <div className="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Meta Title</p>
                        <p class="text-dark-900 font-semibold mt-1">Engine Components - AutoParts Shop</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Meta Description</p>
                        <p class="text-dark-700 mt-1">Shop high-quality engine components including spark plugs, filters, ignition systems and more for all vehicle types.</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">URL Slug</p>
                        <a href="#" class="text-primary-600 hover:text-primary-700 font-semibold mt-1">engine-components</a>
                    </div>
                </div>
            </div>

            <!-- Related Categories -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Related Categories</h3>
                <div className="flex flex-wrap gap-2">
                    <span class="badge-primary">Transmission</span>
                    <span class="badge-primary">Cooling System</span>
                    <span class="badge-primary">Electrical</span>
                </div>
            </div>

            <!-- Access & Permissions -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Access & Permissions</h3>
                <div className="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Visibility</p>
                        <span class="badge-success">Everyone</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load category details based on Id
    }
}
