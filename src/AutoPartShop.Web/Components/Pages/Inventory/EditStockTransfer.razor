@page "/inventory/warehouse-transfers/{id}/edit"
@rendermode InteractiveServer

<PageTitle>Edit Stock Transfer - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Edit Stock Transfer</h1>
            <p class="text-dark-500 mt-1">TRF-2024-001 | Main Warehouse → South Regional Hub</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/inventory/warehouse-transfers" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </a>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Transfer Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Transfer Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-info">In Transit</span>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Update Status</label>
                        <select class="input-field">
                            <option selected>In Transit</option>
                            <option>Pending</option>
                            <option>Received</option>
                            <option>Delayed</option>
                            <option>Cancelled</option>
                        </select>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Transfer ID</p>
                        <p class="text-dark-900 font-semibold">TRF-2024-001</p>
                    </div>
                </div>
            </div>

            <!-- Summary Statistics -->
            <div class="card bg-blue-50 border-l-4 border-blue-500">
                <h3 class="text-lg font-bold text-blue-900 mb-4">Summary</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <p class="text-blue-800">Total Items</p>
                        <p class="font-semibold text-blue-900">3 SKUs</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Total Quantity</p>
                        <p class="font-semibold text-blue-900">470 units</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Transfer Value</p>
                        <p class="font-semibold text-blue-900">₹6,90,000</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Shipping Cost</p>
                        <p class="font-semibold text-blue-900">₹8,500</p>
                    </div>
                    <div class="flex justify-between pt-3 border-t border-blue-200">
                        <p class="text-blue-800 font-semibold">Total Cost</p>
                        <p class="font-bold text-blue-900">₹6,98,500</p>
                    </div>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="card bg-red-50 border-l-4 border-red-500">
                <h3 class="text-lg font-bold text-red-900 mb-4">Danger Zone</h3>
                <button class="w-full btn-danger flex items-center justify-center text-sm border border-red-300 bg-red-100 text-red-700 hover:bg-red-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Cancel Transfer
                </button>
                <p class="text-xs text-red-700 mt-2">Cannot cancel if already received at destination</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Warehouse Selection (Read-only) -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Warehouse Information</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">From Warehouse</label>
                        <input type="text" value="Main Warehouse (WH-001)" class="input-field" disabled />
                        <p class="text-xs text-dark-500 mt-2">Cannot change source warehouse</p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">To Warehouse</label>
                        <input type="text" value="South Regional Hub (WH-002)" class="input-field" disabled />
                        <p class="text-xs text-dark-500 mt-2">Cannot change destination warehouse</p>
                    </div>
                </div>
            </div>

            <!-- Transfer Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Transfer Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Transfer Date</label>
                        <input type="date" value="2024-11-15" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Expected Delivery Date</label>
                        <input type="date" value="2024-11-18" class="input-field" />
                    </div>
                </div>

                <div class="mt-6">
                    <label class="block text-sm font-medium text-dark-900 mb-2">Priority</label>
                    <select class="input-field">
                        <option selected>Normal</option>
                        <option>High</option>
                        <option>Urgent</option>
                        <option>Low</option>
                    </select>
                </div>
            </div>

            <!-- Items Being Transferred -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Items in Transfer</h3>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">SKU</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Product Name</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Original Qty</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Current Qty</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Unit</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">ENG-2401</td>
                                <td class="py-4 px-4 text-dark-700">Engine Oil Filter (Premium)</td>
                                <td class="text-right py-4 px-4 text-dark-700">200 units</td>
                                <td class="py-4 px-4">
                                    <input type="number" value="200" class="input-field w-20" />
                                </td>
                                <td class="text-center py-4 px-4 text-dark-700">pcs</td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">BRK-0850</td>
                                <td class="py-4 px-4 text-dark-700">Brake Pad Set (Ceramic)</td>
                                <td class="text-right py-4 px-4 text-dark-700">150 units</td>
                                <td class="py-4 px-4">
                                    <input type="number" value="150" class="input-field w-20" />
                                </td>
                                <td class="text-center py-4 px-4 text-dark-700">pcs</td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">SUS-1205</td>
                                <td class="py-4 px-4 text-dark-700">Shock Absorber Assembly</td>
                                <td class="text-right py-4 px-4 text-dark-700">120 units</td>
                                <td class="py-4 px-4">
                                    <input type="number" value="120" class="input-field w-20" />
                                </td>
                                <td class="text-center py-4 px-4 text-dark-700">pcs</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Shipping Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Shipping Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Shipping Method</label>
                        <select class="input-field">
                            <option selected>Road Transport</option>
                            <option>Rail Transport</option>
                            <option>Air Cargo</option>
                            <option>Internal Transfer</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Tracking Number</label>
                        <input type="text" value="TRACK-2024-001" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Driver Name</label>
                        <input type="text" value="Rajesh Sharma" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Driver Contact</label>
                        <input type="tel" value="+91 9876543210" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Vehicle Number</label>
                        <input type="text" value="DL-01-AB-1234" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Estimated Cost</label>
                        <input type="number" value="8500" class="input-field" />
                    </div>
                </div>

                <div class="mt-6">
                    <label class="block text-sm font-medium text-dark-900 mb-2">Special Instructions</label>
                    <textarea rows="3" class="input-field">Handle with care - Premium parts. Ensure temperature controlled storage. Confirm receipt within 24 hours.</textarea>
                </div>
            </div>

            <!-- Additional Notes -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Additional Notes</h3>

                <textarea rows="4" class="input-field">Urgent restock for South region due to high demand. Prioritize delivery to WH-002.</textarea>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <a href="/inventory/warehouse-transfers" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </a>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load transfer data for editing
    }
}
