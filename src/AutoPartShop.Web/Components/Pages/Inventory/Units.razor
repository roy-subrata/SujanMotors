                                <button class="text-red-600 hover:text-red-700 font-medium text-xs">Delete</button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 5 -->
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Milliliter</td>
                        <td class="py-4 px-4 text-dark-700">ml</td>
                        <td class="py-4 px-4 text-dark-700">Volume</td>
                        <td class="text-center py-4 px-4"><span class="badge-info">No</span></td>
                        <td class="text-center py-4 px-4">
                            <span class="inline-block bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-xs font-semibold">1</span>
                        </td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                        <td class="text-center py-4 px-4">
