                    <!-- Row 11 -->
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Carton</td>
                        <td class="py-4 px-4 text-dark-700">ctn</td>
                        <td class="py-4 px-4 text-dark-700">Count</td>
