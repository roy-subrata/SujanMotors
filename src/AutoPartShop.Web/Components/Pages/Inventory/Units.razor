                                <button class="text-red-600 hover:text-red-700 font-medium text-xs">Delete</button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 6 -->
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Meter</td>
                        <td class="py-4 px-4 text-dark-700">m</td>
                        <td class="py-4 px-4 text-dark-700">Length</td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Yes</span></td>
                        <td class="text-center py-4 px-4">
                            <span class="inline-block bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-xs font-semibold">2</span>
                        </td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                        <td class="text-center py-4 px-4">
                            <div class="flex items-center justify-center gap-2">
                                <a href="/inventory/units/m/edit" class="text-primary-600 hover:text-primary-700 font-medium text-xs">Edit</a>
                                <button class="text-red-600 hover:text-red-700 font-medium text-xs">Delete</button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 7 -->
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Centimeter</td>
                        <td class="py-4 px-4 text-dark-700">cm</td>
                        <td class="py-4 px-4 text-dark-700">Length</td>
                        <td class="text-center py-4 px-4"><span class="badge-info">No</span></td>
                        <td class="text-center py-4 px-4">
                            <span class="inline-block bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-xs font-semibold">1</span>
                        </td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                        <td class="text-center py-4 px-4">
                            <div class="flex items-center justify-center gap-2">
                                <a href="/inventory/units/cm/edit" class="text-primary-600 hover:text-primary-700 font-medium text-xs">Edit</a>
                                <button class="text-red-600 hover:text-red-700 font-medium text-xs">Delete</button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 8 -->
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Millimeter</td>
                        <td class="py-4 px-4 text-dark-700">mm</td>
                        <td class="py-4 px-4 text-dark-700">Length</td>
                        <td class="text-center py-4 px-4"><span class="badge-info">No</span></td>
                        <td class="text-center py-4 px-4">
                            <span class="inline-block bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-xs font-semibold">1</span>
                        </td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                        <td class="text-center py-4 px-4">
                            <div class="flex items-center justify-center gap-2">
                                <a href="/inventory/units/mm/edit" class="text-primary-600 hover:text-primary-700 font-medium text-xs">Edit</a>
                                <button class="text-red-600 hover:text-red-700 font-medium text-xs">Delete</button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 9 -->
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Piece</td>
                        <td class="py-4 px-4 text-dark-700">pcs</td>
                        <td class="py-4 px-4 text-dark-700">Count</td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Yes</span></td>
                        <td class="text-center py-4 px-4">
                            <span class="inline-block bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-xs font-semibold">3</span>
                        </td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                        <td class="text-center py-4 px-4">
                            <div class="flex items-center justify-center gap-2">
                                <a href="/inventory/units/pcs/edit" class="text-primary-600 hover:text-primary-700 font-medium text-xs">Edit</a>
                                <button class="text-red-600 hover:text-red-700 font-medium text-xs">Delete</button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 10 -->
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Box</td>
                        <td class="py-4 px-4 text-dark-700">box</td>
                        <td class="py-4 px-4 text-dark-700">Count</td>
