@page "/inventory/units"

<PageTitle>Units of Measurement - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Units of Measurement</h1>
            <p class="text-dark-500 mt-1">Manage measurement units and conversions</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/inventory/unit-conversions" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16V4m0 0L3 8m4-4l4 4m6 0v12m0 0l4-4m-4 4l-4-4"></path>
                </svg>
                Manage Conversions
            </a>
            <a href="/inventory/units/create" class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Add Unit
            </a>
        </div>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <!-- Total Units -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Total Units</p>
                    <p class="text-2xl font-bold text-dark-900">12</p>
                </div>
                <div class="p-3 bg-primary-100 rounded-lg">
                    <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3h.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Base Units -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Base Units</p>
                    <p class="text-2xl font-bold text-dark-900">5</p>
                </div>
                <div class="p-3 bg-blue-100 rounded-lg">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Active Conversions -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Active Conversions</p>
                    <p class="text-2xl font-bold text-dark-900">18</p>
                </div>
                <div class="p-3 bg-green-100 rounded-lg">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-4">Filters</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Search Unit</label>
                <input type="text" placeholder="Search by name or abbreviation..." class="input-field" />
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Unit Type</label>
                <select class="input-field">
                    <option selected>All Types</option>
                    <option>Weight (kg, g, mg)</option>
                    <option>Volume (L, ml)</option>
                    <option>Length (m, cm, mm)</option>
                    <option>Count (piece, box, carton)</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                <select class="input-field">
                    <option selected>All Status</option>
                    <option>Active</option>
                    <option>Inactive</option>
                </select>
            </div>
        </div>
    </div>

    <!-- Units Table -->
    <div class="card">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-bold text-dark-900">All Units</h3>
            <span class="text-sm text-dark-500">Showing 1-12 of 12 units</span>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-dark-200 bg-dark-50">
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Unit Name</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Abbreviation</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Type</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Base Unit</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Conversions</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-dark-200">
                    <!-- Row 1 -->
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Kilogram</td>
                        <td class="py-4 px-4 text-dark-700">kg</td>
                        <td class="py-4 px-4 text-dark-700">Weight</td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Yes</span></td>
                        <td class="text-center py-4 px-4">
                            <span class="inline-block bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-xs font-semibold">2</span>
                        </td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                        <td class="text-center py-4 px-4">
                            <div class="flex items-center justify-center gap-2">
                                <a href="/inventory/units/kg/edit" class="text-primary-600 hover:text-primary-700 font-medium text-xs">Edit</a>
                                <button class="text-red-600 hover:text-red-700 font-medium text-xs">Delete</button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 2 -->
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Gram</td>
                        <td class="py-4 px-4 text-dark-700">g</td>
                        <td class="py-4 px-4 text-dark-700">Weight</td>
                        <td class="text-center py-4 px-4"><span class="badge-info">No</span></td>
                        <td class="text-center py-4 px-4">
                            <span class="inline-block bg-primary-100 text-primary-700 px-3 py-1 rounded-full text-xs font-semibold">1</span>
                        </td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                        <td class="text-center py-4 px-4">
                            <div class="flex items-center justify-center gap-2">
                                <a href="/inventory/units/g/edit" class="text-primary-600 hover:text-primary-700 font-medium text-xs">Edit</a>
                                <button class="text-red-600 hover:text-red-700 font-medium text-xs">Delete</button>
                            </div>
                        </td>
                    </tr>

                    <!-- Row 3 -->
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Milligram</td>
                        <td class="py-4 px-4 text-dark-700">mg</td>
                        <td class="py-4 px-4 text-dark-700">Weight</td>
                        <td class="text-center py-4 px-4"><span class="badge-info">No</span></td>
                        <td class="text-center py-4 px-4">
