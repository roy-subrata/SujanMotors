@page "/inventory/units/{id}/edit"
@rendermode InteractiveServer

<PageTitle>Edit Unit - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Edit Unit</h1>
            <p class="text-dark-500 mt-1">Kilogram (kg)</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/inventory/units" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </a>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Unit Info -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Unit Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-success">Active</span>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Change Status</label>
                        <select class="input-field">
                            <option selected>Active</option>
                            <option>Inactive</option>
                        </select>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Unit Type</p>
                        <p class="text-dark-900 font-semibold">Weight</p>
                    </div>
                </div>
            </div>

            <!-- Usage Stats -->
            <div class="card bg-blue-50 border-l-4 border-blue-500">
                <h3 class="text-lg font-bold text-blue-900 mb-4">Usage Statistics</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <p class="text-blue-800">Used in Purchases</p>
                        <p class="font-semibold text-blue-900">127</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Used in Sales</p>
                        <p class="font-semibold text-blue-900">342</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Parts in Inventory</p>
                        <p class="font-semibold text-blue-900">45</p>
                    </div>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="card bg-red-50 border-l-4 border-red-500">
                <h3 class="text-lg font-bold text-red-900 mb-4">Danger Zone</h3>
                <button class="w-full btn-danger flex items-center justify-center text-sm border border-red-300 bg-red-100 text-red-700 hover:bg-red-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Delete This Unit
                </button>
                <p class="text-xs text-red-700 mt-2">Cannot delete if used in transactions</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Basic Information Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Basic Information</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Unit Name *</label>
                        <input type="text" value="Kilogram" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Abbreviation *</label>
                        <input type="text" value="kg" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Unit Type *</label>
                        <select class="input-field">
                            <option selected>Weight (kg, g, mg)</option>
                            <option>Volume (L, ml)</option>
                            <option>Length (m, cm, mm)</option>
                            <option>Count (piece, box, carton)</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                        <select class="input-field">
                            <option selected>Active</option>
                            <option>Inactive</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Base Unit Configuration -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Base Unit Configuration</h3>

                <div class="space-y-4">
                    <div>
                        <label class="flex items-center cursor-pointer">
                            <input type="checkbox" class="w-4 h-4 rounded border-dark-300 text-primary-600" checked disabled />
                            <span class="ml-3 text-dark-900 font-medium">Mark as Base Unit</span>
                        </label>
                        <p class="text-sm text-dark-500 mt-2 text-dark-600">This is a base unit and cannot be changed (used for conversions)</p>
                    </div>
                </div>
            </div>

            <!-- Unit Conversions -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Conversion Rates</h3>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Target Unit</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Conversion Factor</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 text-dark-900">Gram (g)</td>
                                <td class="text-right py-4 px-4 text-dark-700">1000</td>
                                <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 text-dark-900">Milligram (mg)</td>
                                <td class="text-right py-4 px-4 text-dark-700">1,000,000</td>
                                <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <a href="/inventory/unit-conversions" class="text-primary-600 hover:text-primary-700 text-sm font-medium inline-block mt-4">
                    Manage all conversions →
                </a>
            </div>

            <!-- Unit Category Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Applicable Categories</h3>

                <div class="space-y-3">
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-dark-300 text-primary-600" checked />
                        <span class="ml-3 text-dark-900">Can be used for purchasing</span>
                    </label>
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-dark-300 text-primary-600" checked />
                        <span class="ml-3 text-dark-900">Can be used for selling</span>
                    </label>
                    <label class="flex items-center cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-dark-300 text-primary-600" />
                        <span class="ml-3 text-dark-900">Can be used for inventory management</span>
                    </label>
                </div>
            </div>

            <!-- Description Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Description (Optional)</h3>

                <textarea rows="4" class="input-field" placeholder="Add any notes or description about this unit...">Standard metric unit of weight. Used for heavy items and bulk purchases.</textarea>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <a href="/inventory/units" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </a>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load unit data for editing
    }
}
