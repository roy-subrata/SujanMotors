@page "/inventory/parts/{id}"

<PageTitle>Part Details - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Part Details</h1>
            <p class="text-dark-500 mt-1">View complete information about this part</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                </svg>
                Print
            </button>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H14v2.828a2 2 0 11-2.828-2.828l8.586-8.586z"></path>
                </svg>
                Edit Part
            </button>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Column - Images and Basic Info -->
        <div class="lg:col-span-1 space-y-6">
            <!-- Part Image -->
            <div class="card">
                <div class="w-full bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg h-56 flex items-center justify-center mb-4">
                    <svg class="w-20 h-20 text-blue-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                    </svg>
                </div>
                <div class="flex gap-2">
                    <button class="flex-1 py-2 border-2 border-primary-600 rounded-lg text-primary-600 font-medium hover:bg-primary-50">Image 1</button>
                    <button class="flex-1 py-2 border border-dark-200 rounded-lg text-dark-600 font-medium hover:bg-dark-100">Image 2</button>
                </div>
            </div>

            <!-- Quick Info Card -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Quick Info</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Status</p>
                        <span class="badge-success mt-2">In Stock</span>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Supplier</p>
                        <p class="text-dark-900 font-medium mt-1">Parts Direct Inc.</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Supplier SKU</p>
                        <p class="text-dark-900 font-medium mt-1">PD-EOF-001-SY</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Last Updated</p>
                        <p class="text-dark-900 font-medium mt-1">Nov 15, 2024</p>
                    </div>
                </div>
            </div>

            <!-- Actions Card -->
            <div class="card space-y-2">
                <button class="w-full btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Reorder
                </button>
                <button class="w-full btn-secondary">
                    <svg class="w-5 h-5 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                    </svg>
                    View History
                </button>
            </div>
        </div>

        <!-- Middle & Right Column - Detailed Information -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Basic Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Basic Information</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Part Name</p>
                        <p class="text-dark-900 font-semibold mt-2">Engine Oil Filter</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">SKU</p>
                        <p class="text-dark-900 font-semibold mt-2">EOF-001</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Category</p>
                        <p class="text-dark-900 font-semibold mt-2">Filters</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Subcategory</p>
                        <p class="text-dark-900 font-semibold mt-2">Engine Maintenance</p>
                    </div>
                    <div className="md:col-span-2">
                        <p class="text-sm text-dark-500 font-medium">Description</p>
                        <p class="text-dark-700 mt-2">Premium synthetic engine oil filter designed for extended drain intervals. Compatible with most gasoline and diesel engines. Provides superior filtration and protection.</p>
                    </div>
                </div>
            </div>

            <!-- Pricing Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Pricing Information</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="border-b md:border-b-0 md:border-r border-dark-200 pb-6 md:pb-0 md:pr-6">
                        <p class="text-sm text-dark-500 font-medium">Cost Price</p>
                        <p class="text-2xl font-bold text-dark-900 mt-2">$8.50</p>
                        <p class="text-xs text-dark-500 mt-1">What we pay</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Selling Price</p>
                        <p class="text-2xl font-bold text-primary-600 mt-2">$12.99</p>
                        <p class="text-xs text-dark-500 mt-1">Customer price</p>
                    </div>
                    <div class="border-b md:border-b-0 md:border-r border-dark-200 pb-6 md:pb-0 md:pr-6">
                        <p class="text-sm text-dark-500 font-medium">Profit Margin</p>
                        <p class="text-2xl font-bold text-green-600 mt-2">$4.49</p>
                        <p class="text-xs text-dark-500 mt-1">Per unit profit</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Markup %</p>
                        <p class="text-2xl font-bold text-green-600 mt-2">52.7%</p>
                        <p class="text-xs text-dark-500 mt-1">Profit percentage</p>
                    </div>
                </div>
            </div>

            <!-- Stock Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Stock Information</h3>
                <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="border-b md:border-b-0 md:border-r border-dark-200 pb-6 md:pb-0 md:pr-6">
                        <p class="text-sm text-dark-500 font-medium">Current Stock</p>
                        <p class="text-3xl font-bold text-dark-900 mt-2">245</p>
                        <p class="text-xs text-dark-500 mt-1">units available</p>
                    </div>
                    <div class="border-b md:border-b-0 md:border-r border-dark-200 pb-6 md:pb-0 md:pr-6">
                        <p class="text-sm text-dark-500 font-medium">Reorder Level</p>
                        <p class="text-3xl font-bold text-dark-900 mt-2">50</p>
                        <p class="text-xs text-dark-500 mt-1">minimum threshold</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Reorder Qty</p>
                        <p class="text-3xl font-bold text-dark-900 mt-2">100</p>
                        <p class="text-xs text-dark-500 mt-1">order amount</p>
                    </div>
                </div>

                <!-- Stock History -->
                <div class="mt-6 pt-6 border-t border-dark-200">
                    <h4 class="font-semibold text-dark-900 mb-3">Stock Movements (Last 7 days)</h4>
                    <div class="space-y-2">
                        <div class="flex items-center justify-between py-2 border-b border-dark-100">
                            <div>
                                <p class="text-sm text-dark-900">+50 units added</p>
                                <p class="text-xs text-dark-500">Purchased from Parts Direct Inc.</p>
                            </div>
                            <p class="text-xs text-dark-600">Nov 15</p>
                        </div>
                        <div class="flex items-center justify-between py-2 border-b border-dark-100">
                            <div>
                                <p class="text-sm text-dark-900">-25 units sold</p>
                                <p class="text-xs text-dark-500">Order #ORD-2024-001</p>
                            </div>
                            <p class="text-xs text-dark-600">Nov 12</p>
                        </div>
                        <div class="flex items-center justify-between py-2">
                            <div>
                                <p class="text-sm text-dark-900">-10 units damaged</p>
                                <p class="text-xs text-dark-500">Quality issue - replacement pending</p>
                            </div>
                            <p class="text-xs text-dark-600">Nov 10</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Supplier Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Supplier Information</h3>
                <div class="space-y-6">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Primary Supplier</p>
                        <div class="flex items-center space-x-3">
                            <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21H5a2 2 0 01-2-2V5a2 2 0 012-2h11l5 5v11a2 2 0 01-2 2z"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="font-semibold text-dark-900">Parts Direct Inc.</p>
                                <p class="text-sm text-dark-500">SKU: PD-EOF-001-SY</p>
                            </div>
                        </div>
                    </div>

                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4 pt-4 border-t border-dark-200">
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Lead Time</p>
                            <p class="text-dark-900 font-semibold mt-1">5-7 days</p>
                        </div>
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Minimum Order</p>
                            <p class="text-dark-900 font-semibold mt-1">10 units</p>
                        </div>
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Contact</p>
                            <p class="text-dark-900 font-semibold mt-1">sales@partsdirect.com</p>
                        </div>
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Phone</p>
                            <p class="text-dark-900 font-semibold mt-1">+1 (555) 123-4567</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Specifications -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Specifications</h3>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Weight</p>
                        <p class="text-dark-900 font-semibold mt-1">0.45 kg</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Dimensions</p>
                        <p class="text-dark-900 font-semibold mt-1">10cm × 8cm × 8cm</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Material</p>
                        <p class="text-dark-900 font-semibold mt-1">Synthetic Media</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Warranty</p>
                        <p class="text-dark-900 font-semibold mt-1">12 months</p>
                    </div>
                    <div className="md:col-span-2">
                        <p class="text-sm text-dark-500 font-medium">Compatibility</p>
                        <p class="text-dark-900 font-semibold mt-1">Most gasoline & diesel engines, 2000-2024 models</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load part details based on Id
    }
}
