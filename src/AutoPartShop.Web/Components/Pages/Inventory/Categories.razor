@page "/inventory/categories"
@rendermode InteractiveServer
@using AutoPartShop.Web.Services
@using MudBlazor
@inject ICategoryService CategoryService
@inject NavigationManager Navigation
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject Microsoft.Extensions.Logging.ILogger<Categories> Logger
@using AutoPartShop.Web.Components.Dialogs

<PageTitle>Categories - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Product Categories</h1>
            <p class="text-dark-500 mt-1">Manage your multilevel product category hierarchy</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button type="button" class="btn-secondary flex items-center justify-center text-xs" @onclick="TestDialog"
                title="Test Dialog System">
                🧪 Test Dialog
            </button>
            <button class="btn-secondary flex items-center justify-center" @onclick="ImportCategories">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Import
            </button>
            <a href="/inventory/categories/add" class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Add Category

            </a>
        </div>
    </div>
    <!-- Search & Filter Section -->
    <div class="card">
        <div class="space-y-4">
            <h3 class="text-sm font-medium text-dark-900">Search & Filter</h3>
            <div class="flex flex-col sm:flex-row gap-3 items-end">
                <div class="flex-1">
                    <label class="block text-xs font-medium text-dark-600 mb-2">Search Categories</label>
                    <div class="relative">
                        <svg class="absolute left-3 top-1/2 transform -translate-y-1/2 w-5 h-5 text-dark-400 pointer-events-none"
                            fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                        </svg>
                        <input type="text" @bind="SearchTerm" @oninput="@((ChangeEventArgs e) => OnSearchChanged(e))"
                            placeholder="Search by name, code, or description..."
                            class="w-full pl-10 pr-4 py-2 border border-dark-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" />
                    </div>
                </div>
                <div class="flex gap-2">
                    <button @onclick="ClearSearch" disabled="@string.IsNullOrEmpty(SearchTerm)"
                        class="px-4 py-2 border border-dark-300 text-dark-600 rounded-lg text-sm font-medium hover:bg-dark-100 disabled:opacity-50 disabled:cursor-not-allowed transition-colors">
                        <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M6 18L18 6M6 6l12 12"></path>
                        </svg>
                        Clear
                    </button>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(SearchTerm))
            {
                <div class="text-sm text-dark-500 mt-2">
                    Found <span class="font-semibold text-dark-900">@FilteredCategories.Count</span> matching categories
                    @if (FilteredCategories.Count > 0)
                    {
                        <span>• Showing @(IsTreeView ? "in tree view" : "in list view")</span>
                    }
                    @if (FilteredCategories.Count == 0)
                    {
                        <span class="text-orange-600 font-medium">• No results found</span>
                    }
                </div>
            }
        </div>
    </div>

    <!-- View Toggle -->
    <div class="card">
        <div class="flex items-center justify-between">
            <h3 class="text-sm font-medium text-dark-900">View Options</h3>
            <div class="flex gap-2">
                <button @onclick="() => SwitchView(true)"
                    class="@(IsTreeView ? "px-4 py-2 bg-primary-600 text-white rounded-lg text-sm font-medium" : "px-4 py-2 border border-dark-300 text-dark-600 rounded-lg text-sm font-medium hover:bg-dark-100")">
                    <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6a2 2 0 012-2h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6z"></path>
                    </svg>
                    Tree View
                </button>
                <button @onclick="() => SwitchView(false)"
                    class="@(!IsTreeView ? "px-4 py-2 bg-primary-600 text-white rounded-lg text-sm font-medium" : "px-4 py-2 border border-dark-300 text-dark-600 rounded-lg text-sm font-medium hover:bg-dark-100")">
                    <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                    List View
                </button>
            </div>
        </div>
    </div>

    <!-- Loading State -->
    @if (IsLoading)
    {
        <div class="card">
            <div class="flex items-center justify-center py-12">
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-12 h-12 bg-primary-100 rounded-full mb-4">
                        <svg class="w-6 h-6 text-primary-600 animate-spin" fill="none" stroke="currentColor"
                            viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15">
                            </path>
                        </svg>
                    </div>
                    <p class="text-dark-600 font-medium">Loading categories...</p>
                </div>
            </div>
        </div>
    }
    <!-- Error State -->
    @if (!IsLoading && !string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="card border-l-4 border-red-500 bg-red-50">
            <div class="flex items-center gap-4">
                <svg class="w-6 h-6 text-red-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div class="flex-1">
                    <h4 class="font-semibold text-red-900">Error Loading Categories</h4>
                    <p class="text-red-700 text-sm">@ErrorMessage</p>
                </div>
                <button @onclick="LoadCategories" class="btn-secondary text-sm">Retry</button>
            </div>
        </div>
    }
    <!-- Tree View -->
    @if (!IsLoading && IsTreeView && FilteredCategories.Any())
    {
        <div class="card">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-lg font-bold text-dark-900">Category Hierarchy</h3>
                <div class="flex gap-2">
                    <button @onclick="ExpandAll" class="text-sm text-dark-600 hover:text-dark-900 font-medium">Expand
                        All</button>
                    <span class="text-dark-300">|</span>
                    <button @onclick="CollapseAll" class="text-sm text-dark-600 hover:text-dark-900 font-medium">Collapse
                        All</button>
                </div>
            </div>

            <div class="space-y-2 max-h-[600px] overflow-y-auto pr-2">
                @foreach (var category in FilteredCategories.Where(c => c.ParentCategoryId == null).OrderBy(c =>
                            c.DisplayOrder))
                {
                    @RenderCategoryNode(category, 0)
                }
            </div>
        </div>
    }
    <!-- List View with Infinite Scroll -->
    @if (!IsLoading && !IsTreeView && FilteredCategories.Any())
    {
        <div class="card">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-lg font-bold text-dark-900">All Categories</h3>
                <div class="text-sm text-dark-500">Showing: @DisplayedCategoriesCount / @FilteredCategories.Count
                    @(string.IsNullOrEmpty(SearchTerm) ? "total" : "matching")</div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-dark-200 sticky top-0 bg-white">
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Name</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Code</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Breadcrumb Path</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Level</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Status</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in FilteredCategories.Take(DisplayedCategoriesCount))
                        {
                            <tr class="border-b border-dark-100 hover:bg-dark-50 transition-colors">
                                <td class="px-4 py-3">
                                    <div class="flex items-center space-x-2">
                                        <div
                                            class="w-2 h-2 rounded-full @(category.ParentCategoryId == null ? "bg-primary-600" : "bg-blue-400")">
                                        </div>
                                        <span class="font-medium text-dark-900">
                                            @if (category.ParentCategoryId.HasValue)
                                            {
                                                <span class="text-dark-500">└─ </span>
                                            }
                                            @category.Name
                                        </span>
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-sm text-dark-600">@category.Code</td>
                                <td class="px-4 py-3 text-sm text-dark-600">
                                    <span class="text-xs font-mono text-dark-500">@category.BreadcrumbPath</span>
                                </td>
                                <td class="px-4 py-3 text-sm">
                                    <span
                                        class="px-3 py-1 @(category.ParentCategoryId == null ? "bg-primary-100 text-primary-700" : "bg-blue-100 text-blue-700") rounded-full text-xs font-medium">
                                        L@(category.DepthLevel + 1)
                                        @if (category.ChildCount > 0)
                                        {
                                            <span class="ml-1">(@category.ChildCount)</span>
                                        }
                                    </span>
                                </td>
                                <td class="px-4 py-3 text-sm">
                                    @if (category.IsActive)
                                    {
                                        <span
                                            class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Active</span>
                                    }
                                    else
                                    {
                                        <span
                                            class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-xs font-medium">Inactive</span>
                                    }
                                </td>
                                <td class="px-4 py-3 text-sm">
                                    <div class="flex gap-2">
                                        <button type="button" @onclick="@(async () => await ViewCategory(category.Id))"
                                            class="text-primary-600 hover:text-primary-700 font-medium">View</button>
                                        <button type="button" @onclick="@(async () => await EditCategory(category.Id))"
                                            class="text-blue-600 hover:text-blue-700 font-medium">Edit</button>
                                        <button type="button" @onclick="@(async () => await HandleDeleteClick(category.Id))"
                                            class="text-red-600 hover:text-red-700 font-medium">Delete</button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>

            <!-- Load More Section -->
            @if (DisplayedCategoriesCount < FilteredCategories.Count)
            {
                <div class="mt-6 flex flex-col items-center gap-4">
                    <div class="text-sm text-dark-500">
                        Showing @DisplayedCategoriesCount of @FilteredCategories.Count @(string.IsNullOrEmpty(SearchTerm) ?
                                        "total" : "matching")
                    </div>
                    @if (IsLoadingMore)
                    {
                        <div class="flex items-center justify-center">
                            <svg class="w-6 h-6 text-primary-600 animate-spin" fill="none" stroke="currentColor"
                                viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15">
                                </path>
                            </svg>
                            <span class="ml-2 text-dark-600">Loading more categories...</span>
                        </div>
                    }
                    <button @onclick="LoadMoreCategories" disabled="@IsLoadingMore"
                        class="px-6 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 disabled:opacity-50 disabled:cursor-not-allowed">
                        Load More Categories
                    </button>
                </div>
            }
        </div>
    }
    <!-- No Search Results State -->
    @if (!IsLoading && !string.IsNullOrEmpty(SearchTerm) && !FilteredCategories.Any())
    {
        <div class="card">
            <div class="flex flex-col items-center justify-center py-12 text-center">
                <svg class="w-16 h-16 text-orange-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <h3 class="text-lg font-semibold text-dark-900 mb-2">No matching categories</h3>
                <p class="text-dark-500 mb-6">Your search "<span class="font-semibold text-dark-900">@SearchTerm</span>"
                    didn't match any categories</p>
                <button @onclick="ClearSearch" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12">
                        </path>
                    </svg>
                    Clear Search
                </button>
            </div>
        </div>
    }
    <!-- Empty State - No Categories At All -->
    @if (!IsLoading && string.IsNullOrEmpty(ErrorMessage) && !CategoryList.Any())
    {
        <div class="card">
            <div class="flex flex-col items-center justify-center py-12 text-center">
                <svg class="w-16 h-16 text-dark-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z">
                    </path>
                </svg>
                <h3 class="text-lg font-semibold text-dark-900 mb-2">No categories found</h3>
                <p class="text-dark-500 mb-6">Start by creating your first category to organize your products</p>
                <a href="/inventory/categories/add" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Create First Category
                </a>
            </div>
        </div>
    }

    <!-- Stats Section -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <div class="card">
            <div class="flex items-center">
                <div class="flex-shrink-0 w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M7 7a7 7 0 110 14 7 7 0 010-14z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm text-dark-500 font-medium">Total Categories</p>
                    <p class="text-2xl font-bold text-dark-900">@CategoryList.Count</p>
                    <p class="text-xs text-dark-500 mt-1">Including all levels</p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="flex items-center">
                <div class="flex-shrink-0 w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm text-dark-500 font-medium">Root Categories</p>
                    <p class="text-2xl font-bold text-dark-900">@CategoryList.Count(c => c.ParentCategoryId == null)</p>
                    <p class="text-xs text-dark-500 mt-1">Top level items</p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="flex items-center">
                <div class="flex-shrink-0 w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm text-dark-500 font-medium">Subcategories</p>
                    <p class="text-2xl font-bold text-dark-900">@CategoryList.Count(c => c.ParentCategoryId != null)</p>
                    <p class="text-xs text-dark-500 mt-1">Child categories</p>
                </div>
            </div>
        </div>

        <div class="card">
            <div class="flex items-center">
                <div class="flex-shrink-0 w-12 h-12 bg-yellow-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-yellow-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
                <div class="ml-4">
                    <p class="text-sm text-dark-500 font-medium">Active</p>
                    <p class="text-2xl font-bold text-dark-900">@CategoryList.Count(c => c.IsActive)</p>
                    <p class="text-xs text-dark-500 mt-1">Active categories</p>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private List<CategoryDto> CategoryList = new();
    private List<CategoryDto> SortedCategories = new();
    private List<CategoryDto> FilteredCategories = new();
    private HashSet<Guid> ExpandedCategories = new();
    private bool IsLoading = true;
    private bool IsTreeView = true;
    private bool IsLoadingMore = false;
    private string ErrorMessage = string.Empty;
    private string SearchTerm = string.Empty;

    // Pagination settings
    private const int InitialDisplayCount = 15;
    private const int LoadMoreCount = 10;
    private int DisplayedCategoriesCount = InitialDisplayCount;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }
    private async Task LoadCategories()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = string.Empty;
            CategoryList = new();
            SortedCategories = new();
            ExpandedCategories.Clear();
            DisplayedCategoriesCount = InitialDisplayCount;
            SearchTerm = string.Empty;
            StateHasChanged();

            var response = await CategoryService.GetAllCategoriesAsync();
            if (response != null)
            {
                CategoryList = response.ToList();
                // Sort categories for list view
                SortedCategories = CategoryList.OrderBy(c => c.DisplayOrder).ThenBy(c => c.Name).ToList();
                // Initialize filtered categories with all categories
                ApplyFilters();

                // Expand first level by default
                foreach (var category in CategoryList.Where(c => c.ParentCategoryId == null))
                {
                    ExpandedCategories.Add(category.Id);
                }
            }
        }
        catch (ServiceException ex)
        {
            ErrorMessage = $"Failed to load categories: {ex.Message}";
            CategoryList = new();
            SortedCategories = new();
            FilteredCategories = new();
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
            CategoryList = new();
            SortedCategories = new();
            FilteredCategories = new();
        }
        finally
        {
            IsLoading = false;
            StateHasChanged();
        }
    }

    private void ApplyFilters()
    {
        if (string.IsNullOrWhiteSpace(SearchTerm))
        {
            FilteredCategories = CategoryList.ToList();
        }
        else
        {
            var searchLower = SearchTerm.ToLower();
            FilteredCategories = CategoryList
            .Where(c => c.Name.ToLower().Contains(searchLower) ||
            c.Code.ToLower().Contains(searchLower) ||
            c.Description?.ToLower().Contains(searchLower) == true ||
            (c.SubCategories?.Any(sc => sc.Name.ToLower().Contains(searchLower) ||
            sc.Code.ToLower().Contains(searchLower)) == true))
            .ToList();
        }

        // Sort to ensure parent categories appear before their subcategories
        FilteredCategories = SortCategoriesByHierarchy(FilteredCategories);
        DisplayedCategoriesCount = InitialDisplayCount;
    }

    private List<CategoryDto> SortCategoriesByHierarchy(List<CategoryDto> categories)
    {
        var sorted = new List<CategoryDto>();
        var categoriesById = categories.ToDictionary(c => c.Id);
        var processed = new HashSet<Guid>();

        // First add all root categories in order
        var rootCategories = categories
        .Where(c => c.ParentCategoryId == null)
        .OrderBy(c => c.DisplayOrder)
        .ThenBy(c => c.Name)
        .ToList();

        foreach (var root in rootCategories)
        {
            AddCategoryAndChildren(root, categories, sorted, processed);
        }

        // Add any orphaned categories (shouldn't happen, but safety check)
        foreach (var category in categories)
        {
            if (!processed.Contains(category.Id))
            {
                sorted.Add(category);
                processed.Add(category.Id);
            }
        }

        return sorted;
    }

    private void AddCategoryAndChildren(CategoryDto category, List<CategoryDto> allCategories, List<CategoryDto> sorted,
    HashSet<Guid> processed)
    {
        if (processed.Contains(category.Id))
            return;

        sorted.Add(category);
        processed.Add(category.Id);

        // Add children in order
        var children = allCategories
        .Where(c => c.ParentCategoryId == category.Id)
        .OrderBy(c => c.DisplayOrder)
        .ThenBy(c => c.Name)
        .ToList();

        foreach (var child in children)
        {
            AddCategoryAndChildren(child, allCategories, sorted, processed);
        }
    }

    private void OnSearchChanged(ChangeEventArgs e)
    {
        SearchTerm = e.Value?.ToString() ?? string.Empty;
        ApplyFilters();
        StateHasChanged();
    }

    private void ClearSearch()
    {
        SearchTerm = string.Empty;
        ApplyFilters();
        StateHasChanged();
    }

    private async Task LoadMoreCategories()
    {
        IsLoadingMore = true;
        StateHasChanged();

        // Simulate loading delay
        await Task.Delay(300);

        DisplayedCategoriesCount = Math.Min(
        DisplayedCategoriesCount + LoadMoreCount,
        CategoryList.Count
        );

        IsLoadingMore = false;
        StateHasChanged();
    }

    private void SwitchView(bool treeView)
    {
        IsTreeView = treeView;
    }

    private void ImportCategories()
    {
        Snackbar.Add("Import feature coming soon", Severity.Info);
    }

    private void ExpandAll()
    {
        foreach (var category in CategoryList)
        {
            ExpandedCategories.Add(category.Id);
        }
    }

    private void CollapseAll()
    {
        ExpandedCategories.Clear();
    }

    private Task ToggleExpand(Guid categoryId)
    {
        if (ExpandedCategories.Contains(categoryId))
        {
            ExpandedCategories.Remove(categoryId);
        }
        else
        {
            ExpandedCategories.Add(categoryId);
        }
        return Task.CompletedTask;
    }

    private Task ViewCategory(Guid id)
    {
        Logger.LogInformation($"[Categories] ViewCategory called for ID: {id}");
        Console.WriteLine($"[Categories] ViewCategory called for ID: {id}");
        Navigation.NavigateTo($"/inventory/categories/{id}");
        return Task.CompletedTask;
    }

    private Task EditCategory(Guid id)
    {
        Logger.LogInformation($"[Categories] EditCategory called for ID: {id}");
        Console.WriteLine($"[Categories] EditCategory called for ID: {id}");
        Navigation.NavigateTo($"/inventory/categories/{id}/edit");
        return Task.CompletedTask;
    }

    private async Task TestDialog()
    {
        Console.WriteLine("[Categories] TEST DIALOG BUTTON CLICKED");
        Logger.LogInformation("[Categories] TEST DIALOG BUTTON CLICKED");

        var parameters = new DialogParameters<ConfirmDialog>
{
{ nameof(ConfirmDialog.ContentText), "This is a TEST dialog. If you see this, the dialog system is working! Click Cancel to close." }
};

        Console.WriteLine("[Categories] TEST: Calling DialogService.ShowAsync...");
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("TEST Dialog", parameters);

        Console.WriteLine("[Categories] TEST: Dialog shown, awaiting result...");
        var result = await dialog.Result;

        Console.WriteLine($"[Categories] TEST: Dialog result received. Canceled: {result?.Canceled}");
        Snackbar.Add("Test dialog completed successfully!", Severity.Success);
    }

    private async Task HandleDeleteClick(Guid id)
    {
        Console.WriteLine($"[Categories] Delete button clicked for ID: {id}");
        await DeleteCategory(id);
    }

    private async Task DeleteCategory(Guid id)
    {
        Logger.LogInformation($"[Categories] DeleteCategory called for ID: {id}");
        Console.WriteLine($"[Categories] DeleteCategory called for ID: {id}");
        Console.WriteLine($"[Categories] DialogService is: {(DialogService != null ? "NOT NULL" : "NULL")}");

        try
        {
            var parameters = new DialogParameters<ConfirmDialog>
{
{ nameof(ConfirmDialog.ContentText), "Are you sure you want to delete this category? This action cannot be undone." }
};

            Console.WriteLine($"[Categories] Calling DialogService.ShowAsync...");

            if (DialogService == null)
            {
                Logger.LogError("[Categories] DialogService is null. Cannot show confirmation dialog.");
                Console.WriteLine("[Categories] DialogService is null. Cannot show confirmation dialog.");
                Snackbar.Add("Unable to show confirmation dialog.", Severity.Error);
                return;
            }

            var dialog = await DialogService.ShowAsync<ConfirmDialog>("Confirm Delete", parameters);

            if (dialog == null)
            {
                Logger.LogError("[Categories] DialogService returned a null dialog reference.");
                Console.WriteLine("[Categories] DialogService returned a null dialog reference.");
                Snackbar.Add("Failed to open confirmation dialog.", Severity.Error);
                return;
            }

            Console.WriteLine($"[Categories] Dialog shown, awaiting result...");
            var result = await dialog.Result;

            Console.WriteLine($"[Categories] Dialog result object: {(result == null ? "NULL" : "NOT NULL")}");
            Console.WriteLine($"[Categories] Dialog result.Canceled: {result?.Canceled}");
            Console.WriteLine($"[Categories] Dialog result.Data: {result?.Data}");
            Logger.LogInformation($"[Categories] Delete dialog result - Canceled: {result?.Canceled}");
            Console.WriteLine($"[Categories] Delete dialog result - Canceled: {result?.Canceled}");

            if (result?.Canceled != true)
            {
                try
                {
                    Logger.LogInformation($"[Categories] Proceeding with deletion for ID: {id}");
                    Console.WriteLine($"[Categories] Calling DeleteCategoryAsync for ID: {id}");
                    await CategoryService.DeleteCategoryAsync(id);
                    Logger.LogInformation($"[Categories] Category deleted successfully: {id}");
                    Console.WriteLine($"[Categories] Category deleted successfully: {id}");
                    Snackbar.Add("Category deleted successfully", Severity.Success);
                    await LoadCategories();
                    StateHasChanged();
                }
                catch (ServiceException ex)
                {
                    ErrorMessage = $"Error deleting category: {ex.Message}";
                    Logger.LogError($"[Categories] ServiceException during deletion: {ex.Message}");
                    Console.WriteLine($"[Categories] ServiceException: {ex.Message}");
                    Snackbar.Add($"Error: {ex.Message}", Severity.Error);
                    StateHasChanged();
                }
                catch (Exception ex)
                {
                    ErrorMessage = $"An unexpected error occurred: {ex.Message}";
                    Logger.LogError($"[Categories] Unexpected exception during deletion: {ex.Message}");
                    Console.WriteLine($"[Categories] Unexpected exception: {ex.GetType().Name} - {ex.Message}");
                    Snackbar.Add($"Error: {ex.Message}", Severity.Error);
                    StateHasChanged();
                }
            }
            else
            {
                Logger.LogInformation($"[Categories] Delete operation canceled by user for ID: {id}");
                Console.WriteLine($"[Categories] Delete operation canceled by user for ID: {id}");
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"[Categories] CRITICAL ERROR in DeleteCategory: {ex.GetType().Name} - {ex.Message}");
            Logger.LogError($"[Categories] CRITICAL ERROR in DeleteCategory: {ex.Message}");
            Snackbar.Add($"Error showing delete confirmation: {ex.Message}", Severity.Error);
            StateHasChanged();
        }
    }

    /// <summary>
    /// Recursively renders category nodes with proper nesting for tree view
    /// </summary>
    private RenderFragment RenderCategoryNode(CategoryDto category, int depth) => __builder =>
    {
        <div class="border border-dark-200 rounded-lg overflow-hidden mb-2" style="margin-left: @(depth * 16)px;">
            <div class="flex items-center hover:bg-primary-50 transition-colors">
                <!-- Expand/Collapse Button -->
                <button @onclick="() => ToggleExpand(category.Id)"
                    disabled="@(category.SubCategories?.Any() != true ||
                                                                   (!string.IsNullOrEmpty(SearchTerm) &&
                                                                    !category.SubCategories.Any(sc => sc.Name.ToLower().Contains(SearchTerm.ToLower()) ||
                                                                                                     sc.Code.ToLower().Contains(SearchTerm.ToLower()))))"
                    class="p-3 text-dark-600 hover:text-dark-900 flex-shrink-0 disabled:opacity-40 disabled:cursor-not-allowed">
                    @if (category.SubCategories?.Any() == true)
                    {
                        <svg class="w-5 h-5 transition-transform @(ExpandedCategories?.Contains(category.Id) == true ? "rotate-90" : "")"
                            fill="currentColor" viewBox="0 0 24 24">
                            <path d="M7 10l5 5 5-5z"></path>
                        </svg>
                    }
                    else
                    {
                        <span class="w-5 h-5 inline-block"></span>
                    }
                </button>

                <!-- Category Content -->
                <div class="flex-1 py-3 px-2">
                    <div class="flex items-center space-x-3">
                        <div
                            class="w-8 h-8 bg-gradient-to-br from-primary-400 to-primary-600 rounded flex items-center justify-center flex-shrink-0">
                            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M20 7l-8-4-8 4m0 0l8-4 8 4m0 0v10l-8 4-8-4V7m8 4v10m-8-4l8 4 8-4"></path>
                            </svg>
                        </div>
                        <div class="flex-1 min-w-0">
                            <p class="font-semibold text-dark-900">@category.Name</p>
                            <p class="text-xs text-dark-500">
                                @category.Code
                                @if (category.SubCategories?.Any() == true)
                                {
                                    var totalSubs = category.SubCategories.Count;
                                    var visibleSubs = string.IsNullOrEmpty(SearchTerm)
                                ? totalSubs
                                : category.SubCategories.Count(sc =>
                                sc.Name.ToLower().Contains(SearchTerm.ToLower()) ||
                                sc.Code.ToLower().Contains(SearchTerm.ToLower()));

                                    @if (visibleSubs == totalSubs)
                                    {
                                        <span>• @totalSubs subcategories</span>
                                    }
                                    else
                                    {
                                        <span>• @visibleSubs/@totalSubs subcategories</span>
                                        <span class="text-orange-600 font-medium">(filtered)</span>
                                    }
                                }
                                else
                                {
                                    <span>• No subcategories</span>
                                }
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Status Badge -->
                <div class="px-2 flex-shrink-0">
                    @if (category.IsActive)
                    {
                        <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Active</span>
                    }
                    else
                    {
                        <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-xs font-medium">Inactive</span>
                    }
                </div>

                <!-- Action Buttons -->
                <div class="px-4 py-3 flex gap-2 flex-shrink-0">
                    <button type="button" @onclick="@(async () => await ViewCategory(category.Id))"
                        class="text-primary-600 hover:text-primary-700 font-medium text-sm" title="View Category">View</button>
                    <button type="button" @onclick="@(async () => await EditCategory(category.Id))"
                        class="text-blue-600 hover:text-blue-700 font-medium text-sm" title="Edit Category">Edit</button>
                    <button type="button" @onclick="@(async () => await HandleDeleteClick(category.Id))"
                        class="text-red-600 hover:text-red-700 font-medium text-sm" title="Delete Category">Delete</button>
                </div>
            </div>

            <!-- Subcategories (Recursive) -->
            @if (ExpandedCategories?.Contains(category.Id) == true && category.SubCategories?.Any() == true)
            {
                var visibleSubCategories = string.IsNullOrEmpty(SearchTerm)
            ? category.SubCategories.OrderBy(c => c.DisplayOrder).ToList()
            : category.SubCategories
            .Where(sc => sc.Name.ToLower().Contains(SearchTerm.ToLower()) ||
            sc.Code.ToLower().Contains(SearchTerm.ToLower()))
            .OrderBy(c => c.DisplayOrder)
            .ToList();

                @if (visibleSubCategories.Any())
                {
                    <div class="bg-dark-50 border-t border-dark-200">
                        @foreach (var subCategory in visibleSubCategories)
                        {
                            @RenderCategoryNode(subCategory, depth + 1)
                        }
                    </div>
                }
            }
        </div>
    };
}