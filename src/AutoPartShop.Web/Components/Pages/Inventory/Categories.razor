@page "/inventory/categories"
@using AutoPartShop.Web.Services
@inject ICategoryService CategoryService
@inject NavigationManager Navigation

<PageTitle>Categories - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Product Categories</h1>
            <p class="text-dark-500 mt-1">Manage your multilevel product category hierarchy</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Import
            </button>
            <a href="/inventory/categories/add" class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Add Category
            </a>
        </div>
    </div>

    <!-- View Toggle -->
    <div class="card">
        <div class="flex items-center justify-between">
            <h3 class="text-sm font-medium text-dark-900">View Options</h3>
            <div class="flex gap-2">
                <button @onclick="() => SwitchView(true)" class="@(IsTreeView ? "px-4 py-2 bg-primary-600 text-white rounded-lg text-sm font-medium" : "px-4 py-2 border border-dark-300 text-dark-600 rounded-lg text-sm font-medium hover:bg-dark-100")">
                    <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h12a2 2 0 012 2v12a2 2 0 01-2 2H6a2 2 0 01-2-2V6z"></path>
                    </svg>
                    Tree View
                </button>
                <button @onclick="() => SwitchView(false)" class="@(!IsTreeView ? "px-4 py-2 bg-primary-600 text-white rounded-lg text-sm font-medium" : "px-4 py-2 border border-dark-300 text-dark-600 rounded-lg text-sm font-medium hover:bg-dark-100")">
                    <svg class="w-4 h-4 inline-block mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
                    </svg>
                    List View
                </button>
            </div>
        </div>
    </div>

    <!-- Loading State -->
    @if (IsLoading)
    {
        <div class="card">
            <div class="flex items-center justify-center py-12">
                <div class="text-center">
                    <div class="inline-flex items-center justify-center w-12 h-12 bg-primary-100 rounded-full mb-4">
                        <svg class="w-6 h-6 text-primary-600 animate-spin" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                        </svg>
                    </div>
                    <p class="text-dark-600 font-medium">Loading categories...</p>
                </div>
            </div>
        </div>
    }
    <!-- Error State -->
    else if (!string.IsNullOrEmpty(ErrorMessage))
    {
        <div class="card border-l-4 border-red-500 bg-red-50">
            <div class="flex items-center gap-4">
                <svg class="w-6 h-6 text-red-600 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <div class="flex-1">
                    <h4 class="font-semibold text-red-900">Error Loading Categories</h4>
                    <p class="text-red-700 text-sm">@ErrorMessage</p>
                </div>
                <button @onclick="LoadCategories" class="btn-secondary text-sm">Retry</button>
            </div>
        </div>
    }
    <!-- Tree View -->
    else if (IsTreeView && CategoryList.Any())
    {
        <div class="card">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-lg font-bold text-dark-900">Category Hierarchy</h3>
                <div class="flex gap-2">
                    <button @onclick="ExpandAll" class="text-sm text-dark-600 hover:text-dark-900 font-medium">Expand All</button>
                    <span class="text-dark-300">|</span>
                    <button @onclick="CollapseAll" class="text-sm text-dark-600 hover:text-dark-900 font-medium">Collapse All</button>
                </div>
            </div>

            <div class="space-y-2">
                @foreach (var category in CategoryList.Where(c => c.ParentCategoryId == null).OrderBy(c => c.DisplayOrder))
                {
                    <CategoryTreeItem Category="category" AllCategories="CategoryList"
                        OnEdit="EditCategory" OnDelete="DeleteCategory" OnView="ViewCategory"
                        ExpandedCategories="ExpandedCategories" OnToggleExpand="ToggleExpand" />
                }
            </div>
        </div>
    }
    <!-- List View -->
    else if (!IsTreeView && CategoryList.Any())
    {
        <div class="card">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-lg font-bold text-dark-900">All Categories</h3>
                <div class="text-sm text-dark-500">Total: @CategoryList.Count</div>
            </div>

            <div class="overflow-x-auto">
                <table class="w-full">
                    <thead>
                        <tr class="border-b border-dark-200">
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Name</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Code</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Type</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Status</th>
                            <th class="px-4 py-3 text-left text-sm font-semibold text-dark-900">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var category in CategoryList.OrderBy(c => c.DisplayOrder).ThenBy(c => c.Name))
                        {
                            <tr class="border-b border-dark-100 hover:bg-dark-50 transition-colors">
                                <td class="px-4 py-3">
                                    <div class="flex items-center space-x-2">
                                        <div class="w-2 h-2 rounded-full @(category.ParentCategoryId == null ? "bg-primary-600" : "bg-blue-400")"></div>
                                        <span class="font-medium text-dark-900">
                                            @if (category.ParentCategoryId.HasValue)
                                            {
                                                <span class="text-dark-500">└─ </span>
                                            }
                                            @category.Name
                                        </span>
                                    </div>
                                </td>
                                <td class="px-4 py-3 text-sm text-dark-600">@category.Code</td>
                                <td class="px-4 py-3 text-sm text-dark-600">
                                    @if (category.ParentCategoryId == null)
                                    {
                                        <span class="px-3 py-1 bg-primary-100 text-primary-700 rounded-full text-xs font-medium">Root</span>
                                    }
                                    else
                                    {
                                        <span class="px-3 py-1 bg-blue-100 text-blue-700 rounded-full text-xs font-medium">Sub</span>
                                    }
                                </td>
                                <td class="px-4 py-3 text-sm">
                                    @if (category.IsActive)
                                    {
                                        <span class="px-3 py-1 bg-green-100 text-green-700 rounded-full text-xs font-medium">Active</span>
                                    }
                                    else
                                    {
                                        <span class="px-3 py-1 bg-gray-100 text-gray-700 rounded-full text-xs font-medium">Inactive</span>
                                    }
                                </td>
                                <td class="px-4 py-3 flex gap-2">
                                    <button @onclick="() => ViewCategory(category.Id)" class="text-primary-600 hover:text-primary-700 text-sm font-medium">View</button>
                                    <button @onclick="() => EditCategory(category.Id)" class="text-blue-600 hover:text-blue-700 text-sm font-medium">Edit</button>
                                    <button @onclick="() => DeleteCategory(category.Id)" class="text-red-600 hover:text-red-700 text-sm font-medium">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
    <!-- Empty State -->
    else if (!IsLoading)
    {
        <div class="card">
            <div class="flex flex-col items-center justify-center py-12">
                <svg class="w-16 h-16 text-dark-300 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m0 0l8-4 8 4m0 0v10l-8 4-8-4V7m8 4v10m-8-4l8 4 8-4"></path>
                </svg>
                <h4 class="text-lg font-semibold text-dark-900 mb-2">No Categories Found</h4>
                <p class="text-dark-500 mb-6">Start by creating your first product category</p>
                <a href="/inventory/categories/add" class="btn-primary">Create First Category</a>
            </div>
        </div>
    }

    <!-- Stats Section -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="card-sm border-l-4 border-primary-500">
            <h4 class="font-semibold text-dark-900 mb-3">Total Categories</h4>
            <p class="text-3xl font-bold text-primary-600">@CategoryList.Count</p>
            <p class="text-dark-500 text-xs mt-2">Including all levels</p>
        </div>

        <div class="card-sm border-l-4 border-blue-500">
            <h4 class="font-semibold text-dark-900 mb-3">Root Categories</h4>
            <p class="text-3xl font-bold text-blue-600">@CategoryList.Count(c => c.ParentCategoryId == null)</p>
            <p class="text-dark-500 text-xs mt-2">Top level items</p>
        </div>

        <div class="card-sm border-l-4 border-green-500">
            <h4 class="font-semibold text-dark-900 mb-3">Subcategories</h4>
            <p class="text-3xl font-bold text-green-600">@CategoryList.Count(c => c.ParentCategoryId != null)</p>
            <p class="text-dark-500 text-xs mt-2">Child categories</p>
        </div>

        <div class="card-sm border-l-4 border-orange-500">
            <h4 class="font-semibold text-dark-900 mb-3">Active</h4>
            <p class="text-3xl font-bold text-orange-600">@CategoryList.Count(c => c.IsActive)</p>
            <p class="text-dark-500 text-xs mt-2">Active categories</p>
        </div>
    </div>
</div>

@code {
    private List<CategoryDto> CategoryList = new();
    private HashSet<Guid> ExpandedCategories = new();
    private bool IsLoading = true;
    private bool IsTreeView = true;
    private string ErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadCategories();
    }

    private async Task LoadCategories()
    {
        try
        {
            IsLoading = true;
            ErrorMessage = string.Empty;
            CategoryList = new();
            ExpandedCategories.Clear();

            var response = await CategoryService.GetAllCategoriesAsync();
            if (response != null)
            {
                CategoryList = response.ToList();
                // Expand first level by default
                foreach (var category in CategoryList.Where(c => c.ParentCategoryId == null))
                {
                    ExpandedCategories.Add(category.Id);
                }
            }
        }
        catch (ServiceException ex)
        {
            ErrorMessage = $"Failed to load categories: {ex.Message}";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An error occurred: {ex.Message}";
        }
        finally
        {
            IsLoading = false;
        }
    }

    private void SwitchView(bool treeView)
    {
        IsTreeView = treeView;
    }

    private void ExpandAll()
    {
        foreach (var category in CategoryList)
        {
            ExpandedCategories.Add(category.Id);
        }
    }

    private void CollapseAll()
    {
        ExpandedCategories.Clear();
    }

    private void ToggleExpand(Guid categoryId)
    {
        if (ExpandedCategories.Contains(categoryId))
        {
            ExpandedCategories.Remove(categoryId);
        }
        else
        {
            ExpandedCategories.Add(categoryId);
        }
    }

    private void ViewCategory(Guid id)
    {
        Navigation.NavigateTo($"/inventory/categories/view/{id}");
    }

    private void EditCategory(Guid id)
    {
        Navigation.NavigateTo($"/inventory/categories/edit/{id}");
    }

    private async Task DeleteCategory(Guid id)
    {
        if (!await ConfirmDelete()) return;

        try
        {
            await CategoryService.DeleteCategoryAsync(id);
            await LoadCategories();
        }
        catch (ServiceException ex)
        {
            ErrorMessage = $"Error deleting category: {ex.Message}";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"An unexpected error occurred: {ex.Message}";
        }
    }

    private async Task<bool> ConfirmDelete()
    {
        // In a real app, use a confirmation dialog
        return await Task.FromResult(true);
    }
}
