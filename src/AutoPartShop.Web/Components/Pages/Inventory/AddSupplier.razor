@page "/inventory/suppliers/add"
@rendermode InteractiveServer

<PageTitle>Add New Supplier - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Add New Supplier</h1>
            <p class="text-dark-500 mt-1">Register a new supplier in your network</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Create Supplier
            </button>
        </div>
    </div>

    <!-- Add Supplier Form -->
    <form class="space-y-6">
        <!-- Basic Information Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Basic Information</h3>
            <div class="space-y-6">
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Supplier Name *</label>
                        <input type="text" placeholder="e.g., Parts Direct Inc." class="input-field" required />
                        <p class="text-xs text-dark-500 mt-1">Official business name</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Supplier Code</label>
                        <input type="text" placeholder="e.g., SUP-001" class="input-field" />
                        <p class="text-xs text-dark-500 mt-1">Auto-generated if left empty</p>
                    </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Category *</label>
                        <select class="input-field" required>
                            <option value="">-- Select category --</option>
                            <option value="distributor">Distributor</option>
                            <option value="manufacturer">Manufacturer</option>
                            <option value="wholesaler">Wholesaler</option>
                            <option value="importer">Importer</option>
                            <option value="retailer">Retailer</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Country/Region *</label>
                        <select class="input-field" required>
                            <option value="">-- Select country --</option>
                            <option value="usa">United States</option>
                            <option value="uk">United Kingdom</option>
                            <option value="japan">Japan</option>
                            <option value="germany">Germany</option>
                            <option value="canada">Canada</option>
                            <option value="india">India</option>
                            <option value="other">Other</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Company Description</label>
                    <textarea rows="4" class="input-field" placeholder="Describe the supplier's business..."></textarea>
                    <p class="text-xs text-dark-500 mt-1">Brief overview of their services and specialties</p>
                </div>
            </div>
        </div>

        <!-- Contact Information Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Contact Information</h3>
            <div className="space-y-6">
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Primary Contact Name *</label>
                        <input type="text" placeholder="Full name" class="input-field" required />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Title/Position</label>
                        <input type="text" placeholder="e.g., Sales Manager" class="input-field" />
                    </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Email Address *</label>
                        <input type="email" placeholder="email@supplier.com" class="input-field" required />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Phone Number *</label>
                        <input type="tel" placeholder="+1 (555) 123-4567" class="input-field" required />
                    </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Website</label>
                        <input type="url" placeholder="https://www.supplier.com" class="input-field" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Alternative Contact</label>
                        <input type="tel" placeholder="+1 (555) 987-6543" class="input-field" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Address Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Address Information</h3>
            <div className="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Street Address *</label>
                    <input type="text" placeholder="Street address" class="input-field" required />
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">City *</label>
                        <input type="text" placeholder="City" class="input-field" required />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">State/Province</label>
                        <input type="text" placeholder="State" class="input-field" />
                    </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Postal Code *</label>
                        <input type="text" placeholder="Postal code" class="input-field" required />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Country *</label>
                        <input type="text" placeholder="Country" class="input-field" required />
                    </div>
                </div>
            </div>
        </div>

        <!-- Business Terms Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Business Terms</h3>
            <div className="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Average Lead Time (Days) *</label>
                    <input type="number" placeholder="5" class="input-field" required />
                    <p class="text-xs text-dark-500 mt-1">Typical delivery time</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Minimum Order Quantity *</label>
                    <input type="number" placeholder="10" class="input-field" required />
                    <p class="text-xs text-dark-500 mt-1">Minimum units per order</p>
                </div>
            </div>

            <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Payment Terms</label>
                    <select class="input-field">
                        <option value="">-- Select terms --</option>
                        <option value="net30">Net 30</option>
                        <option value="net60">Net 60</option>
                        <option value="prepaid">Prepaid</option>
                        <option value="cod">Cash on Delivery</option>
                        <option value="custom">Custom</option>
                    </select>
                </div>
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Currency Preference</label>
                    <select class="input-field">
                        <option value="">-- Select currency --</option>
                        <option value="usd">USD ($)</option>
                        <option value="eur">EUR (€)</option>
                        <option value="gbp">GBP (£)</option>
                        <option value="jpy">JPY (¥)</option>
                        <option value="other">Other</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Product Categories Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Product Categories</h3>
            <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="checkbox" class="w-4 h-4 rounded border-dark-300" checked />
                    <span class="text-sm font-medium text-dark-900">Filters</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="checkbox" class="w-4 h-4 rounded border-dark-300" />
                    <span class="text-sm font-medium text-dark-900">Brake System</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="checkbox" class="w-4 h-4 rounded border-dark-300" />
                    <span class="text-sm font-medium text-dark-900">Engine Components</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="checkbox" class="w-4 h-4 rounded border-dark-300" />
                    <span class="text-sm font-medium text-dark-900">Transmission</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="checkbox" class="w-4 h-4 rounded border-dark-300" />
                    <span class="text-sm font-medium text-dark-900">Suspension</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="checkbox" class="w-4 h-4 rounded border-dark-300" />
                    <span class="text-sm font-medium text-dark-900">Electrical</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="checkbox" class="w-4 h-4 rounded border-dark-300" />
                    <span class="text-sm font-medium text-dark-900">Cooling System</span>
                </label>
                <label class="flex items-center space-x-3 cursor-pointer">
                    <input type="checkbox" class="w-4 h-4 rounded border-dark-300" />
                    <span class="text-sm font-medium text-dark-900">Fluids</span>
                </label>
            </div>
        </div>

        <!-- Additional Information -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Additional Information</h3>
            <div className="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Tax ID / VAT Number</label>
                    <input type="text" placeholder="Tax or VAT identification" class="input-field" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Notes & Special Requirements</label>
                    <textarea rows="3" class="input-field" placeholder="Any special notes or requirements..."></textarea>
                </div>

                <div>
                    <label class="flex items-center space-x-3 cursor-pointer">
                        <input type="checkbox" checked class="w-4 h-4 rounded border-dark-300" />
                        <span class="text-sm font-medium text-dark-900">Active Supplier</span>
                    </label>
                    <p class="text-xs text-dark-500 mt-2">Uncheck to create as inactive</p>
                </div>

                <div>
                    <label class="flex items-center space-x-3 cursor-pointer">
                        <input type="checkbox" checked class="w-4 h-4 rounded border-dark-300" />
                        <span class="text-sm font-medium text-dark-900">Verified Supplier</span>
                    </label>
                    <p class="text-xs text-dark-500 mt-2">Mark as verified after checking credentials</p>
                </div>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="flex flex-col sm:flex-row gap-2 sm:gap-4 justify-between">
            <button type="button" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <div class="flex gap-2">
                <button type="reset" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                    </svg>
                    Reset
                </button>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Create Supplier
                </button>
            </div>
        </div>
    </form>
</div>

@code {
    protected override void OnInitialized()
    {
        // Initialize form
    }
}
