@page "/inventory/warehouse-transfers/create"
@rendermode InteractiveServer

<PageTitle>Create Stock Transfer - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Create Stock Transfer</h1>
            <p class="text-dark-500 mt-1">Transfer inventory between warehouses</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/inventory/warehouse-transfers" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </a>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Create Transfer
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Quick Guide -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Transfer Guide</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Select source & destination warehouses</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Add items with quantities</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Set transfer & expected delivery dates</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Add notes and shipping details</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Review and confirm transfer</span>
                    </div>
                </div>
            </div>

            <!-- Info Card -->
            <div class="card bg-blue-50 border-l-4 border-blue-500">
                <h3 class="text-lg font-bold text-blue-900 mb-3">Transfer ID Auto-Generated</h3>
                <p class="text-sm text-blue-800">Transfer ID will be auto-generated (TRF-2024-XXX) when you create this transfer. You can track it through the transfers list.</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Warehouse Selection -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Warehouse Selection</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">From Warehouse *</label>
                        <select class="input-field">
                            <option selected>Select Source Warehouse</option>
                            <option>Main Warehouse (WH-001)</option>
                            <option>South Regional Hub (WH-002)</option>
                            <option>East Distribution (WH-003)</option>
                            <option>West Express Hub (WH-004)</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">To Warehouse *</label>
                        <select class="input-field">
                            <option selected>Select Destination Warehouse</option>
                            <option>Main Warehouse (WH-001)</option>
                            <option>South Regional Hub (WH-002)</option>
                            <option>East Distribution (WH-003)</option>
                            <option>West Express Hub (WH-004)</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Transfer Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Transfer Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Transfer Date *</label>
                        <input type="date" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Expected Delivery Date *</label>
                        <input type="date" class="input-field" />
                    </div>
                </div>

                <div class="mt-6">
                    <label class="block text-sm font-medium text-dark-900 mb-2">Priority</label>
                    <select class="input-field">
                        <option selected>Normal</option>
                        <option>High</option>
                        <option>Urgent</option>
                        <option>Low</option>
                    </select>
                </div>
            </div>

            <!-- Items to Transfer -->
            <div class="card">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-bold text-dark-900">Items to Transfer</h3>
                    <button class="btn-sm bg-primary-600 text-white hover:bg-primary-700 px-3 py-1 rounded flex items-center gap-2">
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        Add Item
                    </button>
                </div>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">SKU</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Product Name</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Available</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Transfer Qty</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Unit</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">ENG-2401</td>
                                <td class="py-4 px-4 text-dark-700">Engine Oil Filter (Premium)</td>
                                <td class="text-right py-4 px-4 text-dark-700">450 units</td>
                                <td class="py-4 px-4">
                                    <input type="number" value="200" class="input-field w-20" />
                                </td>
                                <td class="text-center py-4 px-4 text-dark-700">pcs</td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 text-xs font-medium">Remove</button>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">BRK-0850</td>
                                <td class="py-4 px-4 text-dark-700">Brake Pad Set (Ceramic)</td>
                                <td class="text-right py-4 px-4 text-dark-700">320 units</td>
                                <td class="py-4 px-4">
                                    <input type="number" value="150" class="input-field w-20" />
                                </td>
                                <td class="text-center py-4 px-4 text-dark-700">pcs</td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 text-xs font-medium">Remove</button>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">SUS-1205</td>
                                <td class="py-4 px-4 text-dark-700">Shock Absorber Assembly</td>
                                <td class="text-right py-4 px-4 text-dark-700">180 units</td>
                                <td class="py-4 px-4">
                                    <input type="number" value="120" class="input-field w-20" />
                                </td>
                                <td class="text-center py-4 px-4 text-dark-700">pcs</td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 text-xs font-medium">Remove</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <div class="mt-4 p-4 bg-dark-50 rounded-lg">
                    <div class="flex justify-between items-center">
                        <p class="font-medium text-dark-900">Total Items to Transfer:</p>
                        <p class="text-2xl font-bold text-primary-600">470 units</p>
                    </div>
                </div>
            </div>

            <!-- Shipping Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Shipping Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Shipping Method</label>
                        <select class="input-field">
                            <option selected>Road Transport</option>
                            <option>Rail Transport</option>
                            <option>Air Cargo</option>
                            <option>Internal Transfer</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Tracking Number (Optional)</label>
                        <input type="text" placeholder="e.g., TRACK123456" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Driver Name</label>
                        <input type="text" placeholder="e.g., Sharma" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Driver Contact</label>
                        <input type="tel" placeholder="e.g., +91 9876543210" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Vehicle Number (Optional)</label>
                        <input type="text" placeholder="e.g., DL-01-AB-1234" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Estimated Cost</label>
                        <input type="number" placeholder="e.g., 5000" class="input-field" />
                    </div>
                </div>

                <div class="mt-6">
                    <label class="block text-sm font-medium text-dark-900 mb-2">Special Instructions</label>
                    <textarea rows="3" class="input-field" placeholder="Add any special handling, delivery instructions, or notes..."></textarea>
                </div>
            </div>

            <!-- Additional Notes -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Additional Notes</h3>

                <textarea rows="4" class="input-field" placeholder="Add internal notes about this transfer..."></textarea>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <a href="/inventory/warehouse-transfers" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </a>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Create Transfer
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Initialize create transfer form
    }
}
