@page "/inventory/stock-levels"
@rendermode InteractiveServer

<PageTitle>Stock Levels - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Stock Levels</h1>
            <p class="text-dark-500 mt-1">Monitor and manage inventory levels across all parts</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                </svg>
                Print
            </button>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export
            </button>
        </div>
    </div>

    <!-- Filters Card -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-5 gap-4">
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Search Parts</label>
                <input type="text" placeholder="Filter by name or SKU..." class="input-field" />
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Stock Status</label>
                <select class="input-field">
                    <option>All Status</option>
                    <option>In Stock</option>
                    <option>Low Stock</option>
                    <option>Critical</option>
                    <option>Out of Stock</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Category</label>
                <select class="input-field">
                    <option>All Categories</option>
                    <option>Filters</option>
                    <option>Brake System</option>
                    <option>Engine</option>
                    <option>Electrical</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Stock Range</label>
                <input type="text" placeholder="Min - Max units" class="input-field" />
            </div>
            <div class="flex items-end">
                <button class="btn-primary w-full">Apply Filters</button>
            </div>
        </div>
    </div>

    <!-- Stock Levels Table -->
    <div class="card">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-bold text-dark-900">Stock Levels Overview</h3>
            <div class="text-sm text-dark-500">
                Showing <span class="font-semibold">1-10</span> of <span class="font-semibold">245</span> parts
            </div>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-dark-200">
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Part Name</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">SKU</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Current Stock</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Reorder Level</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Status</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Progress</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <!-- Row 1: In Stock -->
                    <tr class="border-b border-dark-100 hover:bg-primary-50 transition-colors">
                        <td class="py-4 px-4">
                            <div class="flex items-center space-x-3">
                                <div class="w-10 h-10 bg-blue-100 rounded-lg flex items-center justify-center">
                                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4"></path>
                                    </svg>
                                </div>
                                <p class="font-medium text-dark-900">Engine Oil Filter</p>
                            </div>
                        </td>
                        <td class="py-4 px-4 text-sm text-dark-700">EOF-001</td>
                        <td class="py-4 px-4">
                            <div class="text-sm">
                                <p class="font-semibold text-dark-900">245</p>
                                <p class="text-xs text-dark-500">units</p>
                            </div>
                        </td>
                        <td class="py-4 px-4 text-sm text-dark-700">50 units</td>
                        <td class="py-4 px-4">
                            <span class="badge-success">In Stock</span>
                        </td>
                        <td class="py-4 px-4">
                            <div class="w-full bg-dark-200 rounded-full h-2">
                                <div class="bg-green-500 h-2 rounded-full" style="width: 100%"></div>
                            </div>
                            <p class="text-xs text-dark-500 mt-1">490%</p>
                        </td>
                        <td class="py-4 px-4">
