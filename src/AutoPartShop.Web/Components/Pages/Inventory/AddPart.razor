@page "/inventory/parts/add"

<PageTitle>Add New Part - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Add New Part</h1>
            <p class="text-dark-500 mt-1">Create a new automotive part in your inventory</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2">
            <button class="btn-secondary">
                <svg class="w-5 h-5 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <button class="btn-primary">
                <svg class="w-5 h-5 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Create Part
            </button>
        </div>
    </div>

    <!-- Add Part Form -->
    <form class="space-y-6">
        <!-- Basic Information Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Basic Information</h3>
            <div class="space-y-6">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Part Name *</label>
                        <input type="text" placeholder="e.g., Engine Oil Filter" class="input-field" required />
                        <p class="text-xs text-dark-500 mt-1">Clear and descriptive name</p>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">SKU *</label>
                        <input type="text" placeholder="e.g., EOF-001" class="input-field" required />
                        <p class="text-xs text-dark-500 mt-1">Unique identifier for this part</p>
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Category *</label>
                        <select class="input-field" required>
                            <option value="">-- Select a category --</option>
                            <option value="filters">Filters</option>
                            <option value="brake">Brake System</option>
                            <option value="engine">Engine</option>
                            <option value="transmission">Transmission</option>
                            <option value="suspension">Suspension</option>
                            <option value="electrical">Electrical</option>
                            <option value="cooling">Cooling System</option>
                            <option value="fluids">Fluids</option>
                            <option value="exterior">Exterior</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Subcategory</label>
                        <select class="input-field">
                            <option value="">-- Select subcategory (optional) --</option>
                            <option value="engine-maint">Engine Maintenance</option>
                            <option value="cabin-filters">Cabin Filters</option>
                            <option value="air-filters">Air Filters</option>
                            <option value="fuel-filters">Fuel Filters</option>
                        </select>
                    </div>
                </div>

                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Description</label>
                    <textarea rows="4" class="input-field" placeholder="Enter detailed product description..."></textarea>
                    <p class="text-xs text-dark-500 mt-1">Describe features, specifications, and benefits</p>
                </div>

                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Product Image</label>
                    <div class="border-2 border-dashed border-dark-300 rounded-lg p-8 text-center cursor-pointer hover:border-primary-500 hover:bg-primary-50 transition-colors">
                        <svg class="w-16 h-16 text-dark-400 mx-auto mb-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                        </svg>
                        <p class="text-dark-700 font-semibold">Click to upload or drag and drop</p>
                        <p class="text-dark-500 text-sm">PNG, JPG, GIF up to 5MB</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Pricing Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Pricing Information</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Cost Price ($) *</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-dark-500">$</span>
                        <input type="number" step="0.01" class="input-field pl-7" placeholder="0.00" required />
                    </div>
                    <p class="text-xs text-dark-500 mt-1">What you pay for this part</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Selling Price ($) *</label>
                    <div class="relative">
                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-dark-500">$</span>
                        <input type="number" step="0.01" class="input-field pl-7" placeholder="0.00" required />
                    </div>
                    <p class="text-xs text-dark-500 mt-1">Price for customers</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Profit Margin (Auto)</label>
                    <input type="text" value="$0.00 (0%)" class="input-field bg-dark-100" disabled />
                    <p class="text-xs text-dark-500 mt-1">Calculated automatically</p>
                </div>
            </div>
        </div>

        <!-- Stock Information Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Stock Information</h3>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Initial Stock *</label>
                    <input type="number" value="0" class="input-field" placeholder="0" required />
                    <p class="text-xs text-dark-500 mt-1">Opening quantity</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Reorder Level *</label>
                    <input type="number" value="50" class="input-field" placeholder="0" required />
                    <p class="text-xs text-dark-500 mt-1">Minimum threshold</p>
                </div>
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Reorder Quantity *</label>
                    <input type="number" value="100" class="input-field" placeholder="0" required />
                    <p class="text-xs text-dark-500 mt-1">Order amount</p>
                </div>
            </div>

            <div class="pt-6 border-t border-dark-200">
                <h4 class="font-semibold text-dark-900 mb-4">Stock Location</h4>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Warehouse *</label>
                        <select class="input-field" required>
                            <option value="">-- Select warehouse --</option>
                            <option value="main">Main Warehouse</option>
                            <option value="branch1">Branch 1</option>
                            <option value="branch2">Branch 2</option>
                        </select>
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Shelf Location</label>
                        <input type="text" placeholder="e.g., A-15-3" class="input-field" />
                        <p class="text-xs text-dark-500 mt-1">Optional storage location</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Supplier Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Supplier Information</h3>
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Primary Supplier *</label>
                    <select class="input-field" required>
                        <option value="">-- Select supplier --</option>
                        <option value="parts-direct">Parts Direct Inc.</option>
                        <option value="auto-supply">Auto Components Ltd.</option>
                        <option value="global">Global Auto Parts</option>
                        <option value="new">+ Add New Supplier</option>
                    </select>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Supplier SKU</label>
                        <input type="text" placeholder="Supplier's part number" class="input-field" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Lead Time (Days) *</label>
                        <input type="number" value="5" class="input-field" placeholder="0" required />
                    </div>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Minimum Order Qty</label>
                        <input type="number" value="10" class="input-field" placeholder="0" />
                    </div>
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Supplier Contact Email</label>
                        <input type="email" placeholder="email@supplier.com" class="input-field" />
                    </div>
                </div>
            </div>
        </div>

        <!-- Specifications Section -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Specifications</h3>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Weight (kg)</label>
                    <input type="number" step="0.01" placeholder="0.00" class="input-field" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Dimensions (L×W×H cm)</label>
                    <input type="text" placeholder="e.g., 10 × 8 × 8" class="input-field" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Material</label>
                    <input type="text" placeholder="e.g., Synthetic Media" class="input-field" />
                </div>
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Warranty (Months)</label>
                    <input type="number" value="12" class="input-field" placeholder="0" />
                </div>
                <div class="md:col-span-2">
                    <label class="block text-sm font-medium text-dark-900 mb-2">Compatibility Notes</label>
                    <textarea rows="3" class="input-field" placeholder="Describe compatible vehicles and models..."></textarea>
                </div>
            </div>
        </div>

        <!-- Additional Information -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Additional Information</h3>
            <div class="space-y-6">
                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Barcode/UPC</label>
                    <input type="text" placeholder="Enter barcode number" class="input-field" />
                </div>

                <div>
                    <label class="block text-sm font-medium text-dark-900 mb-2">Tags (comma separated)</label>
                    <input type="text" placeholder="tag1, tag2, tag3" class="input-field" />
                    <p class="text-xs text-dark-500 mt-1">Helps with searching and filtering</p>
                </div>

                <div class="space-y-3">
                    <label class="flex items-center space-x-3 cursor-pointer">
                        <input type="checkbox" checked class="w-4 h-4 rounded border-dark-300 text-primary-600" />
                        <span class="text-sm font-medium text-dark-900">Active Part</span>
                    </label>

                    <label class="flex items-center space-x-3 cursor-pointer">
                        <input type="checkbox" checked class="w-4 h-4 rounded border-dark-300 text-primary-600" />
                        <span class="text-sm font-medium text-dark-900">Track Stock</span>
                    </label>

                    <label class="flex items-center space-x-3 cursor-pointer">
                        <input type="checkbox" class="w-4 h-4 rounded border-dark-300 text-primary-600" />
                        <span class="text-sm font-medium text-dark-900">Enable Low Stock Alert</span>
                    </label>
                </div>
            </div>
        </div>

        <!-- Form Actions -->
        <div class="flex flex-col sm:flex-row gap-2 justify-between">
            <button type="button" class="btn-secondary">
                <svg class="w-5 h-5 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <div class="flex gap-2">
                <button type="reset" class="btn-secondary">
                    <svg class="w-5 h-5 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                    </svg>
                    Reset
                </button>
                <button type="submit" class="btn-primary">
                    <svg class="w-5 h-5 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Create Part
                </button>
            </div>
        </div>
    </form>

    <!-- Helpful Tips -->
    <div class="bg-blue-50 border border-blue-200 rounded-lg p-6">
        <div class="flex space-x-3">
            <svg class="w-6 h-6 text-blue-600 flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <div>
                <h4 class="font-semibold text-blue-900 mb-2">Tips for Adding Parts</h4>
                <ul class="text-sm text-blue-800 space-y-1">
                    <li>• Use clear and descriptive part names for easy searching</li>
                    <li>• SKU should be unique and follow your naming convention</li>
                    <li>• Set accurate reorder levels based on sales history</li>
                    <li>• Upload high-quality product images for better identification</li>
                    <li>• Add tags to organize and filter parts efficiently</li>
                </ul>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Initialize new part form
    }
}
