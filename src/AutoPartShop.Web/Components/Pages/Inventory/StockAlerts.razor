@page "/inventory/stock-alerts"
@rendermode InteractiveServer

<PageTitle>Stock Alerts - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Stock Alerts & Warnings</h1>
            <p class="text-dark-500 mt-1">Monitor critical inventory issues and alerts</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
                </svg>
                Settings
            </button>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"></path>
                </svg>
                Refresh
            </button>
        </div>
    </div>

    <!-- Alert Summary -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="card-sm border-l-4 border-red-500 bg-red-50">
            <h4 class="font-semibold text-dark-900 mb-2">Critical Alerts</h4>
            <p class="text-3xl font-bold text-red-600">18</p>
            <p class="text-dark-500 text-xs mt-2">Urgent action required</p>
            <a href="#critical" class="text-red-600 hover:text-red-700 text-sm font-medium inline-block mt-2">View all →</a>
        </div>

        <div class="card-sm border-l-4 border-orange-500 bg-orange-50">
            <h4 class="font-semibold text-dark-900 mb-2">Warning Alerts</h4>
            <p class="text-3xl font-bold text-orange-600">56</p>
            <p class="text-dark-500 text-xs mt-2">Monitor closely</p>
            <a href="#warning" class="text-orange-600 hover:text-orange-700 text-sm font-medium inline-block mt-2">View all →</a>
        </div>

        <div class="card-sm border-l-4 border-blue-500 bg-blue-50">
            <h4 class="font-semibold text-dark-900 mb-2">Info Alerts</h4>
            <p class="text-3xl font-bold text-blue-600">12</p>
            <p class="text-dark-500 text-xs mt-2">Informational</p>
            <a href="#info" class="text-blue-600 hover:text-blue-700 text-sm font-medium inline-block mt-2">View all →</a>
        </div>

        <div class="card-sm border-l-4 border-green-500 bg-green-50">
            <h4 class="font-semibold text-dark-900 mb-2">Resolved</h4>
            <p class="text-3xl font-bold text-green-600">234</p>
            <p class="text-dark-500 text-xs mt-2">This month</p>
        </div>
    </div>

    <!-- Filter & Sort -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Alert Type</label>
                <select class="input-field">
                    <option>All Types</option>
                    <option>Critical</option>
                    <option>Warning</option>
                    <option>Info</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                <select class="input-field">
                    <option>All Status</option>
                    <option>Active</option>
                    <option>Resolved</option>
                    <option>Acknowledged</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Sort By</label>
                <select class="input-field">
                    <option>Most Recent</option>
                    <option>Oldest First</option>
                    <option>Severity</option>
                    <option>Part Name</option>
                </select>
            </div>
            <div class="flex items-end">
                <button class="btn-primary w-full">Apply Filters</button>
            </div>
        </div>
    </div>

    <!-- Critical Alerts Section -->
    <div id="critical" class="space-y-4">
        <h3 class="text-xl font-bold text-dark-900 flex items-center">
            <span class="w-3 h-3 bg-red-600 rounded-full mr-3"></span>
            Critical Alerts (18)
        </h3>

        <!-- Alert 1 -->
        <div class="card border-l-4 border-red-500 bg-red-50">
            <div class="flex items-start justify-between mb-4">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-dark-900">Spark Plugs (4pc) - Out of Stock</p>
                        <p class="text-sm text-dark-600 mt-1">SKU: SP-004</p>
                        <p class="text-sm text-dark-500 mt-2">Current Stock: 0 units | Reorder Level: 50 units</p>
                    </div>
                </div>
                <div class="text-right flex-shrink-0">
                    <span class="badge-danger">Critical</span>
                    <p class="text-xs text-dark-400 mt-2">5 days ago</p>
                </div>
            </div>
            <div class="bg-white rounded p-3 mb-3">
                <p class="text-sm text-dark-600"><strong>Issue:</strong> Part is completely out of stock. No units available for customer orders.</p>
            </div>
            <div class="flex gap-2">
                <button class="text-primary-600 hover:text-primary-700 text-sm font-medium">Reorder Now</button>
                <button class="text-dark-600 hover:text-dark-700 text-sm font-medium">View Part</button>
                <button class="text-dark-600 hover:text-dark-700 text-sm font-medium">Acknowledge</button>
            </div>
        </div>

        <!-- Alert 2 -->
        <div class="card border-l-4 border-red-500 bg-red-50">
            <div class="flex items-start justify-between mb-4">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-red-100 rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-dark-900">Alternator - Critical Stock Level</p>
                        <p class="text-sm text-dark-600 mt-1">SKU: ALT-009</p>
                        <p class="text-sm text-dark-500 mt-2">Current Stock: 3 units | Reorder Level: 50 units</p>
                    </div>
                </div>
                <div class="text-right flex-shrink-0">
                    <span class="badge-danger">Critical</span>
                    <p class="text-xs text-dark-400 mt-2">2 days ago</p>
                </div>
            </div>
            <div class="bg-white rounded p-3 mb-3">
                <p class="text-sm text-dark-600"><strong>Issue:</strong> Stock is below 10% of reorder level. Immediate reordering recommended.</p>
            </div>
            <div class="flex gap-2">
                <button class="text-primary-600 hover:text-primary-700 text-sm font-medium">Reorder Now</button>
                <button class="text-dark-600 hover:text-dark-700 text-sm font-medium">View Part</button>
                <button class="text-dark-600 hover:text-dark-700 text-sm font-medium">Acknowledge</button>
            </div>
        </div>
    </div>

    <!-- Warning Alerts Section -->
    <div id="warning" class="space-y-4">
        <h3 class="text-xl font-bold text-dark-900 flex items-center">
            <span class="w-3 h-3 bg-orange-500 rounded-full mr-3"></span>
            Warning Alerts (56)
        </h3>

        <!-- Alert 3 -->
        <div class="card border-l-4 border-orange-500 bg-orange-50">
            <div class="flex items-start justify-between mb-4">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-dark-900">Brake Pads Set - Low Stock</p>
                        <p class="text-sm text-dark-600 mt-1">SKU: BPS-002</p>
                        <p class="text-sm text-dark-500 mt-2">Current Stock: 12 units | Reorder Level: 50 units</p>
                    </div>
                </div>
                <div class="text-right flex-shrink-0">
                    <span class="badge-warning">Warning</span>
                    <p class="text-xs text-dark-400 mt-2">1 day ago</p>
                </div>
            </div>
            <div class="bg-white rounded p-3 mb-3">
                <p class="text-sm text-dark-600"><strong>Issue:</strong> Stock is below reorder level. Plan reordering within 2-3 days.</p>
            </div>
            <div class="flex gap-2">
                <button class="text-primary-600 hover:text-primary-700 text-sm font-medium">Reorder</button>
                <button class="text-dark-600 hover:text-dark-700 text-sm font-medium">View Part</button>
                <button class="text-dark-600 hover:text-dark-700 text-sm font-medium">Acknowledge</button>
            </div>
        </div>

        <!-- Alert 4 -->
        <div class="card border-l-4 border-orange-500 bg-orange-50">
            <div class="flex items-start justify-between mb-4">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4v.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-dark-900">Radiator Hose - Low Stock</p>
                        <p class="text-sm text-dark-600 mt-1">SKU: RAH-006</p>
                        <p class="text-sm text-dark-500 mt-2">Current Stock: 8 units | Reorder Level: 50 units</p>
                    </div>
                </div>
                <div class="text-right flex-shrink-0">
                    <span class="badge-warning">Warning</span>
                    <p class="text-xs text-dark-400 mt-2">3 days ago</p>
                </div>
            </div>
            <div class="bg-white rounded p-3 mb-3">
                <p class="text-sm text-dark-600"><strong>Issue:</strong> Stock is below reorder level. Plan reordering within 2-3 days.</p>
            </div>
            <div class="flex gap-2">
                <button class="text-primary-600 hover:text-primary-700 text-sm font-medium">Reorder</button>
                <button class="text-dark-600 hover:text-dark-700 text-sm font-medium">View Part</button>
                <button class="text-dark-600 hover:text-dark-700 text-sm font-medium">Acknowledge</button>
            </div>
        </div>
    </div>

    <!-- Info Alerts Section -->
    <div id="info" class="space-y-4">
        <h3 class="text-xl font-bold text-dark-900 flex items-center">
            <span class="w-3 h-3 bg-blue-500 rounded-full mr-3"></span>
            Info Alerts (12)
        </h3>

        <!-- Alert 5 -->
        <div class="card border-l-4 border-blue-500 bg-blue-50">
            <div class="flex items-start justify-between mb-4">
                <div class="flex items-start gap-4">
                    <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center flex-shrink-0">
                        <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                        </svg>
                    </div>
                    <div>
                        <p class="font-semibold text-dark-900">Engine Oil Filter - High Stock</p>
                        <p class="text-sm text-dark-600 mt-1">SKU: EOF-001</p>
                        <p class="text-sm text-dark-500 mt-2">Current Stock: 245 units | Reorder Level: 50 units</p>
                    </div>
                </div>
                <div class="text-right flex-shrink-0">
                    <span class="badge-primary">Info</span>
                    <p class="text-xs text-dark-400 mt-2">1 week ago</p>
                </div>
            </div>
            <div class="bg-white rounded p-3 mb-3">
                <p class="text-sm text-dark-600"><strong>Note:</strong> Stock is significantly above reorder level. Good inventory position maintained.</p>
            </div>
            <div class="flex gap-2">
                <button class="text-dark-600 hover:text-dark-700 text-sm font-medium">Dismiss</button>
            </div>
        </div>
    </div>

    <!-- Alert Settings -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-6">Alert Settings</h3>
        <p class="text-sm text-dark-600 mb-4">Configure how you receive stock alerts</p>
        <div className="space-y-4">
            <div class="flex items-center justify-between">
                <div>
                    <p class="font-medium text-dark-900">Email Notifications</p>
                    <p class="text-sm text-dark-500">Receive critical alerts via email</p>
                </div>
                <input type="checkbox" checked class="w-5 h-5 rounded" />
            </div>
            <div class="border-t border-dark-200 pt-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="font-medium text-dark-900">SMS Alerts</p>
                        <p class="text-sm text-dark-500">Get urgent alerts via SMS</p>
                    </div>
                    <input type="checkbox" class="w-5 h-5 rounded" />
                </div>
            </div>
            <div class="border-t border-dark-200 pt-4">
                <div class="flex items-center justify-between">
                    <div>
                        <p class="font-medium text-dark-900">In-App Notifications</p>
                        <p class="text-sm text-dark-500">Show alerts in the dashboard</p>
                    </div>
                    <input type="checkbox" checked class="w-5 h-5 rounded" />
                </div>
            </div>
        </div>
    </div>
</div>
