@page "/inventory/suppliers/{id}"
@rendermode InteractiveServer

<PageTitle>Supplier Details - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Supplier Details</h1>
            <p class="text-dark-500 mt-1">Complete information about this supplier</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                </svg>
                Print
            </button>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H14v2.828a2 2 0 11-2.828-2.828l8.586-8.586z"></path>
                </svg>
                Edit Supplier
            </button>
        </div>
    </div>

    <!-- Main Content Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Column - Quick Info -->
        <div class="lg:col-span-1 space-y-6">
            <!-- Supplier Logo/Avatar -->
            <div class="card">
                <div class="w-full bg-gradient-to-br from-blue-50 to-blue-100 rounded-lg h-40 flex items-center justify-center mb-4">
                    <div class="w-20 h-20 bg-blue-600 rounded-full flex items-center justify-center">
                        <span class="text-white text-3xl font-bold">PD</span>
                    </div>
                </div>
                <p class="text-center font-semibold text-dark-900">Parts Direct Inc.</p>
                <p class="text-center text-sm text-dark-500 mt-1">SUP-001</p>
            </div>

            <!-- Quick Info Card -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Quick Info</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Status</p>
                        <span class="badge-success mt-2">Active</span>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Category</p>
                        <p class="text-dark-900 font-medium mt-1">Distributor</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Country</p>
                        <p class="text-dark-900 font-medium mt-1">United States</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Member Since</p>
                        <p class="text-dark-900 font-medium mt-1">Jan 15, 2020</p>
                    </div>
                </div>
            </div>

            <!-- Actions Card -->
            <div class="card space-y-2">
                <button class="w-full btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Place Order
                </button>
                <button class="w-full btn-secondary">
                    <svg class="w-5 h-5 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                    </svg>
                    View History
                </button>
            </div>
        </div>

        <!-- Right Column - Detailed Information -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Basic Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Basic Information</h3>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Supplier Name</p>
                        <p class="text-dark-900 font-semibold mt-2">Parts Direct Inc.</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Supplier Code</p>
                        <p class="text-dark-900 font-semibold mt-2">SUP-001</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Category</p>
                        <p class="text-dark-900 font-semibold mt-2">Distributor</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Country/Region</p>
                        <p class="text-dark-900 font-semibold mt-2">United States</p>
                    </div>
                    <div className="md:col-span-2">
                        <p class="text-sm text-dark-500 font-medium">Company Description</p>
                        <p class="text-dark-700 mt-2">Leading automotive parts distributor specializing in OEM and aftermarket components for domestic and imported vehicles. With over 20 years of industry experience, we provide quality products and reliable service.</p>
                    </div>
                </div>
            </div>

            <!-- Contact Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Contact Information</h3>
                <div className="space-y-6">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Primary Contact</p>
                        <div class="flex items-center space-x-3">
                            <div class="w-12 h-12 bg-blue-100 rounded-full flex items-center justify-center">
                                <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                                </svg>
                            </div>
                            <div>
                                <p class="font-semibold text-dark-900">John Smith</p>
                                <p class="text-sm text-dark-500">Sales Manager</p>
                            </div>
                        </div>
                    </div>

                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4 pt-4 border-t border-dark-200">
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Email</p>
                            <a href="mailto:sales@partsdirect.com" class="text-primary-600 hover:text-primary-700 font-semibold mt-1">sales@partsdirect.com</a>
                        </div>
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Phone</p>
                            <a href="tel:+15551234567" class="text-primary-600 hover:text-primary-700 font-semibold mt-1">+1 (555) 123-4567</a>
                        </div>
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Website</p>
                            <a href="https://www.partsdirect.com" target="_blank" class="text-primary-600 hover:text-primary-700 font-semibold mt-1">www.partsdirect.com</a>
                        </div>
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Alternative</p>
                            <a href="tel:+15559876543" class="text-primary-600 hover:text-primary-700 font-semibold mt-1">+1 (555) 987-6543</a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Address Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Address Information</h3>
                <div className="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Street Address</p>
                        <p class="text-dark-900 font-semibold mt-1">123 Commerce Street</p>
                    </div>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <p class="text-sm text-dark-500 font-medium">City</p>
                            <p class="text-dark-900 font-semibold mt-1">Houston</p>
                        </div>
                        <div>
                            <p class="text-sm text-dark-500 font-medium">State/Province</p>
                            <p class="text-dark-900 font-semibold mt-1">Texas</p>
                        </div>
                    </div>
                    <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Postal Code</p>
                            <p class="text-dark-900 font-semibold mt-1">77002</p>
                        </div>
                        <div>
                            <p class="text-sm text-dark-500 font-medium">Country</p>
                            <p class="text-dark-900 font-semibold mt-1">United States</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Business Terms -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Business Terms</h3>
                <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="border-b md:border-b-0 md:border-r border-dark-200 pb-6 md:pb-0 md:pr-6">
                        <p class="text-sm text-dark-500 font-medium">Average Lead Time</p>
                        <p class="text-2xl font-bold text-dark-900 mt-2">5-7 days</p>
                        <p class="text-xs text-dark-500 mt-1">Typical delivery time</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Minimum Order</p>
                        <p class="text-2xl font-bold text-dark-900 mt-2">10 units</p>
                        <p class="text-xs text-dark-500 mt-1">Per order</p>
                    </div>
                    <div class="border-b md:border-b-0 md:border-r border-dark-200 pb-6 md:pb-0 md:pr-6">
                        <p class="text-sm text-dark-500 font-medium">Payment Terms</p>
                        <p class="text-dark-900 font-semibold mt-2">Net 30</p>
                        <p class="text-xs text-dark-500 mt-1">30 days to pay</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Currency</p>
                        <p class="text-dark-900 font-semibold mt-2">USD ($)</p>
                        <p class="text-xs text-dark-500 mt-1">Preferred currency</p>
                    </div>
                </div>
            </div>

            <!-- Performance Metrics -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Performance Metrics</h3>
                <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
                    <div class="border-b md:border-b-0 md:border-r border-dark-200 pb-6 md:pb-0 md:pr-6">
                        <p class="text-sm text-dark-500 font-medium">Supplier Rating</p>
                        <div class="flex items-center mt-2">
                            <p class="text-2xl font-bold text-yellow-600 mr-2">4.8</p>
                            <span class="text-yellow-500 text-xl">★</span>
                        </div>
                        <p class="text-xs text-dark-500 mt-1">Out of 5.0</p>
                    </div>
                    <div class="border-b md:border-b-0 md:border-r border-dark-200 pb-6 md:pb-0 md:pr-6">
                        <p class="text-sm text-dark-500 font-medium">On-Time Delivery</p>
                        <p class="text-2xl font-bold text-green-600 mt-2">96%</p>
                        <p class="text-xs text-dark-500 mt-1">Last 90 days</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Quality Score</p>
                        <p class="text-2xl font-bold text-green-600 mt-2">98%</p>
                        <p class="text-xs text-dark-500 mt-1">Product quality</p>
                    </div>
                </div>
            </div>

            <!-- Product Categories -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Product Categories</h3>
                <div className="flex flex-wrap gap-2">
                    <span class="badge-primary">Filters</span>
                    <span class="badge-primary">Brake System</span>
                    <span class="badge-primary">Engine Components</span>
                    <span class="badge-primary">Electrical</span>
                    <span class="badge-primary">Fluids</span>
                </div>
            </div>

            <!-- Additional Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Additional Information</h3>
                <div className="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Tax ID / VAT Number</p>
                        <p class="text-dark-900 font-semibold mt-1">12-3456789</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Special Requirements</p>
                        <p class="text-dark-900 mt-1">Requires minimum 48-hour notice for rush orders. Closed on US Federal Holidays.</p>
                    </div>
                    <div className="pt-4 border-t border-dark-200">
                        <p class="text-sm text-dark-500 font-medium mb-3">Account Status</p>
                        <div className="flex gap-4">
                            <span class="badge-success">Active</span>
                            <span class="badge-primary">Verified</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load supplier details based on Id
    }
}
