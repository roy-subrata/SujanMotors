@page "/inventory/stock-levels/{id}/adjust"

<PageTitle>Adjust Stock - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Adjust Stock Level</h1>
            <p class="text-dark-500 mt-1">Add or remove inventory for this part</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Update Stock
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Column: Part Info -->
        <div class="space-y-6">
            <!-- Part Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Part Information</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Part Name</p>
                        <p class="text-dark-900 font-semibold mt-1">Engine Oil Filter</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">SKU</p>
                        <p class="text-dark-900 font-semibold mt-1">EOF-001</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Category</p>
                        <p class="text-dark-900 font-semibold mt-1">Filters</p>
                    </div>
                </div>
            </div>

            <!-- Current Stock Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Current Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Stock Level</p>
                        <div class="flex items-center space-x-3">
                            <div class="text-3xl font-bold text-primary-600">245</div>
                            <span class="badge-success">In Stock</span>
                        </div>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Reorder Level</p>
                        <p class="text-dark-900 font-semibold">50 units</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Above Reorder By</p>
                        <p class="text-green-600 font-semibold">195 units (390%)</p>
                    </div>
                </div>
            </div>

            <!-- Stock Warnings -->
            <div class="card bg-blue-50 border-l-4 border-blue-500">
                <h3 class="text-lg font-bold text-blue-900 mb-3">Information</h3>
                <p class="text-sm text-blue-800">Current stock is well above the reorder level. Good inventory position!</p>
            </div>
        </div>

        <!-- Right Column: Adjustment Form -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Stock Adjustment Form -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Stock Adjustment</h3>
                <form class="space-y-6">
                    <!-- Adjustment Type -->
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-4">Adjustment Type *</label>
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                            <label class="flex items-center space-x-3 p-4 border-2 border-primary-600 rounded-lg cursor-pointer">
                                <input type="radio" name="adjType" value="add" checked class="w-4 h-4" />
                                <div>
                                    <p class="font-semibold text-dark-900">Add Stock</p>
                                    <p class="text-xs text-dark-500">Increase inventory (Purchase, Returns)</p>
                                </div>
                            </label>
                            <label class="flex items-center space-x-3 p-4 border-2 border-dark-200 rounded-lg cursor-pointer hover:border-primary-600">
                                <input type="radio" name="adjType" value="remove" class="w-4 h-4" />
                                <div>
                                    <p class="font-semibold text-dark-900">Remove Stock</p>
                                    <p class="text-xs text-dark-500">Decrease inventory (Damage, Adjustment)</p>
                                </div>
                            </label>
                        </div>
                    </div>

                    <!-- Quantity -->
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Quantity *</label>
                        <input type="number" placeholder="Enter quantity" class="input-field text-lg" required />
                        <p class="text-xs text-dark-500 mt-1">Number of units to add or remove</p>
                    </div>

                    <!-- Reason/Reference -->
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Reason for Adjustment *</label>
                        <select class="input-field" required>
                            <option value="">-- Select Reason --</option>
                            <optgroup label="Add Stock Reasons">
                                <option value="purchase">Purchase Order Received</option>
                                <option value="return">Supplier Return/Exchange</option>
                                <option value="correction">Inventory Correction</option>
                                <option value="transfer">Transfer In</option>
                                <option value="other">Other</option>
                            </optgroup>
                            <optgroup label="Remove Stock Reasons">
                                <option value="damage">Damaged/Defective</option>
                                <option value="expired">Expired/Obsolete</option>
                                <option value="loss">Loss/Theft</option>
                                <option value="correction">Inventory Correction</option>
                                <option value="transfer-out">Transfer Out</option>
                                <option value="other">Other</option>
                            </optgroup>
                        </select>
                    </div>

                    <!-- Reference Number -->
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Reference Number</label>
                        <input type="text" placeholder="e.g., PO-2024-001, RMA-12345" class="input-field" />
                        <p class="text-xs text-dark-500 mt-1">Purchase Order, RMA, or Transaction ID</p>
                    </div>

                    <!-- Notes -->
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Notes</label>
                        <textarea rows="3" placeholder="Additional details about this adjustment..." class="input-field"></textarea>
                    </div>

                    <!-- Supplier/Source -->
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Supplier/Source (if applicable)</label>
                        <select class="input-field">
                            <option value="">-- Select Supplier --</option>
                            <option value="parts-direct">Parts Direct Inc.</option>
                            <option value="auto-supply">Auto Components Ltd.</option>
                            <option value="global">Global Auto Parts</option>
                            <option value="internal">Internal Transfer</option>
                        </select>
                    </div>

                    <!-- Adjustment Preview -->
                    <div class="bg-dark-50 border border-dark-200 rounded-lg p-4">
                        <p class="text-sm font-medium text-dark-900 mb-3">Stock Adjustment Preview</p>
                        <div className="grid grid-cols-2 gap-4">
                            <div>
                                <p class="text-xs text-dark-500">Current Stock</p>
                                <p class="text-2xl font-bold text-dark-900">245 units</p>
                            </div>
                            <div>
                                <p class="text-xs text-dark-500">Adjustment</p>
                                <p class="text-2xl font-bold text-primary-600">+ 0 units</p>
                            </div>
                        </div>
                        <div class="border-t border-dark-200 mt-4 pt-4">
                            <p class="text-xs text-dark-500">New Stock Level</p>
                            <p class="text-3xl font-bold text-dark-900">245 units</p>
                        </div>
                    </div>
                </form>
            </div>

            <!-- Batch Adjustment Option -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Batch Adjustment</h3>
                <p class="text-sm text-dark-500 mb-4">Need to adjust stock for multiple parts? Use batch mode.</p>
                <button type="button" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                    Upload CSV for Batch Adjustment
                </button>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <button type="button" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </button>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Update Stock
                </button>
            </div>
        </div>
    </div>

    <!-- Recent Adjustments -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-6">Recent Adjustments for This Part</h3>
        <div class="space-y-4">
            <!-- Adjustment 1 -->
            <div class="flex items-center justify-between p-4 border border-dark-200 rounded-lg">
                <div class="flex-1">
                    <p class="font-semibold text-dark-900">+50 units</p>
                    <p class="text-sm text-dark-500">Purchase Order Received - PO-2024-123</p>
                    <p class="text-xs text-dark-400">Nov 15, 2024 • By Admin User</p>
                </div>
                <div class="text-right">
                    <span class="badge-success">Add</span>
                </div>
            </div>

            <!-- Adjustment 2 -->
            <div class="flex items-center justify-between p-4 border border-dark-200 rounded-lg">
                <div class="flex-1">
                    <p class="font-semibold text-dark-900">-25 units</p>
                    <p class="text-sm text-dark-500">Damaged/Defective - Quality Issue</p>
                    <p class="text-xs text-dark-400">Nov 12, 2024 • By Warehouse Staff</p>
                </div>
                <div class="text-right">
                    <span class="badge-danger">Remove</span>
                </div>
            </div>

            <!-- Adjustment 3 -->
            <div class="flex items-center justify-between p-4 border border-dark-200 rounded-lg">
                <div class="flex-1">
                    <p class="font-semibold text-dark-900">-10 units</p>
                    <p class="text-sm text-dark-500">Inventory Correction</p>
                    <p class="text-xs text-dark-400">Nov 10, 2024 • By Admin User</p>
                </div>
                <div class="text-right">
                    <span class="badge-danger">Remove</span>
                </div>
            </div>

            <!-- Adjustment 4 -->
            <div class="flex items-center justify-between p-4 border border-dark-200 rounded-lg">
                <div class="flex-1">
                    <p class="font-semibold text-dark-900">+100 units</p>
                    <p class="text-sm text-dark-500">Purchase Order Received - PO-2024-098</p>
                    <p class="text-xs text-dark-400">Nov 5, 2024 • By Admin User</p>
                </div>
                <div class="text-right">
                    <span class="badge-success">Add</span>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load part and stock data based on Id
    }
}
