                        <th class="text-left py-3 px-4 font-semibold text-dark-900">From Warehouse</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">To Warehouse</th>
                        <th class="text-right py-3 px-4 font-semibold text-dark-900">Items Count</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Transfer Date</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Expected Delivery</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-dark-200">
                    <tr class="hover:bg-dark-50">
