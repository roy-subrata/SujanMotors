    <!-- Transfer Summary -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Most Active Routes -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-6">Most Active Transfer Routes</h3>

            <div class="space-y-4">
                <div class="flex items-center justify-between p-3 bg-dark-50 rounded-lg">
                    <span class="text-sm font-medium text-dark-900">Main (WH-001) → South (WH-002)</span>
                    <span class="badge-info">18 transfers</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-dark-50 rounded-lg">
                    <span class="text-sm font-medium text-dark-900">South (WH-002) → East (WH-003)</span>
                    <span class="badge-info">15 transfers</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-dark-50 rounded-lg">
                    <span class="text-sm font-medium text-dark-900">Main (WH-001) → West (WH-004)</span>
                    <span class="badge-info">12 transfers</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-dark-50 rounded-lg">
                    <span class="text-sm font-medium text-dark-900">East (WH-003) → Main (WH-001)</span>
                    <span class="badge-info">10 transfers</span>
                </div>
                <div class="flex items-center justify-between p-3 bg-dark-50 rounded-lg">
                    <span class="text-sm font-medium text-dark-900">West (WH-004) → South (WH-002)</span>
                    <span class="badge-info">8 transfers</span>
                </div>
            </div>
        </div>

        <!-- Monthly Transfer Statistics -->
