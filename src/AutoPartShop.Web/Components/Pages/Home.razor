@page "/"

<PageTitle>Dashboard - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Dashboard</h1>
            <p class="text-dark-500 mt-1">Welcome back! Here's your business overview.</p>
        </div>
        <div class="mt-4 sm:mt-0 flex space-x-2">
            <button class="btn-secondary">
                <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                Last 30 Days
            </button>
            <button class="btn-primary">
                <svg class="w-5 h-5 inline-block mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Export
            </button>
        </div>
    </div>

    <!-- Key Metrics Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Total Sales Card -->
        <div class="card group">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-dark-500 text-sm font-medium">Total Sales</p>
                    <p class="text-3xl font-bold text-dark-900 mt-2">$28,450</p>
                    <p class="text-green-600 text-sm mt-2">
                        <span class="font-semibold">+12.5%</span> from last month
                    </p>
                </div>
                <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center group-hover:bg-primary-200 transition-colors">
                    <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Orders Card -->
        <div class="card group">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-dark-500 text-sm font-medium">Total Orders</p>
                    <p class="text-3xl font-bold text-dark-900 mt-2">1,248</p>
                    <p class="text-green-600 text-sm mt-2">
                        <span class="font-semibold">+8.2%</span> from last month
                    </p>
                </div>
                <div class="w-12 h-12 bg-blue-100 rounded-lg flex items-center justify-center group-hover:bg-blue-200 transition-colors">
                    <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Inventory Value Card -->
        <div class="card group">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-dark-500 text-sm font-medium">Inventory Value</p>
                    <p class="text-3xl font-bold text-dark-900 mt-2">$145,280</p>
                    <p class="text-orange-600 text-sm mt-2">
                        <span class="font-semibold">-2.1%</span> from last month
                    </p>
                </div>
                <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center group-hover:bg-orange-200 transition-colors">
                    <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m0 0l8-4 8 4m0 0v10l-8 4-8-4V7m8 4v10m-8-4l8 4 8-4"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Customers Card -->
        <div class="card group">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-dark-500 text-sm font-medium">Active Customers</p>
                    <p class="text-3xl font-bold text-dark-900 mt-2">324</p>
                    <p class="text-green-600 text-sm mt-2">
                        <span class="font-semibold">+5.3%</span> from last month
                    </p>
                </div>
                <div class="w-12 h-12 bg-purple-100 rounded-lg flex items-center justify-center group-hover:bg-purple-200 transition-colors">
                    <svg class="w-6 h-6 text-purple-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-2a6 6 0 0112 0v2zm0 0h6v-2a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts and Tables Grid -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Sales Trend Chart -->
        <div class="lg:col-span-2 card">
            <div class="flex items-center justify-between mb-6">
                <h3 class="text-lg font-bold text-dark-900">Sales Trend</h3>
                <select class="text-sm border border-dark-200 rounded-lg px-3 py-1.5 focus:outline-none focus:ring-2 focus:ring-primary-500">
                    <option>Last 7 days</option>
                    <option>Last 30 days</option>
                    <option>Last 90 days</option>
                </select>
            </div>
            <!-- Placeholder for chart -->
            <div class="h-64 bg-gradient-to-b from-primary-50 to-transparent rounded-lg flex items-end justify-around p-6 space-x-2">
                <div class="w-full bg-primary-200 rounded-t-lg" style="height: 40%;"></div>
                <div class="w-full bg-primary-300 rounded-t-lg" style="height: 65%;"></div>
                <div class="w-full bg-primary-400 rounded-t-lg" style="height: 55%;"></div>
                <div class="w-full bg-primary-500 rounded-t-lg" style="height: 75%;"></div>
                <div class="w-full bg-primary-600 rounded-t-lg" style="height: 85%;"></div>
                <div class="w-full bg-primary-700 rounded-t-lg" style="height: 90%;"></div>
                <div class="w-full bg-primary-800 rounded-t-lg" style="height: 70%;"></div>
            </div>
        </div>

        <!-- Top Products -->
        <div class="card">
            <h3 class="text-lg font-bold text-dark-900 mb-4">Top Products</h3>
            <div class="space-y-4">
                <div class="flex items-center justify-between pb-3 border-b border-dark-100">
                    <div>
                        <p class="text-sm font-medium text-dark-900">Engine Oil Filter</p>
                        <p class="text-xs text-dark-500 mt-1">245 sold</p>
                    </div>
                    <span class="badge-primary">45%</span>
                </div>
                <div class="flex items-center justify-between pb-3 border-b border-dark-100">
                    <div>
                        <p class="text-sm font-medium text-dark-900">Brake Pads Set</p>
                        <p class="text-xs text-dark-500 mt-1">182 sold</p>
                    </div>
                    <span class="badge-primary">34%</span>
                </div>
                <div class="flex items-center justify-between pb-3 border-b border-dark-100">
                    <div>
                        <p class="text-sm font-medium text-dark-900">Air Filter</p>
                        <p class="text-xs text-dark-500 mt-1">156 sold</p>
                    </div>
                    <span class="badge-primary">29%</span>
                </div>
                <div class="flex items-center justify-between pt-2">
                    <div>
                        <p class="text-sm font-medium text-dark-900">Spark Plugs (4pcs)</p>
                        <p class="text-xs text-dark-500 mt-1">98 sold</p>
                    </div>
                    <span class="badge-primary">18%</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Orders Table -->
    <div class="card">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-bold text-dark-900">Recent Orders</h3>
            <a href="/orders/all" class="text-primary-600 hover:text-primary-700 text-sm font-medium">View All →</a>
        </div>

        <div class="overflow-x-auto">
            <table class="w-full table-striped table-hover">
                <thead>
                    <tr class="border-b border-dark-200">
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Order ID</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Customer</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Amount</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Status</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Date</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900 text-sm">Action</th>
                    </tr>
                </thead>
                <tbody>
                    <tr class="border-b border-dark-100 last:border-0 hover:bg-primary-50 transition-colors">
                        <td class="py-4 px-4 text-sm font-medium text-dark-900">#ORD-2024-001</td>
                        <td class="py-4 px-4 text-sm text-dark-700">John Automotive</td>
                        <td class="py-4 px-4 text-sm font-semibold text-dark-900">$2,450</td>
                        <td class="py-4 px-4">
                            <span class="badge badge-success">Completed</span>
                        </td>
                        <td class="py-4 px-4 text-sm text-dark-600">Nov 15, 2024</td>
                        <td class="py-4 px-4">
                            <button class="text-primary-600 hover:text-primary-700 text-sm font-medium">View</button>
                        </td>
                    </tr>
                    <tr class="border-b border-dark-100 last:border-0 hover:bg-primary-50 transition-colors">
                        <td class="py-4 px-4 text-sm font-medium text-dark-900">#ORD-2024-002</td>
                        <td class="py-4 px-4 text-sm text-dark-700">City Motors</td>
                        <td class="py-4 px-4 text-sm font-semibold text-dark-900">$1,890</td>
                        <td class="py-4 px-4">
                            <span class="badge badge-warning">In Progress</span>
                        </td>
                        <td class="py-4 px-4 text-sm text-dark-600">Nov 14, 2024</td>
                        <td class="py-4 px-4">
                            <button class="text-primary-600 hover:text-primary-700 text-sm font-medium">View</button>
                        </td>
                    </tr>
                    <tr class="border-b border-dark-100 last:border-0 hover:bg-primary-50 transition-colors">
                        <td class="py-4 px-4 text-sm font-medium text-dark-900">#ORD-2024-003</td>
                        <td class="py-4 px-4 text-sm text-dark-700">Highway Repair Shop</td>
                        <td class="py-4 px-4 text-sm font-semibold text-dark-900">$3,120</td>
                        <td class="py-4 px-4">
                            <span class="badge badge-primary">Pending</span>
                        </td>
                        <td class="py-4 px-4 text-sm text-dark-600">Nov 13, 2024</td>
                        <td class="py-4 px-4">
                            <button class="text-primary-600 hover:text-primary-700 text-sm font-medium">View</button>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Quick Stats -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Low Stock Alert -->
        <div class="card-sm border-l-4 border-orange-500">
            <h4 class="font-semibold text-dark-900 mb-3">Low Stock Items</h4>
            <p class="text-2xl font-bold text-orange-600">12</p>
            <p class="text-dark-500 text-xs mt-2">Items need restocking</p>
            <a href="/inventory/stock" class="text-orange-600 hover:text-orange-700 text-sm font-medium inline-block mt-3">View details →</a>
        </div>

        <!-- Pending Orders -->
        <div class="card-sm border-l-4 border-blue-500">
            <h4 class="font-semibold text-dark-900 mb-3">Pending Orders</h4>
            <p class="text-2xl font-bold text-blue-600">8</p>
            <p class="text-dark-500 text-xs mt-2">Awaiting payment/processing</p>
            <a href="/orders/active" class="text-blue-600 hover:text-blue-700 text-sm font-medium inline-block mt-3">View details →</a>
        </div>

        <!-- Revenue Target -->
        <div class="card-sm border-l-4 border-green-500">
            <h4 class="font-semibold text-dark-900 mb-3">Monthly Target</h4>
            <div class="flex items-center space-x-3">
                <div>
                    <p class="text-2xl font-bold text-green-600">85%</p>
                    <p class="text-dark-500 text-xs mt-1">of monthly goal</p>
                </div>
                <div class="w-16 h-16 rounded-full bg-green-100 flex items-center justify-center">
                    <span class="text-lg font-bold text-green-600">85%</span>
                </div>
            </div>
        </div>
    </div>
</div>
