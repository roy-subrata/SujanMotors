@page "/orders/create"

<PageTitle>Create Order - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Create Order</h1>
            <p class="text-dark-500 mt-1">Create a new customer order</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/orders" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </a>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Create Order
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Order Summary -->
            <div class="card bg-blue-50 border-l-4 border-blue-500">
                <h3 class="text-lg font-bold text-blue-900 mb-4">Order Summary</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex justify-between">
                        <p class="text-blue-800">Subtotal</p>
                        <p class="font-semibold text-blue-900">₹0</p>
                    </div>
                    <div class="flex justify-between">
                        <p class="text-blue-800">Tax (18%)</p>
                        <p class="font-semibold text-blue-900">₹0</p>
                    </div>
                    <div className="border-t border-blue-200 pt-2 mt-2 flex justify-between">
                        <p className="font-semibold text-blue-900">Total Amount</p>
                        <p className="text-lg font-bold text-blue-600">₹0</p>
                    </div>
                </div>
            </div>

            <!-- Quick Info -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Quick Info</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Auto-generated Order ID</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Add customer and select items</span>
                    </div>
                    <div class="flex items-start gap-3">
                        <svg class="w-5 h-5 text-primary-600 mt-0.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path>
                        </svg>
                        <span class="text-dark-700">Specify quantities and prices</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Customer & Order Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Customer & Order Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Customer *</label>
                        <select class="input-field">
                            <option selected>Select Customer</option>
                            <option>Sharma Auto Parts</option>
                            <option>Tech Engine Solutions</option>
                            <option>Drive Forward Ltd</option>
                            <option>Mechanic's Hub</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Order Date *</label>
                        <input type="date" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Delivery Date *</label>
                        <input type="date" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Terms (Days)</label>
                        <input type="number" placeholder="30" class="input-field" value="30" />
                    </div>
                </div>
            </div>

            <!-- Order Items Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Order Items</h3>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Part Name</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">SKU</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Unit Price</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Qty</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Amount</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">Engine Oil Filter</td>
                                <td class="py-4 px-4 text-dark-700">EOF-001</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹450</td>
                                <td class="text-center py-4 px-4"><input type="number" min="1" value="10" class="w-16 px-2 py-1 border border-dark-200 rounded text-center" /></td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹4,500</td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 font-medium text-xs">Remove</button>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">Brake Pad Set</td>
                                <td class="py-4 px-4 text-dark-700">BPS-002</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹1,200</td>
                                <td class="text-center py-4 px-4"><input type="number" min="1" value="5" class="w-16 px-2 py-1 border border-dark-200 rounded text-center" /></td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹6,000</td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 font-medium text-xs">Remove</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <button class="btn-secondary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                    </svg>
                    Add Item
                </button>
            </div>

            <!-- Shipping Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Shipping Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-dark-900 mb-2">Shipping Address</label>
                        <textarea rows="3" class="input-field" placeholder="Enter complete shipping address...">123, Auto Parts Street, Dadar East, Mumbai 400014</textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Shipping Method</label>
                        <select class="input-field">
                            <option selected>Standard Delivery</option>
                            <option>Express Delivery</option>
                            <option>Overnight Delivery</option>
                            <option>Self Pickup</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Shipping Cost</label>
                        <input type="number" placeholder="0.00" class="input-field" value="500" />
                    </div>
                </div>
            </div>

            <!-- Payment Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Information</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Method</label>
                        <select class="input-field">
                            <option selected>Credit</option>
                            <option>Bank Transfer</option>
                            <option>Check</option>
                            <option>Digital Wallet</option>
                            <option>Cash</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Discount (%)</label>
                        <input type="number" placeholder="0" class="input-field" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-dark-900 mb-2">Order Notes (Optional)</label>
                        <textarea rows="3" class="input-field" placeholder="Add any special instructions or notes..."></textarea>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <a href="/orders" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </a>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Create Order
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Initialize create order form
    }
}
