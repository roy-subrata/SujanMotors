@page "/orders/{id}/view"
@rendermode InteractiveServer

<PageTitle>View Order - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Order Details</h1>
            <p class="text-dark-500 mt-1">ORD-2024-152 • Sharma Auto Parts • Dec 20, 2024</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/orders" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Back
            </a>
            <a href="/orders/{id}/edit" class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Edit Order
            </a>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Order Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Order Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-success">Delivered</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Order ID</p>
                        <p class="text-dark-900 font-semibold">ORD-2024-152</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Order Date</p>
                        <p class="text-dark-900 font-semibold">Dec 20, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Delivery Date</p>
                        <p class="text-dark-900 font-semibold">Dec 27, 2024</p>
                    </div>
                </div>
            </div>

            <!-- Order Summary -->
            <div class="card bg-green-50 border-l-4 border-green-500">
                <h3 class="text-lg font-bold text-green-900 mb-4">Order Summary</h3>
                <div class="space-y-2 text-sm">
                    <div class="flex items-center justify-between">
                        <p class="text-green-800">Subtotal</p>
                        <p class="font-semibold text-green-900">₹10,500</p>
                    </div>
                    <div class="flex items-center justify-between">
                        <p class="text-green-800">Tax (18%)</p>
                        <p class="font-semibold text-green-900">₹1,890</p>
                    </div>
                    <div class="flex items-center justify-between">
                        <p class="text-green-800">Shipping</p>
                        <p class="font-semibold text-green-900">₹500</p>
                    </div>
                    <div className="border-t border-green-200 pt-2 mt-2 flex items-center justify-between">
                        <p className="font-semibold text-green-900">Order Total</p>
                        <p className="text-lg font-bold text-green-600">₹12,890</p>
                    </div>
                </div>
            </div>

            <!-- Customer Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Customer Details</h3>
                <div class="space-y-3 text-sm">
                    <div>
                        <p class="text-dark-500 font-medium mb-1">Customer Name</p>
                        <p class="text-dark-900 font-semibold">Sharma Auto Parts</p>
                    </div>
                    <div>
                        <p class="text-dark-500 font-medium mb-1">Contact Person</p>
                        <p class="text-dark-900 font-semibold">Rajesh Sharma</p>
                    </div>
                    <div>
                        <p class="text-dark-500 font-medium mb-1">Email</p>
                        <p class="text-dark-900 font-semibold">sharma@autoparts.com</p>
                    </div>
                    <div>
                        <p class="text-dark-500 font-medium mb-1">Phone</p>
                        <p class="text-dark-900 font-semibold">+91 98765 43210</p>
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Order Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Order Information</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Order ID</p>
                        <p class="text-dark-900 font-semibold">ORD-2024-152</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Customer</p>
                        <p class="text-dark-900 font-semibold">Sharma Auto Parts</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Order Date</p>
                        <p class="text-dark-900 font-semibold">Dec 20, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Delivery Date</p>
                        <p class="text-dark-900 font-semibold">Dec 27, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Payment Terms</p>
                        <p class="text-dark-900 font-semibold">30 Days</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-1">Payment Status</p>
                        <span class="badge-success">Paid</span>
                    </div>
                </div>
            </div>

            <!-- Order Items -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Order Items</h3>

                <div class="overflow-x-auto">
                    <table class="w-full text-sm">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Part Name</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">SKU</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Unit Price</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Qty</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Amount</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">Engine Oil Filter</td>
                                <td class="py-4 px-4 text-dark-700">EOF-001</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹450</td>
                                <td class="text-center py-4 px-4 text-dark-700">10</td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹4,500</td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">Brake Pad Set</td>
                                <td class="py-4 px-4 text-dark-700">BPS-002</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹1,200</td>
                                <td class="text-center py-4 px-4 text-dark-700">5</td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹6,000</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Shipping Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Shipping Details</h3>

                <div className="bg-dark-50 rounded-lg p-4 space-y-4">
                    <div>
                        <p className="text-xs text-dark-500 font-medium\">Shipping Address</p>
                        <p className="text-sm font-semibold text-dark-900\">123, Auto Parts Street, Dadar East, Mumbai 400014</p>
                    </div>
                    <div>
                        <p className="text-xs text-dark-500 font-medium\">Shipping Method</p>
                        <p className="text-sm font-semibold text-dark-900\">Standard Delivery</p>
                    </div>
                    <div>
                        <p className="text-xs text-dark-500 font-medium\">Tracking Number</p>
                        <p className="text-sm font-semibold text-dark-900\">TRACK-2024-152-001</p>
                    </div>
                    <div>
                        <p className="text-xs text-dark-500 font-medium\">Estimated Delivery</p>
                        <p className="text-sm font-semibold text-dark-900\">Dec 27, 2024</p>
                    </div>
                </div>
            </div>

            <!-- Order Timeline -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Order Timeline</h3>

                <div className="space-y-4">
                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                            <div className="w-0.5 h-12 bg-dark-200 mt-2"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Order Confirmed</p>
                            <p className="text-sm text-dark-500">Dec 20, 2024 10:30 AM</p>
                        </div>
                    </div>

                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                            <div className="w-0.5 h-12 bg-dark-200 mt-2"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Order Shipped</p>
                            <p className="text-sm text-dark-500">Dec 23, 2024 02:15 PM</p>
                        </div>
                    </div>

                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Order Delivered</p>
                            <p className="text-sm text-dark-500">Dec 27, 2024 05:45 PM</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Order Notes -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Order Notes</h3>
                <p class="text-dark-700">Order processed and dispatched on time. All items verified before shipment. Customer confirmed receipt on Dec 27, 2024.</p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load order details
    }
}
