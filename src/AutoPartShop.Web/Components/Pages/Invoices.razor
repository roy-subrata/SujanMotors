    <!-- Filters Section -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-4">Filters</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Search Invoice</label>
                <input type="text" placeholder="Search by Invoice # or Customer..." class="input-field" />
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                <select class="input-field">
                    <option selected>All Status</option>
                    <option>Draft</option>
                    <option>Sent</option>
                    <option>Viewed</option>
                    <option>Paid</option>
                    <option>Partially Paid</option>
                    <option>Overdue</option>
                    <option>Cancelled</option>
