@page "/customers/{id}/edit"
@rendermode InteractiveServer

<PageTitle>Edit Customer - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Edit Customer</h1>
            <p class="text-dark-500 mt-1">C-001 • Sharma Auto Parts</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/customers" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </a>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Customer Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Customer Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-success">Active</span>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Change Status</label>
                        <select class="input-field">
                            <option selected>Active</option>
                            <option>Inactive</option>
                            <option>Suspended</option>
                        </select>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Customer Type</p>
                        <span class="badge-info">Retail</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Customer ID</p>
                        <p class="text-dark-900 font-semibold">C-001</p>
                    </div>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="card bg-red-50 border-l-4 border-red-500">
                <h3 class="text-lg font-bold text-red-900 mb-4">Danger Zone</h3>
                <button class="w-full btn-danger flex items-center justify-center text-sm border border-red-300 bg-red-100 text-red-700 hover:bg-red-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Delete This Customer
                </button>
                <p class="text-xs text-red-700 mt-2">This action cannot be undone. This will permanently delete the customer record.</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Basic Information Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Basic Information</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Company/Business Name *</label>
                        <input type="text" value="Sharma Auto Parts" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Contact Person Name *</label>
                        <input type="text" value="Rajesh Sharma" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Email Address *</label>
                        <input type="email" value="sharma@autoparts.com" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Phone Number *</label>
                        <input type="tel" value="+91 98765 43210" class="input-field" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-dark-900 mb-2">Website (Optional)</label>
                        <input type="url" value="https://www.sharmaparts.com" class="input-field" />
                    </div>
                </div>
            </div>

            <!-- Address Information Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Address Information</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-dark-900 mb-2">Street Address *</label>
                        <input type="text" value="123, Auto Parts Street, Dadar East" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">City *</label>
                        <select class="input-field">
                            <option selected>Mumbai</option>
                            <option>Delhi</option>
                            <option>Bangalore</option>
                            <option>Pune</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">State *</label>
                        <select class="input-field">
                            <option selected>Maharashtra</option>
                            <option>Delhi</option>
                            <option>Karnataka</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Postal Code *</label>
                        <input type="text" value="400014" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Country *</label>
                        <input type="text" value="India" class="input-field" disabled />
                    </div>
                </div>
            </div>

            <!-- Business Information Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Business Information</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">GST Number (Optional)</label>
                        <input type="text" value="27AACSN1234C1Z0" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">PAN Number (Optional)</label>
                        <input type="text" value="AABCS5555A" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Credit Limit (₹)</label>
                        <input type="number" value="500000" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Terms (Days)</label>
                        <input type="number" value="30" class="input-field" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="block text-sm font-medium text-dark-900 mb-2">Business Description (Optional)</label>
                        <textarea rows="3" class="input-field">Leading supplier of automotive spare parts and components. Serves retail and wholesale customers across Mumbai region.</textarea>
                    </div>
                </div>
            </div>

            <!-- Bank Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Bank Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Bank Name</label>
                        <input type="text" value="HDFC Bank" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Account Holder Name</label>
                        <input type="text" value="Sharma Auto Parts" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Account Number</label>
                        <input type="text" value="1023456789" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">IFSC Code</label>
                        <input type="text" value="HDFC0000001" class="input-field" />
                    </div>
                </div>
            </div>

            <!-- Contact Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Additional Contact Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Secondary Contact Person</label>
                        <input type="text" value="Priya Sharma" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Secondary Phone Number</label>
                        <input type="tel" value="+91 98765 11111" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Alternate Email</label>
                        <input type="email" value="priya@autoparts.com" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Fax Number (Optional)</label>
                        <input type="tel" placeholder="Fax number" class="input-field" />
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <a href="/customers" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </a>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load customer data for editing
    }
}
