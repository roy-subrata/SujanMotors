@page "/procurement/grn"

<PageTitle>Goods Receipt Note - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Goods Receipt Note</h1>
            <p class="text-dark-500 mt-1">Track received shipments and update inventory</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Create GRN
            </button>
        </div>
    </div>

    <!-- Filters Card -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Search GRN</label>
                <input type="text" placeholder="Filter by GRN #, PO #, or Supplier..." class="input-field" />
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                <select class="input-field">
                    <option>All Status</option>
                    <option>Draft</option>
                    <option>Pending QC</option>
                    <option>Completed</option>
                    <option>Rejected</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Date Range</label>
                <select class="input-field">
                    <option>Last 7 Days</option>
                    <option>Last 30 Days</option>
                    <option>Last 3 Months</option>
                    <option>Custom Range</option>
                </select>
            </div>
            <div class="flex items-end">
                <button class="btn-primary w-full">Apply Filters</button>
            </div>
        </div>
    </div>

    <!-- GRN Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="card-sm">
            <h4 class="font-semibold text-dark-900 mb-3">Total Receipts</h4>
            <p class="text-3xl font-bold text-primary-600">58</p>
            <p class="text-dark-500 text-xs mt-2">This month</p>
        </div>

        <div class="card-sm">
            <h4 class="font-semibold text-dark-900 mb-3">Pending QC</h4>
            <p class="text-3xl font-bold text-orange-600">5</p>
            <p class="text-dark-500 text-xs mt-2">Awaiting quality check</p>
        </div>

        <div class="card-sm">
            <h4 class="font-semibold text-dark-900 mb-3">Rejected Items</h4>
            <p class="text-3xl font-bold text-red-600">3</p>
            <p class="text-dark-500 text-xs mt-2">Quality issues found</p>
        </div>

        <div class="card-sm">
            <h4 class="font-semibold text-dark-900 mb-3">Total Units Received</h4>
            <p class="text-3xl font-bold text-green-600">1,245</p>
            <p class="text-dark-500 text-xs mt-2">This month</p>
        </div>
    </div>

    <!-- GRN List -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-6">Goods Receipt Notes</h3>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-dark-200">
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">GRN #</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">PO #</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Supplier</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Units</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Status</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Received Date</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-dark-200">
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">GRN-2024-001</td>
                        <td class="py-4 px-4 text-dark-700">PO-2024-001</td>
                        <td class="py-4 px-4 text-dark-700">Parts Direct Inc.</td>
                        <td class="py-4 px-4 text-dark-700">500</td>
                        <td class="py-4 px-4"><span class="badge-success">Completed</span></td>
                        <td class="py-4 px-4 text-sm text-dark-500">Nov 18, 2024</td>
                        <td class="py-4 px-4">
                            <a href="#" class="text-primary-600 hover:text-primary-700 font-semibold text-sm">View</a>
                        </td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">GRN-2024-002</td>
                        <td class="py-4 px-4 text-dark-700">PO-2024-002</td>
                        <td class="py-4 px-4 text-dark-700">Auto Components Ltd.</td>
                        <td class="py-4 px-4 text-dark-700">200</td>
                        <td class="py-4 px-4"><span class="badge-warning">Pending QC</span></td>
                        <td class="py-4 px-4 text-sm text-dark-500">Nov 21, 2024</td>
                        <td class="py-4 px-4">
                            <a href="#" class="text-primary-600 hover:text-primary-700 font-semibold text-sm">Inspect</a>
                        </td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">GRN-2024-003</td>
                        <td class="py-4 px-4 text-dark-700">PO-2024-003</td>
                        <td class="py-4 px-4 text-dark-700">Global Auto Parts</td>
                        <td class="py-4 px-4 text-dark-700">312</td>
                        <td class="py-4 px-4"><span class="badge-success">Completed</span></td>
                        <td class="py-4 px-4 text-sm text-dark-500">Nov 19, 2024</td>
                        <td class="py-4 px-4">
                            <a href="#" class="text-primary-600 hover:text-primary-700 font-semibold text-sm">View</a>
                        </td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">GRN-2024-004</td>
                        <td class="py-4 px-4 text-dark-700">PO-2024-004</td>
                        <td class="py-4 px-4 text-dark-700">Parts Direct Inc.</td>
                        <td class="py-4 px-4 text-dark-700">100</td>
                        <td class="py-4 px-4"><span class="badge-danger">Rejected</span></td>
                        <td class="py-4 px-4 text-sm text-dark-500">Nov 17, 2024</td>
                        <td class="py-4 px-4">
                            <a href="#" class="text-primary-600 hover:text-primary-700 font-semibold text-sm">Details</a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-between mt-6 pt-6 border-t border-dark-200">
            <p class="text-sm text-dark-500">Showing 1-4 of 58 Goods Receipt Notes</p>
            <div class="flex gap-2">
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-100">Previous</button>
                <button class="px-3 py-2 bg-primary-600 text-white rounded-lg">1</button>
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-100">2</button>
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-100">3</button>
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-100">Next</button>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Load Goods Receipt Note data
    }
}
