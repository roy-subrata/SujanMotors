@page "/procurement/payments/{id}/edit"

<PageTitle>Edit Supplier Payment - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Edit Payment</h1>
            <p class="text-dark-500 mt-1">PAY-2024-001 • Update payment details</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Payment Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Payment Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-success">Completed</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Payment Reference</p>
                        <p class="text-dark-900 font-semibold">PAY-2024-001</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Payment Date</p>
                        <p class="text-dark-900 font-semibold">Nov 18, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Supplier</p>
                        <p class="text-dark-900 font-semibold">Parts Direct Inc.</p>
                    </div>
                </div>
            </div>

            <!-- Payment Summary -->
            <div class="card bg-green-50 border-l-4 border-green-500">
                <h3 class="text-lg font-bold text-green-900 mb-3">Payment Summary</h3>
                <div class="space-y-2 text-sm">
                    <div class="flex items-center justify-between">
                        <p class="text-green-800">Total Invoices</p>
                        <p class="font-semibold text-green-900">₹31,000</p>
                    </div>
                    <div class="flex items-center justify-between">
                        <p class="text-green-800">Discount Applied</p>
                        <p class="font-semibold text-green-900">₹0</p>
                    </div>
                    <div className="border-t border-green-200 pt-2 mt-2 flex items-center justify-between">
                        <p className="font-semibold text-green-900">Amount Paid</p>
                        <p className="text-lg font-bold text-green-600">₹31,000</p>
                    </div>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="card bg-red-50 border-l-4 border-red-500">
                <h3 class="text-lg font-bold text-red-900 mb-4">Danger Zone</h3>
                <button class="w-full btn-danger flex items-center justify-center text-sm border border-red-300 bg-red-100 text-red-700 hover:bg-red-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Delete This Payment
                </button>
                <p class="text-xs text-red-700 mt-2">This action cannot be undone. This will permanently delete the payment record.</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Payment Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Reference</label>
                        <input type="text" value="PAY-2024-001" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Supplier *</label>
                        <input type="text" value="Parts Direct Inc." class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Date *</label>
                        <input type="date" value="2024-11-18" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Status</label>
                        <select class="input-field">
                            <option selected>Completed</option>
                            <option>Pending</option>
                            <option>Processing</option>
                            <option>Failed</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Paid Invoices Section -->
            <div class="card">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-bold text-dark-900">Paid Invoices</h3>
                    <p class="text-sm text-dark-500">(Read-only for completed payments)</p>
                </div>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Invoice #</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">PO #</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Amount</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Due Date</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-002</td>
                                <td class="py-4 px-4 text-dark-700">PO-2024-003</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹22,500</td>
                                <td class="py-4 px-4 text-dark-700">Nov 18, 2024</td>
                                <td class="text-center py-4 px-4">
                                    <span class="badge-success">Paid</span>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-003</td>
                                <td class="py-4 px-4 text-dark-700">PO-2024-002</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹8,500</td>
                                <td class="py-4 px-4 text-dark-700">Nov 22, 2024</td>
                                <td class="text-center py-4 px-4">
                                    <span class="badge-success">Paid</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Payment Terms & Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Terms & Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Method *</label>
                        <select class="input-field">
                            <option>Bank Transfer</option>
                            <option>Check</option>
                            <option>Credit Card</option>
                            <option>Cash</option>
                            <option>Digital Wallet</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Currency</label>
                        <input type="text" value="INR (₹)" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Discount Amount</label>
                        <input type="number" placeholder="0.00" class="input-field" value="0" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Late Payment Charges</label>
                        <input type="number" placeholder="0.00" class="input-field" value="0" />
                    </div>
                </div>
            </div>

            <!-- Bank Account Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Bank Account Details</h3>

                <div className="bg-dark-50 rounded-lg p-4 space-y-4">
                    <div>
                        <p className="text-xs text-dark-500 font-medium\">Bank Name</p>
                        <p className="text-sm font-semibold text-dark-900\">HDFC Bank</p>
                    </div>
                    <div>
                        <p className="text-xs text-dark-500 font-medium\">Account Number</p>
                        <p className="text-sm font-semibold text-dark-900\">10234567890123</p>
                    </div>
                    <div>
                        <p className="text-xs text-dark-500 font-medium\">IFSC Code</p>
                        <p className="text-sm font-semibold text-dark-900\">HDFC0000001</p>
                    </div>
                    <div>
                        <p className="text-xs text-dark-500 font-medium\">Account Holder Name</p>
                        <p className="text-sm font-semibold text-dark-900\">Parts Direct Inc.</p>
                    </div>
                </div>
            </div>

            <!-- Transaction Reference Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Transaction Reference</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Transaction Reference #</label>
                        <input type="text" value="TXN123456789" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Check/Draft Number (if applicable)</label>
                        <input type="text" placeholder="e.g., Check # 1001" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Notes</label>
                        <textarea rows="3" class="input-field" placeholder="Add any additional payment notes...">Payment for outstanding invoices INV-2024-002 and INV-2024-003. Transfer completed successfully through HDFC Bank.</textarea>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <button type="button" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </button>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load payment data for editing
    }
}
