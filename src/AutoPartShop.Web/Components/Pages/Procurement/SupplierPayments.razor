@page "/procurement/payments"

<PageTitle>Supplier Payments - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Supplier Payments</h1>
            <p class="text-dark-500 mt-1">Track and manage supplier payments</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                Record Payment
            </button>
        </div>
    </div>

    <!-- Filters Card -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Search Payment</label>
                <input type="text" placeholder="Filter by Supplier or PO #..." class="input-field" />
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                <select class="input-field">
                    <option>All Status</option>
                    <option>Pending</option>
                    <option>Scheduled</option>
                    <option>Paid</option>
                    <option>Overdue</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Payment Method</label>
                <select class="input-field">
                    <option>All Methods</option>
                    <option>Bank Transfer</option>
                    <option>Check</option>
                    <option>Credit Card</option>
                    <option>Cash</option>
                </select>
            </div>
            <div class="flex items-end">
                <button class="btn-primary w-full">Apply Filters</button>
            </div>
        </div>
    </div>

    <!-- Payment Statistics -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <div class="card-sm">
            <h4 class="font-semibold text-dark-900 mb-3">Total Payable</h4>
            <p class="text-3xl font-bold text-primary-600">₹85.5L</p>
            <p class="text-dark-500 text-xs mt-2">Outstanding amount</p>
        </div>

        <div class="card-sm">
            <h4 class="font-semibold text-dark-900 mb-3">Overdue</h4>
            <p class="text-3xl font-bold text-red-600">₹12.3L</p>
            <p class="text-dark-500 text-xs mt-2">Past due date</p>
        </div>

        <div class="card-sm">
            <h4 class="font-semibold text-dark-900 mb-3">Paid This Month</h4>
            <p class="text-3xl font-bold text-green-600">₹45.8L</p>
            <p class="text-dark-500 text-xs mt-2">Total payments made</p>
        </div>

        <div class="card-sm">
            <h4 class="font-semibold text-dark-900 mb-3">Avg Payment Days</h4>
            <p class="text-3xl font-bold text-blue-600">8.5 days</p>
            <p class="text-dark-500 text-xs mt-2">From invoice date</p>
        </div>
    </div>

    <!-- Payment Status Overview -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Status Overview</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
                <div class="flex items-center justify-between mb-3">
                    <p class="font-medium text-dark-900">Pending Payments</p>
                    <span class="badge-warning">15 invoices</span>
                </div>
                <div class="space-y-2">
                    <div>
                        <div class="flex items-center justify-between text-sm mb-1">
                            <span class="text-dark-700">Parts Direct Inc.</span>
                            <span class="font-semibold text-dark-900">₹15,000</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-orange-500 h-2 rounded-full" style="width: 35%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between text-sm mb-1">
                            <span class="text-dark-700">Auto Components Ltd.</span>
                            <span class="font-semibold text-dark-900">₹8,500</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-orange-500 h-2 rounded-full" style="width: 20%"></div>
                        </div>
                    </div>
                </div>
            </div>

            <div>
                <div class="flex items-center justify-between mb-3">
                    <p class="font-medium text-dark-900">Overdue Payments</p>
                    <span class="badge-danger">5 invoices</span>
                </div>
                <div class="space-y-2">
                    <div>
                        <div class="flex items-center justify-between text-sm mb-1">
                            <span class="text-dark-700">Global Auto Parts</span>
                            <span class="font-semibold text-dark-900">₹6,200 (8 days)</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-red-500 h-2 rounded-full" style="width: 45%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between text-sm mb-1">
                            <span class="text-dark-700">Premium Supplies Co.</span>
                            <span class="font-semibold text-dark-900">₹4,100 (15 days)</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-red-500 h-2 rounded-full" style="width: 30%"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Payments List -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-6">Recent Payments</h3>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-dark-200">
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Invoice #</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Supplier</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Amount</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Due Date</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Status</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Payment Method</th>
                        <th class="text-left py-4 px-4 font-semibold text-dark-900">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-dark-200">
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-001</td>
                        <td class="py-4 px-4 text-dark-700">Parts Direct Inc.</td>
                        <td class="py-4 px-4 text-dark-700">₹15,000</td>
                        <td class="py-4 px-4 text-sm text-dark-500">Nov 20, 2024</td>
                        <td class="py-4 px-4"><span class="badge-success">Paid</span></td>
                        <td class="py-4 px-4 text-dark-700">Bank Transfer</td>
                        <td class="py-4 px-4">
                            <a href="#" class="text-primary-600 hover:text-primary-700 font-semibold text-sm">View</a>
                        </td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-002</td>
                        <td class="py-4 px-4 text-dark-700">Auto Components Ltd.</td>
                        <td class="py-4 px-4 text-dark-700">₹8,500</td>
                        <td class="py-4 px-4 text-sm text-dark-500">Nov 22, 2024</td>
                        <td class="py-4 px-4"><span class="badge-warning">Pending</span></td>
                        <td class="py-4 px-4 text-dark-700">-</td>
                        <td class="py-4 px-4">
                            <a href="#" class="text-primary-600 hover:text-primary-700 font-semibold text-sm">Pay</a>
                        </td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-003</td>
                        <td class="py-4 px-4 text-dark-700">Global Auto Parts</td>
                        <td class="py-4 px-4 text-dark-700">₹12,300</td>
                        <td class="py-4 px-4 text-sm text-dark-500">Nov 18, 2024</td>
                        <td class="py-4 px-4"><span class="badge-danger">Overdue</span></td>
                        <td class="py-4 px-4 text-dark-700">-</td>
                        <td class="py-4 px-4">
                            <a href="#" class="text-primary-600 hover:text-primary-700 font-semibold text-sm">Pay Now</a>
                        </td>
                    </tr>
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-004</td>
                        <td class="py-4 px-4 text-dark-700">Premium Supplies Co.</td>
                        <td class="py-4 px-4 text-dark-700">₹6,200</td>
                        <td class="py-4 px-4 text-sm text-dark-500">Nov 25, 2024</td>
                        <td class="py-4 px-4"><span class="badge-info">Scheduled</span></td>
                        <td class="py-4 px-4 text-dark-700">Bank Transfer</td>
                        <td class="py-4 px-4">
                            <a href="#" class="text-primary-600 hover:text-primary-700 font-semibold text-sm">View</a>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="flex items-center justify-between mt-6 pt-6 border-t border-dark-200">
            <p class="text-sm text-dark-500">Showing 1-4 of 28 Payments</p>
            <div class="flex gap-2">
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-100">Previous</button>
                <button class="px-3 py-2 bg-primary-600 text-white rounded-lg">1</button>
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-100">2</button>
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-100">Next</button>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Load Supplier Payments data
    }
}
