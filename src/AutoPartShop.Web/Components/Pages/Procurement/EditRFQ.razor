@page "/procurement/rfq/{id}/edit"

<PageTitle>Edit Request for Quote - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Edit Request for Quote</h1>
            <p class="text-dark-500 mt-1">RFQ-2024-001 • Update quote details</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- RFQ Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">RFQ Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-success">Sent to Suppliers</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">RFQ Number</p>
                        <p class="text-dark-900 font-semibold">RFQ-2024-001</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Created Date</p>
                        <p class="text-dark-900 font-semibold">Nov 15, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Created By</p>
                        <p class="text-dark-900 font-semibold">Admin User</p>
                    </div>
                </div>
            </div>

            <!-- Quote Progress -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Quote Responses</h3>
                <div class="space-y-3">
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Received</p>
                            <span class="font-bold text-dark-900">3 / 4</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-3">
                            <div class="bg-green-500 h-3 rounded-full" style="width: 75%"></div>
                        </div>
                    </div>

                    <div className="pt-3 border-t border-dark-200">
                        <p className="text-xs text-dark-500 space-y-2">
                            <div className="flex items-center space-x-2">
                                <span className="w-2 h-2 bg-green-500 rounded-full"></span>
                                <span>Parts Direct Inc. - Quoted</span>
                            </div>
                            <div className="flex items-center space-x-2">
                                <span className="w-2 h-2 bg-green-500 rounded-full"></span>
                                <span>Auto Components Ltd. - Quoted</span>
                            </div>
                            <div className="flex items-center space-x-2">
                                <span className="w-2 h-2 bg-green-500 rounded-full"></span>
                                <span>Global Auto Parts - Quoted</span>
                            </div>
                            <div className="flex items-center space-x-2">
                                <span className="w-2 h-2 bg-orange-500 rounded-full"></span>
                                <span>Premium Supplies Co. - Pending</span>
                            </div>
                        </p>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card space-y-2">
                <button class="w-full btn-primary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                    </svg>
                    Compare Quotes
                </button>
                <button class="w-full btn-secondary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8m0 8l-4-4m4 4l4-4"></path>
                    </svg>
                    Send Reminder
                </button>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- RFQ Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">RFQ Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">RFQ Number</label>
                        <input type="text" value="RFQ-2024-001" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">RFQ Date</label>
                        <input type="date" value="2024-11-15" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Quote Deadline *</label>
                        <input type="date" value="2024-11-22" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Priority</label>
                        <select class="input-field">
                            <option>Normal</option>
                            <option selected>Urgent</option>
                            <option>Very Urgent</option>
                        </select>
                    </div>
                </div>

                <div className="mt-6">
                    <label class="block text-sm font-medium text-dark-900 mb-2">Additional Notes</label>
                    <textarea rows="3" class="input-field">Please provide competitive pricing for bulk orders. Include shipping cost in your quote.</textarea>
                </div>
            </div>

            <!-- Items Section -->
            <div class="card">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-bold text-dark-900">Items</h3>
                    <button class="btn-primary flex items-center justify-center text-sm">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        Add Item
                    </button>
                </div>

                <div class="space-y-4">
                    <!-- Item 1 -->
                    <div class="border border-dark-200 rounded-lg p-4">
                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <div>
                                <label class="block text-sm font-medium text-dark-900 mb-2">Part</label>
                                <select class="input-field">
                                    <option selected>Engine Oil Filter (EOF-001)</option>
                                    <option>Brake Pads Set (BPS-001)</option>
                                    <option>Air Filter (AF-001)</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-dark-900 mb-2">Quantity</label>
                                <input type="number" value="500" class="input-field" />
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mb-4">
                            <div>
                                <label class="block text-sm font-medium text-dark-900 mb-2">Unit</label>
                                <select class="input-field">
                                    <option selected>Units</option>
                                    <option>Pieces</option>
                                    <option>Boxes</option>
                                </select>
                            </div>
                            <div>
                                <label class="block text-sm font-medium text-dark-900 mb-2">Current Stock</label>
                                <input type="text" value="195 units" class="input-field" disabled />
                            </div>
                        </div>

                        <div>
                            <label class="block text-sm font-medium text-dark-900 mb-2">Specifications</label>
                            <textarea rows="2" class="input-field">High quality engine oil filter. Compatible with standard engines.</textarea>
                        </div>

                        <div class="flex justify-end mt-4">
                            <button class="text-red-600 hover:text-red-700 text-sm font-semibold">Remove Item</button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Supplier Selection -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Suppliers</h3>

                <div class="space-y-3">
                    <label class="flex items-center space-x-3 p-3 border border-green-200 bg-green-50 rounded-lg cursor-pointer">
                        <input type="checkbox" class="w-4 h-4" checked />
                        <div class="flex-1">
                            <p class="font-semibold text-dark-900">Parts Direct Inc.</p>
                            <p class="text-xs text-dark-500">Lead Time: 5 days • Quoted: Nov 15</p>
                        </div>
                        <span class="badge-success text-xs">Quoted</span>
                    </label>

                    <label class="flex items-center space-x-3 p-3 border border-green-200 bg-green-50 rounded-lg cursor-pointer">
                        <input type="checkbox" class="w-4 h-4" checked />
                        <div class="flex-1">
                            <p class="font-semibold text-dark-900">Auto Components Ltd.</p>
                            <p class="text-xs text-dark-500">Lead Time: 7 days • Quoted: Nov 14</p>
                        </div>
                        <span class="badge-success text-xs">Quoted</span>
                    </label>

                    <label class="flex items-center space-x-3 p-3 border border-green-200 bg-green-50 rounded-lg cursor-pointer">
                        <input type="checkbox" class="w-4 h-4" checked />
                        <div class="flex-1">
                            <p class="font-semibold text-dark-900">Global Auto Parts</p>
                            <p class="text-xs text-dark-500">Lead Time: 10 days • Quoted: Nov 13</p>
                        </div>
                        <span class="badge-success text-xs">Quoted</span>
                    </label>

                    <label class="flex items-center space-x-3 p-3 border border-orange-200 bg-orange-50 rounded-lg cursor-pointer">
                        <input type="checkbox" class="w-4 h-4" />
                        <div class="flex-1">
                            <p class="font-semibold text-dark-900">Premium Supplies Co.</p>
                            <p class="text-xs text-dark-500">Lead Time: 6 days • Awaiting response</p>
                        </div>
                        <span class="badge-warning text-xs">Pending</span>
                    </label>
                </div>
            </div>

            <!-- Delivery Terms -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Delivery Terms</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Preferred Delivery Location</label>
                        <select class="input-field">
                            <option selected>Main Warehouse</option>
                            <option>Branch 1</option>
                            <option>Branch 2</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Delivery Method</label>
                        <select class="input-field">
                            <option selected>Supplier's Choice</option>
                            <option>Our Logistics</option>
                            <option>Third Party</option>
                        </select>
                    </div>
                </div>

                <div class="flex items-center space-x-2 mt-4">
                    <input type="checkbox" class="w-4 h-4" checked />
                    <label class="text-sm text-dark-900">Include shipping costs in quote</label>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <button type="button" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </button>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load RFQ data for editing
    }
}
