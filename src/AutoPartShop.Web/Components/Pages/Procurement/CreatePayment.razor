@page "/procurement/payments/create"
@rendermode InteractiveServer

<PageTitle>Create Supplier Payment - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Record Supplier Payment</h1>
            <p class="text-dark-500 mt-1">Process payment for supplier invoices</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Record Payment
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Payment Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Payment Details</h3>
                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Reference *</label>
                        <input type="text" placeholder="Auto-generated: PAY-2024-XXX" class="input-field" disabled />
                        <p class="text-xs text-dark-500 mt-1">Auto-generated on save</p>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Supplier *</label>
                        <select class="input-field">
                            <option>-- Select Supplier --</option>
                            <option>Parts Direct Inc.</option>
                            <option>Auto Components Ltd.</option>
                            <option>Global Auto Parts</option>
                            <option>Premium Supplies Co.</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Date *</label>
                        <input type="date" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Method *</label>
                        <select class="input-field">
                            <option>-- Select Method --</option>
                            <option>Bank Transfer</option>
                            <option>Check</option>
                            <option>Credit Card</option>
                            <option>Cash</option>
                            <option>Digital Wallet</option>
                        </select>
                    </div>
                </div>
            </div>

            <!-- Payment Summary -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Payment Summary</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex items-center justify-between">
                        <p class="text-dark-700">Invoice Amount</p>
                        <p class="font-semibold text-dark-900">₹0</p>
                    </div>
                    <div class="flex items-center justify-between">
                        <p class="text-dark-700">Discount</p>
                        <p class="font-semibold text-dark-900">₹0</p>
                    </div>
                    <div class="border-t border-dark-200 pt-3 flex items-center justify-between">
                        <p class="font-semibold text-dark-900">Payment Amount</p>
                        <p class="text-lg font-bold text-primary-600">₹0</p>
                    </div>
                </div>
            </div>

            <!-- Notes -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Notes</h3>
                <textarea rows="4" placeholder="Add payment reference notes..." class="input-field"></textarea>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Invoice Selection Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Select Invoices to Pay</h3>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">
                                    <input type="checkbox" class="w-4 h-4" />
                                </th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Invoice #</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">PO #</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Amount</th>
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Due Date</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4">
                                    <input type="checkbox" class="w-4 h-4" />
                                </td>
                                <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-001</td>
                                <td class="py-4 px-4 text-dark-700">PO-2024-001</td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹15,000</td>
                                <td class="py-4 px-4 text-dark-700">Nov 20, 2024</td>
                                <td class="text-center py-4 px-4">
                                    <span class="badge-warning">Pending</span>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4">
                                    <input type="checkbox" class="w-4 h-4" checked />
                                </td>
                                <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-002</td>
                                <td class="py-4 px-4 text-dark-700">PO-2024-003</td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹22,500</td>
                                <td class="py-4 px-4 text-dark-700">Nov 18, 2024</td>
                                <td class="text-center py-4 px-4">
                                    <span class="badge-danger">Overdue</span>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4">
                                    <input type="checkbox" class="w-4 h-4" checked />
                                </td>
                                <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-003</td>
                                <td class="py-4 px-4 text-dark-700">PO-2024-002</td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹8,500</td>
                                <td class="py-4 px-4 text-dark-700">Nov 22, 2024</td>
                                <td class="text-center py-4 px-4">
                                    <span class="badge-warning">Pending</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <p class="text-sm text-dark-500">Selected invoices total: <span class="font-bold text-dark-900">₹31,000</span></p>
            </div>

            <!-- Payment Terms -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Terms & Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Method *</label>
                        <select class="input-field">
                            <option>Bank Transfer</option>
                            <option>Check</option>
                            <option>Credit Card</option>
                            <option>Cash</option>
                            <option>Digital Wallet</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Currency</label>
                        <select class="input-field">
                            <option selected>INR (₹)</option>
                            <option>USD ($)</option>
                            <option>EUR (€)</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Bank Account (if applicable)</label>
                        <select class="input-field">
                            <option>-- Select Bank Account --</option>
                            <option>HDFC Bank - Main Account</option>
                            <option>ICICI Bank - Payments Account</option>
                            <option>Axis Bank - Operating Account</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Check Number (if applicable)</label>
                        <input type="text" placeholder="Check #" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Discount Amount</label>
                        <input type="number" placeholder="0.00" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Late Payment Charges</label>
                        <input type="number" placeholder="0.00" class="input-field" />
                    </div>
                </div>
            </div>

            <!-- Bank Details (for Bank Transfer) -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Supplier Bank Details</h3>

                <div className="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-4">
                    <p className="text-sm text-blue-800">Bank details for Parts Direct Inc.</p>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Bank Name</label>
                        <input type="text" value="HDFC Bank" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Account Number</label>
                        <input type="text" value="10234567890123" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">IFSC Code</label>
                        <input type="text" value="HDFC0001234" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Account Holder Name</label>
                        <input type="text" value="Parts Direct Inc." class="input-field" disabled />
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <button type="button" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </button>
                <button type="button" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-3m-1 4a3 3 0 11-6 0 3 3 0 016 0z"></path>
                    </svg>
                    Save as Draft
                </button>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Record Payment
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Load supplier and invoice data
    }
}
