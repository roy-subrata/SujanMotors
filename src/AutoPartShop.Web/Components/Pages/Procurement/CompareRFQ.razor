@page "/procurement/rfq/{id}/compare"

<PageTitle>Compare Quotes - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Compare Quotes</h1>
            <p class="text-dark-500 mt-1">RFQ-2024-001 • Engine Oil Filter • 500 units</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export Comparison
            </button>
        </div>
    </div>

    <!-- Comparison Info -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
            <div>
                <p class="text-sm text-dark-500 font-medium">Total Quotes Received</p>
                <p class="text-3xl font-bold text-primary-600 mt-2">3</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Lowest Price</p>
                <p class="text-3xl font-bold text-green-600 mt-2">₹1,480</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Highest Price</p>
                <p class="text-3xl font-bold text-red-600 mt-2">₹1,650</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Price Difference</p>
                <p class="text-3xl font-bold text-orange-600 mt-2">₹170 (11.5%)</p>
            </div>
        </div>
    </div>

    <!-- Detailed Comparison Table -->
    <div class="card overflow-hidden">
        <h3 class="text-lg font-bold text-dark-900 mb-6">Detailed Quote Comparison</h3>

        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b-2 border-dark-200 bg-dark-50">
                        <th class="text-left py-4 px-4 font-semibold text-dark-900 w-32">Criteria</th>
                        <th class="text-center py-4 px-4 font-semibold text-dark-900">
                            <div class="text-sm font-bold text-green-600">RECOMMENDED</div>
                            <div class="text-sm font-semibold text-dark-900">Parts Direct Inc.</div>
                        </th>
                        <th class="text-center py-4 px-4 font-semibold text-dark-900">
                            <div class="text-sm font-semibold text-dark-900">Auto Components Ltd.</div>
                        </th>
                        <th class="text-center py-4 px-4 font-semibold text-dark-900">
                            <div class="text-sm font-semibold text-dark-900">Global Auto Parts</div>
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-dark-200">
                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Unit Price</td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-green-600">₹1,480</p>
                            <span class="badge-success text-xs">Best Price</span>
                        </td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">₹1,550</p>
                            <span class="text-xs text-dark-500">+₹70</span>
                        </td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">₹1,650</p>
                            <span class="text-xs text-dark-500">+₹170</span>
                        </td>
                    </tr>

                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Total Amount (500 units)</td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-green-600">₹7,40,000</p>
                        </td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">₹7,75,000</p>
                            <span class="text-xs text-dark-500">+₹35,000</span>
                        </td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">₹8,25,000</p>
                            <span class="text-xs text-dark-500">+₹85,000</span>
                        </td>
                    </tr>

                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Lead Time</td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">5 days</p>
                            <span class="badge-success text-xs">Fastest</span>
                        </td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">7 days</p>
                        </td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">10 days</p>
                        </td>
                    </tr>

                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Minimum Order</td>
                        <td class="text-center py-4 px-4 text-dark-700">100 units</td>
                        <td class="text-center py-4 px-4 text-dark-700">200 units</td>
                        <td class="text-center py-4 px-4 text-dark-700">300 units</td>
                    </tr>

                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Payment Terms</td>
                        <td class="text-center py-4 px-4 text-dark-700">Net 30</td>
                        <td class="text-center py-4 px-4 text-dark-700">Net 15</td>
                        <td class="text-center py-4 px-4 text-dark-700">Net 45</td>
                    </tr>

                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Warranty/Guarantee</td>
                        <td class="text-center py-4 px-4">
                            <span class="badge-success">12 months</span>
                        </td>
                        <td class="text-center py-4 px-4">
                            <span class="badge-secondary">6 months</span>
                        </td>
                        <td class="text-center py-4 px-4">
                            <span class="badge-secondary">6 months</span>
                        </td>
                    </tr>

                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Delivery Cost</td>
                        <td class="text-center py-4 px-4">
                            <span class="text-sm">Free</span>
                        </td>
                        <td class="text-center py-4 px-4">
                            <span class="text-sm">₹5,000</span>
                        </td>
                        <td class="text-center py-4 px-4">
                            <span class="text-sm">₹3,000</span>
                        </td>
                    </tr>

                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">Quality Rating</td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">⭐⭐⭐⭐⭐</p>
                            <span class="text-xs text-dark-500">4.8/5</span>
                        </td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">⭐⭐⭐⭐</p>
                            <span class="text-xs text-dark-500">4.2/5</span>
                        </td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">⭐⭐⭐⭐</p>
                            <span class="text-xs text-dark-500">4.0/5</span>
                        </td>
                    </tr>

                    <tr class="hover:bg-dark-50">
                        <td class="py-4 px-4 font-semibold text-dark-900">On-Time Delivery %</td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-green-600">98%</p>
                        </td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">94%</p>
                        </td>
                        <td class="text-center py-4 px-4">
                            <p class="text-lg font-bold text-dark-900">92%</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- Score Card -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-6">Overall Score</h3>
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
            <!-- Parts Direct Inc. -->
            <div class="border-2 border-green-200 rounded-lg p-6 bg-green-50">
                <p class="font-semibold text-dark-900 mb-4">Parts Direct Inc.</p>
                <div class="space-y-3">
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Price Score</p>
                            <span class="text-sm font-bold text-dark-900">10/10</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-green-500 h-2 rounded-full" style="width: 100%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Quality Score</p>
                            <span class="text-sm font-bold text-dark-900">9/10</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-green-500 h-2 rounded-full" style="width: 90%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Delivery Score</p>
                            <span class="text-sm font-bold text-dark-900">10/10</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-green-500 h-2 rounded-full" style="width: 100%"></div>
                        </div>
                    </div>
                    <div class="border-t border-green-200 pt-3 mt-3">
                        <p class="text-sm text-dark-700">Overall Rating</p>
                        <p class="text-2xl font-bold text-green-600 mt-1">9.3/10</p>
                    </div>
                </div>
                <button class="w-full mt-4 btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Select & Create PO
                </button>
            </div>

            <!-- Auto Components Ltd. -->
            <div class="border-2 border-dark-200 rounded-lg p-6">
                <p class="font-semibold text-dark-900 mb-4">Auto Components Ltd.</p>
                <div class="space-y-3">
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Price Score</p>
                            <span class="text-sm font-bold text-dark-900">7/10</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-orange-500 h-2 rounded-full" style="width: 70%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Quality Score</p>
                            <span class="text-sm font-bold text-dark-900">8/10</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-orange-500 h-2 rounded-full" style="width: 80%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Delivery Score</p>
                            <span class="text-sm font-bold text-dark-900">7/10</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-orange-500 h-2 rounded-full" style="width: 70%"></div>
                        </div>
                    </div>
                    <div class="border-t border-dark-200 pt-3 mt-3">
                        <p class="text-sm text-dark-700">Overall Rating</p>
                        <p class="text-2xl font-bold text-dark-900 mt-1">7.3/10</p>
                    </div>
                </div>
                <button class="w-full mt-4 btn-secondary flex items-center justify-center">
                    Select & Create PO
                </button>
            </div>

            <!-- Global Auto Parts -->
            <div class="border-2 border-dark-200 rounded-lg p-6">
                <p class="font-semibold text-dark-900 mb-4">Global Auto Parts</p>
                <div class="space-y-3">
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Price Score</p>
                            <span class="text-sm font-bold text-dark-900">5/10</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-red-500 h-2 rounded-full" style="width: 50%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Quality Score</p>
                            <span class="text-sm font-bold text-dark-900">7/10</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-red-500 h-2 rounded-full" style="width: 70%"></div>
                        </div>
                    </div>
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Delivery Score</p>
                            <span class="text-sm font-bold text-dark-900">6/10</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-2">
                            <div class="bg-red-500 h-2 rounded-full" style="width: 60%"></div>
                        </div>
                    </div>
                    <div class="border-t border-dark-200 pt-3 mt-3">
                        <p class="text-sm text-dark-700">Overall Rating</p>
                        <p class="text-2xl font-bold text-dark-900 mt-1">6.0/10</p>
                    </div>
                </div>
                <button class="w-full mt-4 btn-secondary flex items-center justify-center">
                    Select & Create PO
                </button>
            </div>
        </div>
    </div>

    <!-- Summary & Recommendation -->
    <div class="card bg-blue-50 border-l-4 border-blue-500">
        <h3 class="text-lg font-bold text-blue-900 mb-3">Recommendation</h3>
        <p class="text-blue-800 mb-3">
            Based on the comparison analysis, <span class="font-semibold">Parts Direct Inc.</span> offers the best overall value with:
        </p>
        <ul class="space-y-2 text-blue-800 ml-4">
            <li>✓ Lowest unit price at ₹1,480 (saving ₹170-₹170 per unit)</li>
            <li>✓ Fastest delivery (5 days)</li>
            <li>✓ Best quality rating (4.8/5)</li>
            <li>✓ Longest warranty (12 months)</li>
            <li>✓ Free delivery</li>
        </ul>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load RFQ and quotes comparison data
    }
}
