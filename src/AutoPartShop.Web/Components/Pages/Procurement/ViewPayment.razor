@page "/procurement/payments/{id}"

<PageTitle>Supplier Payment Details - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Payment Receipt</h1>
            <p class="text-dark-500 mt-1">PAY-2024-001 • Parts Direct Inc. • ₹31,000</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export PDF
            </button>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8m0 8l-4-4m4 4l4-4"></path>
                </svg>
                Print
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H14v2.828a2 2 0 11-2.828-2.828l8.586-8.586z"></path>
                </svg>
                Edit Payment
            </button>
        </div>
    </div>

    <!-- Status Overview -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
            <div>
                <p class="text-sm text-dark-500 font-medium">Status</p>
                <div class="mt-2">
                    <span class="badge-success">Completed</span>
                </div>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Payment Date</p>
                <p class="text-dark-900 font-semibold mt-2">Nov 18, 2024</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Amount Paid</p>
                <p class="text-primary-600 font-bold mt-2">₹31,000</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Payment Method</p>
                <p class="text-dark-900 font-semibold mt-2">Bank Transfer</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Reference #</p>
                <p class="text-dark-900 font-semibold mt-2">TXN123456789</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Payment Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Payment Information</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Payment Reference</p>
                        <p class="text-dark-900 font-semibold mt-1">PAY-2024-001</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Payment Date</p>
                        <p class="text-dark-900 font-semibold mt-1">Nov 18, 2024 03:45 PM</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Processed By</p>
                        <p class="text-dark-900 font-semibold mt-1">Finance Manager</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Payment Status</p>
                        <span class="badge-success mt-1">Completed</span>
                    </div>
                </div>
            </div>

            <!-- Supplier Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Supplier Details</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Supplier Name</p>
                        <p class="text-dark-900 font-semibold mt-1">Parts Direct Inc.</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Contact Person</p>
                        <p class="text-dark-900 font-semibold mt-1">John Smith</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Email</p>
                        <p class="text-dark-900 font-semibold mt-1">john@partsdirect.com</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Phone</p>
                        <p class="text-dark-900 font-semibold mt-1">+91-98765-43210</p>
                    </div>
                </div>
            </div>

            <!-- Payment Summary -->
            <div class="card bg-green-50 border-l-4 border-green-500">
                <h3 class="text-lg font-bold text-green-900 mb-3">Payment Summary</h3>
                <div class="space-y-2 text-sm">
                    <div class="flex items-center justify-between">
                        <p class="text-green-800">Total Invoices</p>
                        <p class="font-semibold text-green-900">₹31,000</p>
                    </div>
                    <div class="flex items-center justify-between">
                        <p class="text-green-800">Discount</p>
                        <p class="font-semibold text-green-900">₹0</p>
                    </div>
                    <div className="border-t border-green-200 pt-2 mt-2 flex items-center justify-between">
                        <p className="font-semibold text-green-900">Amount Paid</p>
                        <p className="text-lg font-bold text-green-600">₹31,000</p>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card space-y-2">
                <button class="w-full btn-primary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                    </svg>
                    Download Receipt
                </button>
                <button class="w-full btn-secondary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M3 14h18m-9-4v8m-7 0a2 2 0 11-4 0 2 2 0 014 0z"></path>
                    </svg>
                    View Bank Details
                </button>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Paid Invoices -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Invoices Paid</h3>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-4 px-4 font-semibold text-dark-900">Invoice #</th>
                                <th class="text-left py-4 px-4 font-semibold text-dark-900">PO #</th>
                                <th class="text-right py-4 px-4 font-semibold text-dark-900">Amount</th>
                                <th class="text-left py-4 px-4 font-semibold text-dark-900">Due Date</th>
                                <th class="text-center py-4 px-4 font-semibold text-dark-900">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-002</td>
                                <td class="py-4 px-4 text-dark-700">PO-2024-003</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹22,500</td>
                                <td class="py-4 px-4 text-dark-700">Nov 18, 2024</td>
                                <td class="text-center py-4 px-4">
                                    <span class="badge-success">Paid</span>
                                </td>
                            </tr>
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">INV-2024-003</td>
                                <td class="py-4 px-4 text-dark-700">PO-2024-002</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹8,500</td>
                                <td class="py-4 px-4 text-dark-700">Nov 22, 2024</td>
                                <td class="text-center py-4 px-4">
                                    <span class="badge-success">Paid</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Payment Method Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Method</h3>

                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Payment Method</p>
                        <span class="badge-primary">Bank Transfer</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Currency</p>
                        <p class="text-dark-900 font-semibold">INR (₹)</p>
                    </div>

                    <div className="bg-dark-50 rounded-lg p-4 space-y-3">
                        <div>
                            <p className="text-xs text-dark-500">From Bank Account</p>
                            <p className="text-sm font-semibold text-dark-900">HDFC Bank - Main Account</p>
                        </div>
                        <div>
                            <p className="text-xs text-dark-500">To Bank Account</p>
                            <p className="text-sm font-semibold text-dark-900">HDFC Bank - A/C: 10234567890123</p>
                        </div>
                        <div>
                            <p className="text-xs text-dark-500">Transaction Reference</p>
                            <p className="text-sm font-semibold text-dark-900">TXN123456789</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Timeline -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Payment Timeline</h3>

                <div className="space-y-4">
                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                            <div className="w-0.5 h-12 bg-dark-200 mt-2"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Payment Initiated</p>
                            <p className="text-sm text-dark-500">Nov 18, 2024 02:30 PM</p>
                        </div>
                    </div>

                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                            <div className="w-0.5 h-12 bg-dark-200 mt-2"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Payment Approved</p>
                            <p className="text-sm text-dark-500">Nov 18, 2024 02:45 PM</p>
                        </div>
                    </div>

                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Payment Completed</p>
                            <p className="text-sm text-dark-500">Nov 18, 2024 03:45 PM</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Payment Notes -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Payment Notes</h3>
                <p class="text-dark-700 bg-dark-50 rounded-lg p-4">Payment for outstanding invoices INV-2024-002 and INV-2024-003. Transfer completed successfully through HDFC Bank.</p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load payment details
    }
}
