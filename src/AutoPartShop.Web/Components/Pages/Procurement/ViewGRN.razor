@page "/procurement/grn/{id}"
@rendermode InteractiveServer

<PageTitle>Goods Receipt Note Details - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Goods Receipt Note</h1>
            <p class="text-dark-500 mt-1">GRN-2024-001 • PO-2024-001 • Engine Oil Filter</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export PDF
            </button>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8m0 8l-4-4m4 4l4-4"></path>
                </svg>
                Print
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H14v2.828a2 2 0 11-2.828-2.828l8.586-8.586z"></path>
                </svg>
                Edit GRN
            </button>
        </div>
    </div>

    <!-- Status Overview -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
            <div>
                <p class="text-sm text-dark-500 font-medium">Status</p>
                <div class="mt-2">
                    <span class="badge-success">Completed</span>
                </div>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">GRN Date</p>
                <p class="text-dark-900 font-semibold mt-2">Nov 18, 2024</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">PO Number</p>
                <p class="text-dark-900 font-semibold mt-2">PO-2024-001</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Units Received</p>
                <p class="text-primary-600 font-bold mt-2">500</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">QC Status</p>
                <p class="text-dark-900 font-semibold mt-2">Passed</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- GRN Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">GRN Information</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">GRN Number</p>
                        <p class="text-dark-900 font-semibold mt-1">GRN-2024-001</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">GRN Date</p>
                        <p class="text-dark-900 font-semibold mt-1">Nov 18, 2024 02:30 PM</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Received By</p>
                        <p class="text-dark-900 font-semibold mt-1">Warehouse Manager</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Inspected By</p>
                        <p class="text-dark-900 font-semibold mt-1">Quality Inspector</p>
                    </div>
                </div>
            </div>

            <!-- Purchase Order Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">PO Details</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">PO Number</p>
                        <p class="text-dark-900 font-semibold mt-1">PO-2024-001</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Supplier</p>
                        <p class="text-dark-900 font-semibold mt-1">Parts Direct Inc.</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">PO Amount</p>
                        <p class="text-dark-900 font-semibold mt-1">₹8,73,200</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Expected Delivery</p>
                        <p class="text-dark-900 font-semibold mt-1">Nov 20, 2024</p>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card space-y-2">
                <button class="w-full btn-primary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                    </svg>
                    Download PDF
                </button>
                <button class="w-full btn-secondary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8m0 8l-4-4m4 4l4-4"></path>
                    </svg>
                    Print GRN
                </button>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Received Items -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Received Items</h3>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-4 px-4 font-semibold text-dark-900">Part</th>
                                <th class="text-right py-4 px-4 font-semibold text-dark-900">PO Qty</th>
                                <th class="text-right py-4 px-4 font-semibold text-dark-900">Received</th>
                                <th class="text-right py-4 px-4 font-semibold text-dark-900">Variance</th>
                                <th class="text-center py-4 px-4 font-semibold text-dark-900">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4">
                                    <p class="font-semibold text-dark-900">Engine Oil Filter</p>
                                    <p class="text-xs text-dark-500">SKU: EOF-001</p>
                                </td>
                                <td class="text-right py-4 px-4 text-dark-700">500</td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">500</td>
                                <td class="text-right py-4 px-4">
                                    <span class="badge-success">0</span>
                                </td>
                                <td class="text-center py-4 px-4">
                                    <span class="badge-success">Accepted</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Quality Inspection Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Quality Inspection</h3>

                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Inspection Status</p>
                        <span class="badge-success">Quality Passed</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Inspection Date</p>
                        <p class="text-dark-900">Nov 18, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Inspected By</p>
                        <p class="text-dark-900">Quality Inspector</p>
                    </div>

                    <div className="border-t border-dark-200 pt-4">
                        <p class="text-sm text-dark-500 font-medium mb-2">Inspection Notes</p>
                        <p class="text-dark-700 bg-dark-50 rounded-lg p-3">All items received are in good condition. Packaging intact. Quantity matches PO. No defects found.</p>
                    </div>
                </div>
            </div>

            <!-- Damage/Defect Report -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Damage/Defect Report</h3>

                <div className="bg-green-50 border border-green-200 rounded-lg p-4">
                    <p className="text-sm text-green-800 font-medium">No Issues Reported</p>
                    <p className="text-sm text-green-700 mt-1">All items received in good condition. No damages or defects found during inspection.</p>
                </div>
            </div>

            <!-- Receiving Notes -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Receiving Notes</h3>
                <p class="text-dark-700 bg-dark-50 rounded-lg p-4">Shipment received at Main Warehouse. All items verified against PO. Inventory updated automatically in system.</p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load GRN details
    }
}
