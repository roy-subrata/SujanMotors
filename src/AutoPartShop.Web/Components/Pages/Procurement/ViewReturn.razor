@page "/procurement/returns/{id}"
@rendermode InteractiveServer

<PageTitle>Purchase Return Details - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Purchase Return</h1>
            <p class="text-dark-500 mt-1">RET-2024-001 • PO-2024-001 • Quality Issue</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export PDF
            </button>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8m0 8l-4-4m4 4l4-4"></path>
                </svg>
                Print
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H14v2.828a2 2 0 11-2.828-2.828l8.586-8.586z"></path>
                </svg>
                Edit Return
            </button>
        </div>
    </div>

    <!-- Status Overview -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
            <div>
                <p class="text-sm text-dark-500 font-medium">Status</p>
                <div class="mt-2">
                    <span class="badge-warning">In Transit</span>
                </div>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Return Date</p>
                <p class="text-dark-900 font-semibold mt-2">Nov 21, 2024</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Original PO</p>
                <p class="text-dark-900 font-semibold mt-2">PO-2024-002</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Refund Amount</p>
                <p class="text-primary-600 font-bold mt-2">₹1,800</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Refund Status</p>
                <p class="text-dark-900 font-semibold mt-2">Pending</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- Return Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Return Information</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Return Number</p>
                        <p class="text-dark-900 font-semibold mt-1">RET-2024-002</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Return Date</p>
                        <p class="text-dark-900 font-semibold mt-1">Nov 21, 2024</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Original PO</p>
                        <p class="text-dark-900 font-semibold mt-1">PO-2024-002</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Return Reason</p>
                        <p class="text-dark-900 font-semibold mt-1">Defective</p>
                    </div>
                </div>
            </div>

            <!-- Supplier Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Supplier Details</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Supplier Name</p>
                        <p class="text-dark-900 font-semibold mt-1">Auto Components Ltd.</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Contact Person</p>
                        <p class="text-dark-900 font-semibold mt-1">Jane Doe</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Email</p>
                        <p class="text-dark-900 font-semibold mt-1">jane@autocomp.com</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Phone</p>
                        <p class="text-dark-900 font-semibold mt-1">+91-98765-54321</p>
                    </div>
                </div>
            </div>

            <!-- Refund Summary -->
            <div class="card bg-blue-50 border-l-4 border-blue-500">
                <h3 class="text-lg font-bold text-blue-900 mb-3">Refund Summary</h3>
                <div class="space-y-2 text-sm">
                    <div class="flex items-center justify-between">
                        <p class="text-blue-800">Subtotal</p>
                        <p class="font-semibold text-blue-900">₹1,800</p>
                    </div>
                    <div class="flex items-center justify-between">
                        <p class="text-blue-800">Shipping Cost</p>
                        <p class="font-semibold text-blue-900">-₹200</p>
                    </div>
                    <div className="border-t border-blue-200 pt-2 mt-2 flex items-center justify-between">
                        <p className="font-semibold text-blue-900">Net Refund</p>
                        <p className="text-lg font-bold text-blue-600">₹1,600</p>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card space-y-2">
                <button class="w-full btn-primary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                    </svg>
                    Download PDF
                </button>
                <button class="w-full btn-secondary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m7 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                    Mark as Received
                </button>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Returned Items -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Returned Items</h3>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-4 px-4 font-semibold text-dark-900">Part</th>
                                <th class="text-right py-4 px-4 font-semibold text-dark-900">Qty Return</th>
                                <th class="text-right py-4 px-4 font-semibold text-dark-900">Unit Price</th>
                                <th class="text-right py-4 px-4 font-semibold text-dark-900">Refund</th>
                                <th class="text-center py-4 px-4 font-semibold text-dark-900">Status</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4">
                                    <p class="font-semibold text-dark-900">Brake Pads Set</p>
                                    <p class="text-xs text-dark-500">SKU: BPS-001</p>
                                </td>
                                <td class="text-right py-4 px-4 text-dark-700">25</td>
                                <td class="text-right py-4 px-4 text-dark-700">₹72</td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹1,800</td>
                                <td class="text-center py-4 px-4">
                                    <span class="badge-warning">In Transit</span>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Return Reason -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Return Reason</h3>

                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Return Reason</p>
                        <span class="badge-danger">Defective</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Issue Type</p>
                        <p class="text-dark-900">Quality Issue</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Description</p>
                        <p class="text-dark-700 bg-dark-50 rounded-lg p-3">The brake pads received have manufacturing defects. The friction material is unevenly distributed and doesn't meet our quality standards. This issue was identified during quality inspection.</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Reference Number</p>
                        <p class="text-dark-900">QI-2024-087</p>
                    </div>
                </div>
            </div>

            <!-- Refund Terms -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Refund Terms</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Refund Method</p>
                        <p class="text-dark-900 font-semibold">Original Payment Method</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Refund Status</p>
                        <span class="badge-warning">Pending</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Expected Refund Date</p>
                        <p class="text-dark-900 font-semibold">Nov 30, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Return Shipping Cost</p>
                        <p class="text-dark-900 font-semibold">₹200</p>
                    </div>

                    <div className="md:col-span-2 bg-dark-50 rounded-lg p-3">
                        <p className="text-sm text-dark-500 font-medium mb-1">Deduct Shipping from Refund</p>
                        <p className="text-dark-900 font-semibold">Yes</p>
                    </div>
                </div>
            </div>

            <!-- Return Timeline -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Return Timeline</h3>

                <div className="space-y-4">
                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                            <div className="w-0.5 h-12 bg-dark-200 mt-2"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Return Initiated</p>
                            <p className="text-sm text-dark-500">Nov 21, 2024 02:30 PM</p>
                        </div>
                    </div>

                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-green-500 rounded-full"></div>
                            <div className="w-0.5 h-12 bg-dark-200 mt-2"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">Return Approved</p>
                            <p className="text-sm text-dark-500">Nov 22, 2024 10:15 AM</p>
                        </div>
                    </div>

                    <div className="flex gap-4">
                        <div className="flex flex-col items-center">
                            <div className="w-3 h-3 bg-orange-500 rounded-full"></div>
                        </div>
                        <div className="flex-1 pt-0.5">
                            <p className="font-semibold text-dark-900">In Transit</p>
                            <p className="text-sm text-dark-500">Shipped to supplier on Nov 22, 2024</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Notes -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Notes</h3>
                <p class="text-dark-700 bg-dark-50 rounded-lg p-4">Return approval granted. Goods expected to reach supplier by Nov 28, 2024. Refund will be processed upon receipt and inspection confirmation.</p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load return details
    }
}
