@page "/procurement/grn/{id}/edit"
@rendermode InteractiveServer

<PageTitle>Edit Goods Receipt Note - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Edit Goods Receipt Note</h1>
            <p class="text-dark-500 mt-1">GRN-2024-001 • Update receipt details</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- GRN Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">GRN Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-success">Completed</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">GRN Number</p>
                        <p class="text-dark-900 font-semibold">GRN-2024-001</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Created Date</p>
                        <p class="text-dark-900 font-semibold">Nov 18, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">PO Reference</p>
                        <p class="text-dark-900 font-semibold">PO-2024-001</p>
                    </div>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="card bg-red-50 border-l-4 border-red-500">
                <h3 class="text-lg font-bold text-red-900 mb-4">Danger Zone</h3>
                <button class="w-full btn-danger flex items-center justify-center text-sm border border-red-300 bg-red-100 text-red-700 hover:bg-red-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Delete This GRN
                </button>
                <p class="text-xs text-red-700 mt-2">This action cannot be undone. This will permanently delete the GRN.</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- GRN Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">GRN Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">GRN Number</label>
                        <input type="text" value="GRN-2024-001" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">PO Number</label>
                        <input type="text" value="PO-2024-001" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Supplier</label>
                        <input type="text" value="Parts Direct Inc." class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Received Date *</label>
                        <input type="date" value="2024-11-18" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Received By *</label>
                        <input type="text" value="Warehouse Manager" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                        <select class="input-field">
                            <option>Draft</option>
                            <option>Pending QC</option>
                            <option selected>Completed</option>
                            <option>Rejected</option>
                        </select>
                    </div>
                </div>

                <div className="mt-6">
                    <label class="block text-sm font-medium text-dark-900 mb-2">Receiving Notes</label>
                    <textarea rows="3" class="input-field">Shipment received at Main Warehouse. All items verified against PO. Inventory updated.</textarea>
                </div>
            </div>

            <!-- Received Items Section -->
            <div class="card">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-bold text-dark-900">Received Items</h3>
                    <button class="btn-primary flex items-center justify-center text-sm">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        Add Item
                    </button>
                </div>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Part</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">PO Qty</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Received</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Variance</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4">
                                    <p class="font-semibold text-dark-900">Engine Oil Filter</p>
                                    <p class="text-xs text-dark-500">EOF-001</p>
                                </td>
                                <td class="text-right py-4 px-4 text-dark-700">500</td>
                                <td class="text-right py-4 px-4">
                                    <input type="number" value="500" class="input-field text-sm text-right w-20" />
                                </td>
                                <td class="text-right py-4 px-4">
                                    <span class="badge-success">0</span>
                                </td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 text-sm">Remove</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <p class="text-center text-dark-500 text-sm">Click "Add Item" to include more parts</p>
            </div>

            <!-- Quality Inspection Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Quality Inspection</h3>

                <div class="space-y-4">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-3">Inspection Status *</label>
                        <div className="space-y-2">
                            <label className="flex items-center space-x-3 p-3 border border-green-200 bg-green-50 rounded-lg cursor-pointer">
                                <input type="radio" name="inspection" value="pass" class="w-4 h-4" checked />
                                <div>
                                    <p className="font-semibold text-dark-900">Quality Passed</p>
                                    <p className="text-xs text-dark-500">All items meet quality standards</p>
                                </div>
                            </label>

                            <label className="flex items-center space-x-3 p-3 border border-dark-200 rounded-lg cursor-pointer hover:bg-dark-50">
                                <input type="radio" name="inspection" value="pending" class="w-4 h-4" />
                                <div>
                                    <p className="font-semibold text-dark-900">Pending QC</p>
                                    <p className="text-xs text-dark-500">Awaiting quality check</p>
                                </div>
                            </label>

                            <label className="flex items-center space-x-3 p-3 border border-dark-200 rounded-lg cursor-pointer hover:bg-dark-50">
                                <input type="radio" name="inspection" value="partial" class="w-4 h-4" />
                                <div>
                                    <p className="font-semibold text-dark-900">Partial Rejection</p>
                                    <p className="text-xs text-dark-500">Some items have quality issues</p>
                                </div>
                            </label>

                            <label className="flex items-center space-x-3 p-3 border border-dark-200 rounded-lg cursor-pointer hover:bg-dark-50">
                                <input type="radio" name="inspection" value="reject" class="w-4 h-4" />
                                <div>
                                    <p className="font-semibold text-dark-900">Full Rejection</p>
                                    <p className="text-xs text-dark-500">All items rejected due to quality</p>
                                </div>
                            </label>
                        </div>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Inspection Notes</label>
                        <textarea rows="3" class="input-field">All items received are in good condition. Packaging intact. Quantity matches PO. No defects found.</textarea>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Inspected By</label>
                        <input type="text" value="Quality Inspector" class="input-field" />
                    </div>
                </div>
            </div>

            <!-- Damage/Defect Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Damage/Defect Report</h3>

                <div class="space-y-4">
                    <div className="flex items-center space-x-2">
                        <input type="checkbox" class="w-4 h-4" />
                        <label class="text-sm text-dark-900">Packaging Damage</label>
                    </div>
                    <div className="flex items-center space-x-2">
                        <input type="checkbox" class="w-4 h-4" />
                        <label class="text-sm text-dark-900">Product Damage</label>
                    </div>
                    <div className="flex items-center space-x-2">
                        <input type="checkbox" class="w-4 h-4" />
                        <label class="text-sm text-dark-900">Missing Items</label>
                    </div>
                    <div className="flex items-center space-x-2">
                        <input type="checkbox" class="w-4 h-4" />
                        <label class="text-sm text-dark-900">Quantity Mismatch</label>
                    </div>
                    <div className="flex items-center space-x-2">
                        <input type="checkbox" class="w-4 h-4" />
                        <label class="text-sm text-dark-900">Wrong Items Received</label>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mt-4 mb-2">Defect Description</label>
                        <textarea rows="3" placeholder="Describe any damages or defects found..." class="input-field"></textarea>
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <button type="button" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </button>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load GRN data for editing
    }
}
