@page "/procurement/purchase-orders/{id}/edit"
@rendermode InteractiveServer

<PageTitle>Edit Purchase Order - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Edit Purchase Order</h1>
            <p class="text-dark-500 mt-1">PO-2024-001 • Update order details</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                Cancel
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                </svg>
                Save Changes
            </button>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- PO Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">PO Status</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Current Status</p>
                        <span class="badge-success">Delivered</span>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">PO Number</p>
                        <p class="text-dark-900 font-semibold">PO-2024-001</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Created Date</p>
                        <p class="text-dark-900 font-semibold">Nov 15, 2024</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Created By</p>
                        <p class="text-dark-900 font-semibold">Admin User</p>
                    </div>
                </div>
            </div>

            <!-- Pricing Summary -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Order Summary</h3>
                <div class="space-y-3 text-sm">
                    <div class="flex items-center justify-between">
                        <p class="text-dark-700">Subtotal</p>
                        <p class="font-semibold text-dark-900">₹7,40,000</p>
                    </div>
                    <div class="flex items-center justify-between">
                        <p class="text-dark-700">Tax (18%)</p>
                        <p class="font-semibold text-dark-900">₹1,33,200</p>
                    </div>
                    <div class="flex items-center justify-between">
                        <p class="text-dark-700">Shipping</p>
                        <p class="font-semibold text-dark-900">Free</p>
                    </div>
                    <div class="border-t border-dark-200 pt-3 flex items-center justify-between">
                        <p class="font-semibold text-dark-900">Total</p>
                        <p class="text-lg font-bold text-primary-600">₹8,73,200</p>
                    </div>
                </div>
            </div>

            <!-- Danger Zone -->
            <div class="card bg-red-50 border-l-4 border-red-500">
                <h3 class="text-lg font-bold text-red-900 mb-4">Danger Zone</h3>
                <button class="w-full btn-danger flex items-center justify-center text-sm border border-red-300 bg-red-100 text-red-700 hover:bg-red-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                    Delete This PO
                </button>
                <p class="text-xs text-red-700 mt-2">This action cannot be undone. This will permanently delete the PO.</p>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- PO Details Section -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">PO Details</h3>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">PO Number</label>
                        <input type="text" value="PO-2024-001" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Supplier *</label>
                        <select class="input-field">
                            <option selected>Parts Direct Inc.</option>
                            <option>Auto Components Ltd.</option>
                            <option>Global Auto Parts</option>
                            <option>Premium Supplies Co.</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">PO Date</label>
                        <input type="date" value="2024-11-15" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Required Delivery Date *</label>
                        <input type="date" value="2024-11-20" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Priority</label>
                        <select class="input-field">
                            <option>Normal</option>
                            <option selected>Urgent</option>
                            <option>Very Urgent</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                        <select class="input-field">
                            <option>Draft</option>
                            <option>Sent</option>
                            <option>Confirmed</option>
                            <option>In Transit</option>
                            <option selected>Delivered</option>
                        </select>
                    </div>
                </div>

                <div className="mt-6">
                    <label class="block text-sm font-medium text-dark-900 mb-2">Notes</label>
                    <textarea rows="3" class="input-field">Please deliver to Main Warehouse. Ensure all items are properly packaged.</textarea>
                </div>
            </div>

            <!-- Line Items Section -->
            <div class="card">
                <div class="flex items-center justify-between mb-6">
                    <h3 class="text-lg font-bold text-dark-900">Line Items</h3>
                    <button class="btn-primary flex items-center justify-center text-sm">
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        Add Item
                    </button>
                </div>

                <div class="overflow-x-auto mb-6">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200 bg-dark-50">
                                <th class="text-left py-3 px-4 font-semibold text-dark-900">Part</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Qty</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Unit Price</th>
                                <th class="text-right py-3 px-4 font-semibold text-dark-900">Amount</th>
                                <th class="text-center py-3 px-4 font-semibold text-dark-900">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4">
                                    <select class="input-field text-sm">
                                        <option selected>Engine Oil Filter (EOF-001)</option>
                                        <option>Brake Pads Set (BPS-001)</option>
                                        <option>Air Filter (AF-001)</option>
                                    </select>
                                </td>
                                <td class="text-right py-4 px-4">
                                    <input type="number" value="500" class="input-field text-sm text-right w-20" />
                                </td>
                                <td class="text-right py-4 px-4">
                                    <input type="number" value="1480" class="input-field text-sm text-right w-24" />
                                </td>
                                <td class="text-right py-4 px-4 font-semibold text-dark-900">₹7,40,000</td>
                                <td class="text-center py-4 px-4">
                                    <button class="text-red-600 hover:text-red-700 text-sm">Remove</button>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <p class="text-center text-dark-500 text-sm">Click "Add Item" to include more parts in this PO</p>
            </div>

            <!-- Supplier Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Supplier Information</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Payment Terms *</label>
                        <select class="input-field">
                            <option selected>Net 30</option>
                            <option>Net 15</option>
                            <option>Net 45</option>
                            <option>COD</option>
                            <option>Advance Payment</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Delivery Location *</label>
                        <select class="input-field">
                            <option selected>Main Warehouse</option>
                            <option>Branch 1</option>
                            <option>Branch 2</option>
                            <option>Direct to Store</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Delivery Method</label>
                        <select class="input-field">
                            <option selected>Supplier's Logistics</option>
                            <option>Our Logistics</option>
                            <option>Third Party</option>
                        </select>
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Shipping Cost</label>
                        <input type="number" value="0" class="input-field" />
                    </div>
                </div>
            </div>

            <!-- Tax & Additional Charges -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Tax & Additional Charges</h3>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Tax Rate (%)</label>
                        <input type="number" value="18" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Tax Amount</label>
                        <input type="number" value="133200" class="input-field" disabled />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Additional Charges</label>
                        <input type="number" value="0" class="input-field" />
                    </div>

                    <div>
                        <label class="block text-sm font-medium text-dark-900 mb-2">Discount Amount</label>
                        <input type="number" value="0" class="input-field" />
                    </div>
                </div>
            </div>

            <!-- Form Actions -->
            <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
                <button type="button" class="btn-secondary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                    Cancel
                </button>
                <button type="submit" class="btn-primary flex items-center justify-center">
                    <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Save Changes
                </button>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load PO data for editing
    }
}
