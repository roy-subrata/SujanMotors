@page "/procurement/rfq/{id}"

<PageTitle>Request for Quote Details - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Request for Quote</h1>
            <p class="text-dark-500 mt-1">RFQ-2024-001 • Engine Oil Filter • 500 units</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"></path>
                </svg>
                Export
            </button>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
                </svg>
                Compare
            </button>
            <button class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H14v2.828a2 2 0 11-2.828-2.828l8.586-8.586z"></path>
                </svg>
                Edit RFQ
            </button>
        </div>
    </div>

    <!-- Status Overview -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-5 gap-6">
            <div>
                <p class="text-sm text-dark-500 font-medium">Status</p>
                <div class="mt-2">
                    <span class="badge-success">Sent to Suppliers</span>
                </div>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">RFQ Date</p>
                <p class="text-dark-900 font-semibold mt-2">Nov 15, 2024</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Deadline</p>
                <p class="text-dark-900 font-semibold mt-2">Nov 22, 2024</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Priority</p>
                <p class="text-dark-900 font-semibold mt-2">Urgent</p>
            </div>
            <div>
                <p class="text-sm text-dark-500 font-medium">Days Remaining</p>
                <p class="text-orange-600 font-semibold mt-2">5 days</p>
            </div>
        </div>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Left Sidebar -->
        <div class="space-y-6">
            <!-- RFQ Information -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">RFQ Information</h3>
                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium">RFQ Number</p>
                        <p class="text-dark-900 font-semibold mt-1">RFQ-2024-001</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Created By</p>
                        <p class="text-dark-900 font-semibold mt-1">Admin User</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Created Date</p>
                        <p class="text-dark-900 font-semibold mt-1">Nov 15, 2024 10:30 AM</p>
                    </div>
                    <div>
                        <p class="text-sm text-dark-500 font-medium">Last Modified</p>
                        <p class="text-dark-900 font-semibold mt-1">Nov 15, 2024 02:15 PM</p>
                    </div>
                </div>
            </div>

            <!-- Quote Status -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Quote Responses</h3>
                <div className="space-y-3">
                    <div>
                        <div class="flex items-center justify-between mb-2">
                            <p class="text-sm text-dark-700">Received</p>
                            <span class="font-bold text-dark-900">3 / 4</span>
                        </div>
                        <div class="w-full bg-dark-200 rounded-full h-3">
                            <div class="bg-green-500 h-3 rounded-full" style="width: 75%"></div>
                        </div>
                    </div>

                    <div className="pt-3 border-t border-dark-200 space-y-2 text-sm">
                        <div className="flex items-center space-x-2">
                            <span className="w-2 h-2 bg-green-500 rounded-full"></span>
                            <span className="text-dark-700">Parts Direct Inc.</span>
                            <span className="ml-auto text-dark-500">Nov 15</span>
                        </div>
                        <div className="flex items-center space-x-2">
                            <span className="w-2 h-2 bg-green-500 rounded-full"></span>
                            <span className="text-dark-700">Auto Components Ltd.</span>
                            <span className="ml-auto text-dark-500">Nov 14</span>
                        </div>
                        <div className="flex items-center space-x-2">
                            <span className="w-2 h-2 bg-green-500 rounded-full"></span>
                            <span className="text-dark-700">Global Auto Parts</span>
                            <span className="ml-auto text-dark-500">Nov 13</span>
                        </div>
                        <div className="flex items-center space-x-2">
                            <span className="w-2 h-2 bg-orange-500 rounded-full"></span>
                            <span className="text-dark-700">Premium Supplies Co.</span>
                            <span className="ml-auto text-dark-500">Pending</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Quick Actions -->
            <div class="card space-y-2">
                <button class="w-full btn-primary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8m0 8l-4-4m4 4l4-4"></path>
                    </svg>
                    Send Reminder
                </button>
                <button class="w-full btn-secondary flex items-center justify-center text-sm">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01"></path>
                    </svg>
                    Download PDF
                </button>
            </div>
        </div>

        <!-- Main Content -->
        <div class="lg:col-span-2 space-y-6">
            <!-- Items Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Items</h3>

                <div class="overflow-x-auto">
                    <table class="w-full">
                        <thead>
                            <tr class="border-b border-dark-200">
                                <th class="text-left py-4 px-4 font-semibold text-dark-900">Part Name</th>
                                <th class="text-left py-4 px-4 font-semibold text-dark-900">SKU</th>
                                <th class="text-right py-4 px-4 font-semibold text-dark-900">Qty</th>
                                <th class="text-left py-4 px-4 font-semibold text-dark-900">Unit</th>
                                <th class="text-left py-4 px-4 font-semibold text-dark-900">Specifications</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-dark-200">
                            <tr class="hover:bg-dark-50">
                                <td class="py-4 px-4 font-semibold text-dark-900">Engine Oil Filter</td>
                                <td class="py-4 px-4 text-dark-700">EOF-001</td>
                                <td class="text-right py-4 px-4 text-dark-700">500</td>
                                <td class="py-4 px-4 text-dark-700">Units</td>
                                <td class="py-4 px-4 text-dark-700">High quality, standard compatible</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>

            <!-- Suppliers Details -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-6">Suppliers Contacted</h3>

                <div class="space-y-4">
                    <!-- Supplier 1 -->
                    <div class="border border-dark-200 rounded-lg p-4">
                        <div class="flex items-center justify-between mb-3">
                            <div>
                                <p class="font-semibold text-dark-900">Parts Direct Inc.</p>
                                <p class="text-xs text-dark-500 mt-1">Lead Time: 5 days</p>
                            </div>
                            <span class="badge-success">Quoted</span>
                        </div>
                        <div class="grid grid-cols-2 gap-3 text-sm">
                            <div>
                                <p class="text-dark-500">Quote Date</p>
                                <p class="font-semibold text-dark-900">Nov 15, 2024</p>
                            </div>
                            <div>
                                <p class="text-dark-500">Response Time</p>
                                <p class="font-semibold text-dark-900">1 day</p>
                            </div>
                        </div>
                    </div>

                    <!-- Supplier 2 -->
                    <div class="border border-dark-200 rounded-lg p-4">
                        <div class="flex items-center justify-between mb-3">
                            <div>
                                <p class="font-semibold text-dark-900">Auto Components Ltd.</p>
                                <p class="text-xs text-dark-500 mt-1">Lead Time: 7 days</p>
                            </div>
                            <span class="badge-success">Quoted</span>
                        </div>
                        <div class="grid grid-cols-2 gap-3 text-sm">
                            <div>
                                <p class="text-dark-500">Quote Date</p>
                                <p class="font-semibold text-dark-900">Nov 14, 2024</p>
                            </div>
                            <div>
                                <p class="text-dark-500">Response Time</p>
                                <p class="font-semibold text-dark-900">2 days</p>
                            </div>
                        </div>
                    </div>

                    <!-- Supplier 3 -->
                    <div class="border border-dark-200 rounded-lg p-4">
                        <div class="flex items-center justify-between mb-3">
                            <div>
                                <p class="font-semibold text-dark-900">Global Auto Parts</p>
                                <p class="text-xs text-dark-500 mt-1">Lead Time: 10 days</p>
                            </div>
                            <span class="badge-success">Quoted</span>
                        </div>
                        <div class="grid grid-cols-2 gap-3 text-sm">
                            <div>
                                <p class="text-dark-500">Quote Date</p>
                                <p class="font-semibold text-dark-900">Nov 13, 2024</p>
                            </div>
                            <div>
                                <p class="text-dark-500">Response Time</p>
                                <p class="font-semibold text-dark-900">3 days</p>
                            </div>
                        </div>
                    </div>

                    <!-- Supplier 4 (Pending) -->
                    <div class="border border-orange-200 bg-orange-50 rounded-lg p-4">
                        <div class="flex items-center justify-between mb-3">
                            <div>
                                <p class="font-semibold text-dark-900">Premium Supplies Co.</p>
                                <p class="text-xs text-dark-500 mt-1">Lead Time: 6 days</p>
                            </div>
                            <span class="badge-warning">Pending</span>
                        </div>
                        <div class="grid grid-cols-2 gap-3 text-sm">
                            <div>
                                <p class="text-dark-500">Sent Date</p>
                                <p class="font-semibold text-dark-900">Nov 12, 2024</p>
                            </div>
                            <div>
                                <p class="text-dark-500">Days Since Sent</p>
                                <p class="font-semibold text-orange-600">3 days</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Delivery Terms -->
            <div class="card">
                <h3 class="text-lg font-bold text-dark-900 mb-4">Delivery Terms & Notes</h3>

                <div class="space-y-4">
                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Preferred Delivery Location</p>
                        <p class="text-dark-900">Main Warehouse</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Delivery Method</p>
                        <p class="text-dark-900">Supplier's Choice</p>
                    </div>

                    <div>
                        <p class="text-sm text-dark-500 font-medium mb-2">Notes</p>
                        <p class="text-dark-900 bg-dark-50 rounded-lg p-3">Please provide competitive pricing for bulk orders. Include shipping cost in your quote.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load RFQ details
    }
}
