@page "/customers"
@rendermode InteractiveServer

<PageTitle>Customers - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Customers</h1>
            <p class="text-dark-500 mt-1">Manage and track all your customers</p>
        </div>
        <a href="/customers/create" class="btn-primary flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Add New Customer
        </a>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Total Customers -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium">Total Customers</p>
                    <p class="text-3xl font-bold text-dark-900 mt-2">1,234</p>
                </div>
                <div class="w-12 h-12 bg-primary-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-2a6 6 0 0112 0v2zm0 0h6v-2a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Active Customers -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium">Active Customers</p>
                    <p class="text-3xl font-bold text-dark-900 mt-2">987</p>
                </div>
                <div class="w-12 h-12 bg-green-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Total Revenue -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium">Total Revenue</p>
                    <p class="text-3xl font-bold text-dark-900 mt-2">₹45.2L</p>
                </div>
                <div class="w-12 h-12 bg-emerald-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-emerald-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Inactive Customers -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium">Inactive Customers</p>
                    <p class="text-3xl font-bold text-dark-900 mt-2">247</p>
                </div>
                <div class="w-12 h-12 bg-orange-100 rounded-lg flex items-center justify-center">
                    <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18.364 5.636l-3.536 3.536m0 5.656l3.536 3.536M9.172 9.172L5.636 5.636m3.536 9.192l-3.536 3.536M21 12a9 9 0 11-18 0 9 9 0 0118 0zm-5 0a4 4 0 11-8 0 4 4 0 018 0z"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters -->
    <div class="card">
        <div class="grid grid-cols-1 md:grid-cols-3 lg:grid-cols-5 gap-4">
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Search Customer</label>
                <input type="text" placeholder="Name, email, phone..." class="input-field" />
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                <select class="input-field">
                    <option>All Status</option>
                    <option selected>Active</option>
                    <option>Inactive</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Customer Type</label>
                <select class="input-field">
                    <option selected>All Types</option>
                    <option>Retail</option>
                    <option>Wholesale</option>
                    <option>Corporate</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">City</label>
                <select class="input-field">
                    <option selected>All Cities</option>
                    <option>Mumbai</option>
                    <option>Delhi</option>
                    <option>Bangalore</option>
                </select>
            </div>
            <div class="flex items-end">
                <button class="btn-primary w-full">
                    <svg class="w-4 h-4 mr-2 inline-block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                    Search
                </button>
            </div>
        </div>
    </div>

    <!-- Customers Table -->
    <div class="card overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full">
                <thead>
                    <tr class="border-b border-dark-200 bg-dark-50">
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Customer Name</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Email</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Phone</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">City</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Type</th>
                        <th class="text-right py-3 px-4 font-semibold text-dark-900">Total Orders</th>
                        <th class="text-right py-3 px-4 font-semibold text-dark-900">Total Spent</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-dark-200">
                    <!-- Customer 1 -->
                    <tr class="hover:bg-dark-50 transition-colors">
                        <td class="py-4 px-4 font-semibold text-dark-900">Sharma Auto Parts</td>
                        <td class="py-4 px-4 text-dark-700">sharma@autoparts.com</td>
                        <td class="py-4 px-4 text-dark-700">+91 98765 43210</td>
                        <td class="py-4 px-4 text-dark-700">Mumbai</td>
                        <td class="text-center py-4 px-4"><span class="badge-info">Retail</span></td>
                        <td class="text-right py-4 px-4 text-dark-700">45</td>
                        <td class="text-right py-4 px-4 text-dark-700">₹2,45,000</td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                        <td class="text-center py-4 px-4">
                            <div class="flex items-center justify-center gap-2">
                                <a href="/customers/C-001/view" class="text-primary-600 hover:text-primary-700" title="View">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                </a>
                                <a href="/customers/C-001/edit" class="text-sky-600 hover:text-sky-700" title="Edit">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>

                    <!-- Customer 2 -->
                    <tr class="hover:bg-dark-50 transition-colors">
                        <td class="py-4 px-4 font-semibold text-dark-900">Tech Engine Solutions</td>
                        <td class="py-4 px-4 text-dark-700">contact@techengine.com</td>
                        <td class="py-4 px-4 text-dark-700">+91 98765 54321</td>
                        <td class="py-4 px-4 text-dark-700">Bangalore</td>
                        <td class="text-center py-4 px-4"><span class="badge-warning">Wholesale</span></td>
                        <td class="text-right py-4 px-4 text-dark-700">128</td>
                        <td class="text-right py-4 px-4 text-dark-700">₹8,75,000</td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                        <td class="text-center py-4 px-4">
                            <div class="flex items-center justify-center gap-2">
                                <a href="/customers/C-002/view" class="text-primary-600 hover:text-primary-700" title="View">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                </a>
                                <a href="/customers/C-002/edit" class="text-sky-600 hover:text-sky-700" title="Edit">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>

                    <!-- Customer 3 -->
                    <tr class="hover:bg-dark-50 transition-colors">
                        <td class="py-4 px-4 font-semibold text-dark-900">Drive Forward Ltd</td>
                        <td class="py-4 px-4 text-dark-700">info@driveforward.com</td>
                        <td class="py-4 px-4 text-dark-700">+91 98765 65432</td>
                        <td class="py-4 px-4 text-dark-700">Delhi</td>
                        <td class="text-center py-4 px-4"><span class="badge-primary">Corporate</span></td>
                        <td class="text-right py-4 px-4 text-dark-700">89</td>
                        <td class="text-right py-4 px-4 text-dark-700">₹12,34,000</td>
                        <td class="text-center py-4 px-4"><span class="badge-success">Active</span></td>
                        <td class="text-center py-4 px-4">
                            <div class="flex items-center justify-center gap-2">
                                <a href="/customers/C-003/view" class="text-primary-600 hover:text-primary-700" title="View">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                </a>
                                <a href="/customers/C-003/edit" class="text-sky-600 hover:text-sky-700" title="Edit">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>

                    <!-- Customer 4 -->
                    <tr class="hover:bg-dark-50 transition-colors">
                        <td class="py-4 px-4 font-semibold text-dark-900">Mechanic's Hub</td>
                        <td class="py-4 px-4 text-dark-700">service@mechanicshub.com</td>
                        <td class="py-4 px-4 text-dark-700">+91 98765 76543</td>
                        <td class="py-4 px-4 text-dark-700">Pune</td>
                        <td class="text-center py-4 px-4"><span class="badge-info">Retail</span></td>
                        <td class="text-right py-4 px-4 text-dark-700">23</td>
                        <td class="text-right py-4 px-4 text-dark-700">₹1,12,000</td>
                        <td class="text-center py-4 px-4"><span class="badge-danger">Inactive</span></td>
                        <td class="text-center py-4 px-4">
                            <div class="flex items-center justify-center gap-2">
                                <a href="/customers/C-004/view" class="text-primary-600 hover:text-primary-700" title="View">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"></path>
                                    </svg>
                                </a>
                                <a href="/customers/C-004/edit" class="text-sky-600 hover:text-sky-700" title="Edit">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                                    </svg>
                                </a>
                            </div>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Pagination -->
        <div class="border-t border-dark-200 px-4 py-4 flex items-center justify-between">
            <p class="text-sm text-dark-600">Showing 1 to 4 of 1,234 customers</p>
            <div class="flex gap-2">
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-50 transition-colors text-sm">Previous</button>
                <button class="px-3 py-2 bg-primary-600 text-white rounded-lg hover:bg-primary-700 transition-colors text-sm">1</button>
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-50 transition-colors text-sm">2</button>
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-50 transition-colors text-sm">3</button>
                <button class="px-3 py-2 border border-dark-200 rounded-lg text-dark-700 hover:bg-dark-50 transition-colors text-sm">Next</button>
            </div>
        </div>
    </div>
</div>

@code {
    protected override void OnInitialized()
    {
        // Load customers data
    }
}
