@page "/invoices/{id}/view"

<PageTitle>View Invoice - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Invoice</h1>
            <p class="text-dark-500 mt-1">INV-2024-127 • Sharma Auto Parts</p>
        </div>
        <div class="flex flex-col sm:flex-row gap-2 flex-shrink-0">
            <a href="/invoices" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Back
            </a>
            <a href="/invoices/{id}/edit" class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Edit Invoice
            </a>
        </div>
    </div>

    <!-- Invoice Preview -->
    <div class="card">
        <!-- Invoice Header -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6 pb-6 border-b border-dark-200">
            <div>
                <h2 class="text-2xl font-bold text-dark-900 mb-2">INVOICE</h2>
                <p class="text-dark-500">Invoice #: INV-2024-127</p>
                <p class="text-dark-500">Order #: ORD-2024-152</p>
            </div>
            <div class="text-right">
                <p class="text-sm text-dark-500 mb-1">Invoice Date</p>
                <p class="text-dark-900 font-semibold">Dec 20, 2024</p>
                <p class="text-sm text-dark-500 mt-3 mb-1">Due Date</p>
                <p class="text-dark-900 font-semibold">Dec 27, 2024</p>
            </div>
        </div>

        <!-- Company & Customer Info -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-12 py-6 border-b border-dark-200">
            <div>
                <p class="text-xs font-semibold text-dark-500 mb-3">FROM</p>
                <p class="font-bold text-dark-900">AutoParts Shop</p>
                <p class="text-sm text-dark-700">Mumbai, Maharashtra</p>
                <p class="text-sm text-dark-700">India</p>
                <p class="text-sm text-dark-700 mt-2">Email: contact@autoparts.com</p>
                <p class="text-sm text-dark-700">Phone: +91-22-XXXX-XXXX</p>
            </div>
            <div>
                <p class="text-xs font-semibold text-dark-500 mb-3">BILL TO</p>
                <p class="font-bold text-dark-900">Sharma Auto Parts</p>
                <p class="text-sm text-dark-700">Contact: Rajesh Sharma</p>
                <p class="text-sm text-dark-700">123, Auto Parts Street, Dadar East</p>
                <p class="text-sm text-dark-700">Mumbai 400014, Maharashtra, India</p>
                <p class="text-sm text-dark-700 mt-2">Email: sharma@autoparts.com</p>
                <p class="text-sm text-dark-700">Phone: +91 98765 43210</p>
            </div>
        </div>

        <!-- Invoice Items -->
        <div class="py-6 border-b border-dark-200">
            <table class="w-full text-sm">
                <thead>
                    <tr class="border-b border-dark-200">
                        <th class="text-left py-3 font-semibold text-dark-900">Description</th>
                        <th class="text-left py-3 font-semibold text-dark-900">SKU</th>
                        <th class="text-right py-3 font-semibold text-dark-900">Unit Price</th>
                        <th class="text-right py-3 font-semibold text-dark-900">Qty</th>
                        <th class="text-right py-3 font-semibold text-dark-900">Amount</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-dark-200">
                    <tr>
                        <td class="py-4 text-dark-900">Engine Oil Filter</td>
                        <td class="py-4 text-dark-700">EOF-001</td>
                        <td class="text-right py-4 text-dark-700">₹450</td>
                        <td class="text-right py-4 text-dark-700">10</td>
                        <td class="text-right py-4 font-semibold text-dark-900">₹4,500</td>
                    </tr>
                    <tr>
                        <td class="py-4 text-dark-900">Brake Pad Set</td>
                        <td class="py-4 text-dark-700">BPS-002</td>
                        <td class="text-right py-4 text-dark-700">₹1,200</td>
                        <td class="text-right py-4 text-dark-700">5</td>
                        <td class="text-right py-4 font-semibold text-dark-900">₹6,000</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Invoice Summary -->
        <div class="py-6 flex justify-end">
            <div class="w-full md:w-80">
                <div class="flex justify-between mb-3">
                    <p class="text-dark-900">Subtotal:</p>
                    <p class="text-dark-900 font-semibold">₹10,500</p>
                </div>
                <div class="flex justify-between mb-3">
                    <p class="text-dark-900">Tax (18%):</p>
                    <p class="text-dark-900 font-semibold">₹1,890</p>
                </div>
                <div class="flex justify-between pt-3 border-t-2 border-dark-300">
                    <p class="text-dark-900 font-bold">Total Amount Due:</p>
                    <p class="text-dark-900 font-bold text-lg">₹12,390</p>
                </div>
            </div>
        </div>

        <!-- Payment Status -->
        <div class="py-6 border-t border-dark-200">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div>
                    <p class="text-xs font-semibold text-dark-500 mb-1">PAYMENT STATUS</p>
                    <span class="badge-success">Paid</span>
                </div>
                <div>
                    <p class="text-xs font-semibold text-dark-500 mb-1">AMOUNT PAID</p>
                    <p class="text-dark-900 font-semibold">₹12,390</p>
                </div>
                <div>
                    <p class="text-xs font-semibold text-dark-500 mb-1">PAYMENT DATE</p>
                    <p class="text-dark-900 font-semibold">Dec 21, 2024</p>
                </div>
            </div>
        </div>

        <!-- Notes -->
        <div class="py-6 border-t border-dark-200">
            <p class="text-xs font-semibold text-dark-500 mb-2">NOTES</p>
            <p class="text-sm text-dark-700">Payment due within 30 days of invoice date. 2% discount if paid within 10 days.</p>
        </div>

        <!-- Action Buttons -->
        <div class="pt-6 border-t border-dark-200 flex flex-col sm:flex-row gap-2 sm:gap-4">
            <a href="/invoices" class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
                </svg>
                Back to List
            </a>
            <a href="/invoices/{id}/edit" class="btn-primary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
                </svg>
                Edit Invoice
            </a>
            <button class="btn-secondary flex items-center justify-center">
                <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path>
                </svg>
                Download PDF
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string? Id { get; set; }

    protected override void OnInitialized()
    {
        // Load invoice details
    }
}
