                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Order ID</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Customer</th>
                        <th class="text-right py-3 px-4 font-semibold text-dark-900">Amount</th>
                        <th class="text-left py-3 px-4 font-semibold text-dark-900">Return Date</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Status</th>
                        <th class="text-center py-3 px-4 font-semibold text-dark-900">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-dark-200">
