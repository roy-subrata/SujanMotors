@page "/sales/returns"
@rendermode InteractiveServer

<PageTitle>Customer Returns - AutoParts Shop</PageTitle>

<div class="space-y-6">
    <!-- Page Header -->
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
        <div>
            <h1 class="text-3xl font-bold text-dark-900">Customer Returns</h1>
            <p class="text-dark-500 mt-1">Manage product returns and refunds</p>
        </div>
        <button class="btn-primary flex items-center justify-center flex-shrink-0">
            <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
            </svg>
            Create Return
        </button>
    </div>

    <!-- Statistics Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
        <!-- Total Returns -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Total Returns</p>
                    <p class="text-2xl font-bold text-dark-900">18</p>
                </div>
                <div class="p-3 bg-primary-100 rounded-lg">
                    <svg class="w-6 h-6 text-primary-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 7h6m0 10v-3m-3 3v.01M9 17h.01M9 14h.01M12 14h.01M15 11h.01M12 11h.01M9 11h.01M7 21h10a2 2 0 002-2V5a2 2 0 00-2-2H7a2 2 0 00-2 2v14a2 2 0 002 2z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Pending Returns -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Pending Returns</p>
                    <p class="text-2xl font-bold text-dark-900">5</p>
                </div>
                <div class="p-3 bg-orange-100 rounded-lg">
                    <svg class="w-6 h-6 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Refunded Amount -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Refunded Amount</p>
                    <p class="text-2xl font-bold text-dark-900">₹42.3K</p>
                </div>
                <div class="p-3 bg-red-100 rounded-lg">
                    <svg class="w-6 h-6 text-red-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Return Rate -->
        <div class="card">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm text-dark-500 font-medium mb-1">Return Rate</p>
                    <p class="text-2xl font-bold text-dark-900">2.3%</p>
                </div>
                <div class="p-3 bg-green-100 rounded-lg">
                    <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7H6v10a1 1 0 001 1h10a1 1 0 001-1V9a1 1 0 00-1-1m-6 0V4a1 1 0 011-1h4a1 1 0 011 1v3M9 17v-4"></path>
                    </svg>
                </div>
            </div>
        </div>
    </div>

    <!-- Filters Section -->
    <div class="card">
        <h3 class="text-lg font-bold text-dark-900 mb-4">Filters</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-4">
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Search Return</label>
                <input type="text" placeholder="Search by Return ID or Order..." class="input-field" />
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Status</label>
                <select class="input-field">
                    <option selected>All Status</option>
                    <option>Pending</option>
                    <option>Received</option>
                    <option>Approved</option>
                    <option>Refunded</option>
                    <option>Rejected</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Customer</label>
                <select class="input-field">
                    <option selected>All Customers</option>
                    <option>Sharma Auto Parts</option>
                    <option>Tech Engine Solutions</option>
                    <option>Drive Forward Ltd</option>
                </select>
            </div>
            <div>
                <label class="block text-sm font-medium text-dark-900 mb-2">Date Range</label>
                <input type="date" class="input-field" />
            </div>
        </div>
    </div>

    <!-- Returns Table -->
    <div class="card">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-lg font-bold text-dark-900">Recent Returns</h3>
            <span class="text-sm text-dark-500">Showing 1-10 of 18 returns</span>
        </div>

