APP_NAME=AutoPartShop.AI
APP_ENV=production
APP_PORT=8088
LOG_LEVEL=INFO

# LLM configuration
OPENAI_API_KEY=replace-with-your-key
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4.1-mini
LLM_TEMPERATURE=0.1

# AutoPartShop API integration
AUTOPARTSHOP_API_BASE_URL=http://autopartshop.api:8080
AUTOPARTSHOP_API_TIMEOUT_SECONDS=30
AUTOPARTSHOP_API_BEARER_TOKEN=

# Qdrant configuration
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=autopartshop_customer_memory
QDRANT_VECTOR_SIZE=1536

# Business defaults
DEFAULT_WAREHOUSE=A
LOW_STOCK_THRESHOLD=5
