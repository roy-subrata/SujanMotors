{
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft.AspNetCore": "Warning"
        }
    },
    "AllowedHosts": "*",
    "Cors": {
        // Explicit cross-origin allow-list applied in non-Development environments.
        // List every frontend origin (scheme + host + port) that may call this API,
        // e.g. "https://shop.example.com". Development ignores this and echoes any origin.
        "AllowedOrigins": []
    },
    "JwtSettings": {
        // SecretKey must be supplied per-environment via user-secrets (dev),
        // environment variables, or a secrets vault. Never commit a real key.
        "SecretKey": "",
        "Issuer": "AutoPartShopAPI",
        "Audience": "AutoPartShopClient",
        "ExpiryInMinutes": 60,
        "RefreshTokenExpiryInDays": 7
    },
    "ConnectionStrings": {
        // Supplied per-environment (appsettings.Development.json for local dev,
        // env vars / vault for production). Do not commit production credentials.
        "AutoPartDb": ""
    },
    "Otel": {
        "Endpoint": "http://otel-collector:4317",
        "ServiceName": "autopartshop-api"
    },
    "ReorderAlerts": {
        // Daily staff broadcast (SignalR bell) listing items at/below their reorder level.
        // LocalTime is the shop's wall clock; TzOffsetMinutes shifts UTC (360 = UTC+6, Bangladesh).
        "Enabled": true,
        "LocalTime": "09:30",
        "TzOffsetMinutes": 360
    },
    "Twilio": {
        // Supplied per-environment via appsettings.Development.json (gitignored) for local dev,
        // or env vars / vault in production (Twilio__AccountSid, Twilio__AuthToken, etc.).
        // Never commit real Twilio credentials to this tracked file.
        "AccountSid": "",
        "AuthToken": "",
        "SmsMsgServiceSid": "",
        "WhatsAppMsgServiceSid": ""
    },
    "Smtp": {
        "Host": "",
        "Port": "587",
        "Username": "",
        "Password": "",
        "FromEmail": "",
        "FromName": "SujanMotors",
        "UseSsl": "false"
    },
    "sms":{
        // Supplied per-environment (appsettings.Development.json locally, env var sms__apiKey in prod).
        // Never commit a real SMS API key to this tracked file.
        "apiKey": ""
    },
    "FileStorage": {
        // Uploaded files (product media, employee photos/documents).
        // Local: blobs live under RootPath (default {ContentRoot}/App_Data/uploads).
        // On the VPS, bind-mount RootPath into the container so files survive rebuilds,
        // and include it in the backup strategy alongside the database.
        // PublicBaseUrl (optional): absolute prefix for returned file URLs, e.g.
        // "https://api.example.com" — leave empty to return relative URLs.
        "Provider": "Local",
        "PublicBaseUrl": "",
        "Local": {
            "RootPath": ""
        }
    },
    "Embedding": {
        // Product semantic search. Leave BaseUrl blank to disable (search falls back to keyword).
        // OpenAI-compatible: BaseUrl is the host root (e.g. "https://api.openai.com" or "http://localhost:11434").
        // Provide ApiKey via user-secrets / env (Embedding__ApiKey). Dimensions must match the
        // vector(N) column (default 1536 = text-embedding-3-small); changing it requires a migration.
        "Provider": "openai",
        "BaseUrl": "",
        "ApiKey": "",
        "Model": "text-embedding-3-small",
        "Dimensions": 1536
    },
    "Serilog": {
        "MinimumLevel": {
            "Default": "Information",
            "Override": {
                "Microsoft.AspNetCore": "Warning",
                "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
                "Microsoft.EntityFrameworkCore.Infrastructure": "Warning"
            }
        }
    }
}
