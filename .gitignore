# .gitignore for a .NET project
bin/
obj/
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
.nuget/
*.nupkg
packages/
# Rider
.idea/
# Visual Studio Code
.vscode/
# macOS
.DS_Store
# Logs
*.log
# Temporary
*.tmp
# Windows reserved filename created accidentally
nul
# node
node_modules/
# Environment / secrets — never commit real credentials.
# Use `dotnet user-secrets` for local secrets, or environment variables in Docker/CI.
# The appsettings.*.json files below are tracked with EMPTY placeholder values.
.env
.env.*
!.env.example
# Claude Code worktrees (temporary agent sandboxes)
.claude/worktrees/
