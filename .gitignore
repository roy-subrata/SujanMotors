# .gitignore for a .NET project
bin/
obj/
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates
.nuget/
*.nupkg
packages/
# Rider
.idea/
# Visual Studio Code
.vscode/
# macOS
.DS_Store
# Logs
*.log
# local settings
appsettings.*.json
# Temporary
*.tmp
# Windows reserved filename created accidentally
nul
# node
node_modules/
# Environment / secrets — never commit these
.env
.env.*
!.env.example
appsettings.Development.json
appsettings.Production.json
# Claude Code worktrees (temporary agent sandboxes)
.claude/worktrees/
