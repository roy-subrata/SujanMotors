# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Database
DB_PASSWORD=YourStrong!Passw0rd
DB_NAME=AutoPartShopDb

# JWT
JWT_SECRET=YourSuperSecretKeyForJWTTokenGenerationMustBe32CharsLong!@#
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_DAYS=7

# Twilio (SMS / WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_SID=
TWILIO_WHATSAPP_SID=

# SMTP (Email)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SujanMotors
