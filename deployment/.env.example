# Copy this file to .env and fill in real values.
# .env is gitignored — never commit real secrets.

# Database
DB_PASSWORD=YourStrong!Passw0rd
DB_NAME=AutoPartShopDb

# JWT (must be ≥ 32 characters)
JWT_SECRET=YourSuperSecretKeyForJWTTokenGenerationMustBe32CharsLong!@#
JWT_EXPIRY_MINUTES=60
JWT_REFRESH_DAYS=7

# CORS — origins allowed to call this API (scheme + host + port)
# For staging: https://sujanmotors-test.azurestaticapps.net
# For production: https://sujanmotors.azurestaticapps.net
CORS_ORIGIN_0=https://sujanmotors.azurestaticapps.net

# Twilio (SMS / WhatsApp) — leave blank to disable
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_SID=
TWILIO_WHATSAPP_SID=

# SMTP (Email) — leave blank to disable
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SujanMotors

# SMS API (smsnetbd) — leave blank to disable
SMS_API_KEY=

# OpenAI Embedding — leave blank to disable semantic search
EMBEDDING_API_KEY=
