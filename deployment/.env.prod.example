# =============================================================================
# PRODUCTION ENVIRONMENT — Environment Variables Template
# =============================================================================
#
# SETUP INSTRUCTIONS:
#   1. Copy this file to .env in the SAME directory:
#        cp .env.prod.example .env
#   2. Fill in ALL real values below (use strong passwords!)
#   3. The .env file is gitignored — NEVER commit it to version control
#
# WHERE THIS IS USED:
#   This file provides secrets to docker-compose.yml on the VPS.
#   The production stack lives at: /opt/sujanmotors/
#   Apply with: docker compose --env-file deployment/.env -f deployment/docker-compose.yml -f deployment/docker-compose.prod.yml up --build -d
#
# ⚠️  SECURITY NOTES:
#   - Use a STRONG, UNIQUE DB_PASSWORD (not the default!)
#   - Generate a real JWT_SECRET (random 64+ char string)
#   - All Twilio/SMTP credentials should be real production credentials
#   - This file should ONLY exist on the VPS, never in version control
#
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SA_PASSWORD: SQL Server SA account password
#   - Must meet SQL Server complexity requirements (8+ chars, uppercase, lowercase, number, special char)
#   - Use a DIFFERENT password than test environment!
DB_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD

# DB_NAME: Name of the SQL Server database
#   - Auto-created on first API startup (migrations run automatically)
DB_NAME=AutoPartShopProdDb

# ---------------------------------------------------------------------------
# JWT (JSON Web Token) Authentication
# ---------------------------------------------------------------------------
# JWT_SECRET: Key used to sign JWT tokens (must be 32+ characters)
#   - Generate with: openssl rand -base64 64
#   - ⚠️  MUST be different from the test environment secret!
JWT_SECRET=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# JWT_EXPIRY_MINUTES: How long an access token is valid (in minutes)
JWT_EXPIRY_MINUTES=60

# JWT_REFRESH_DAYS: How long a refresh token is valid (in days)
JWT_REFRESH_DAYS=7

# ---------------------------------------------------------------------------
# Twilio (SMS / WhatsApp notifications)
# ---------------------------------------------------------------------------
# Required for order status notifications. Get from twilio.com console.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_SID=
TWILIO_WHATSAPP_SID=

# ---------------------------------------------------------------------------
# SMTP (Email notifications)
# ---------------------------------------------------------------------------
# Required for email notifications (order confirmations, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SujanMotors

# Seed settings — auto-create admin user on first run
SEED_ADMIN_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
