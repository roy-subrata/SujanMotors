# =============================================================================
# TEST ENVIRONMENT — Environment Variables Template
# =============================================================================
#
# SETUP INSTRUCTIONS:
#   1. Copy this file to .env in the SAME directory:
#        cp .env.test.example .env
#   2. Fill in real values below (especially passwords and secrets!)
#   3. The .env file is gitignored — NEVER commit it to version control
#
# WHERE THIS IS USED:
#   This file provides secrets to docker-compose.test.yml on the VPS.
#   The test stack lives at: /opt/sujanmotors-test/
#   Apply with: docker compose --env-file deployment/.env -f deployment/docker-compose.test.yml up --build -d
#
# =============================================================================

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SA_PASSWORD: SQL Server SA account password
#   - Must meet SQL Server complexity requirements (8+ chars, uppercase, lowercase, number, special char)
#   - Used by both the DB container and the API to connect
DB_PASSWORD=Test!Passw0rd2024

# DB_NAME: Name of the SQL Server database to create/use
#   - Auto-created on first API startup (migrations run automatically)
#   - Different from production to avoid confusion
DB_NAME=AutoPartShopTestDb

# ---------------------------------------------------------------------------
# JWT (JSON Web Token) Authentication
# ---------------------------------------------------------------------------
# JWT_SECRET: Key used to sign JWT tokens (must be 32+ characters)
#   - Generate a strong random string for real environments
#   - NEVER use this default value in production!
JWT_SECRET=YourSuperSecretKeyForJWTTokenGenerationMustBe32CharsLong!@#

# JWT_EXPIRY_MINUTES: How long an access token is valid (in minutes)
JWT_EXPIRY_MINUTES=60

# JWT_REFRESH_DAYS: How long a refresh token is valid (in days)
JWT_REFRESH_DAYS=7

# ---------------------------------------------------------------------------
# Twilio (SMS / WhatsApp notifications)
# ---------------------------------------------------------------------------
# Leave blank if not using Twilio. Required for order status SMS/WhatsApp.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_SID=
TWILIO_WHATSAPP_SID=

# ---------------------------------------------------------------------------
# SMTP (Email notifications)
# ---------------------------------------------------------------------------
# Leave blank if not using email notifications.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=SujanMotors
